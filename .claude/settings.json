{
  "enabledPlugins": {
    "frontend-design@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Agent",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-dispatch.mjs\" 2>/dev/null || true",
            "statusMessage": "Logging dispatch"
          }
        ]
      }
    ]
  }
}
