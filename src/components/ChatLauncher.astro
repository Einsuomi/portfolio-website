---
/**
 * Persistent chatbot launcher — fixed bottom-right, present from the hero down so
 * the differentiator is never missed. It's an anchor to the chatbot climax section,
 * so it always does something real and degrades perfectly without JS (no dead control).
 * Becomes a real chat toggle when the backend lands.
 */
---

<!-- data-fixed-chrome: intentional floating UI, exempt from the verify-ui
     content-overlap check (it rides over content by design, like any chat FAB). -->
<a class="launcher" href="#chatbot" aria-label="Talk to the assistant about Tong" data-fixed-chrome>
  <svg class="launcher__icon" viewBox="0 0 24 24" aria-hidden="true" fill="none">
    <path d="M4 5h16v11H8l-4 4V5z" stroke="currentColor" stroke-width="1.6"
          stroke-linejoin="round" />
  </svg>
  <span class="launcher__label">Talk</span>
</a>

<script>
  // With JS, the launcher opens the floating chat panel instead of jump-scrolling
  // to the section. Without JS, the anchor href="#chatbot" still works (fallback).
  const launcher = document.querySelector('.launcher');
  launcher?.addEventListener('click', (e) => {
    e.preventDefault();
    document.dispatchEvent(new CustomEvent('chat:open', { detail: { from: 'launcher' } }));
  });
</script>

<style>
  .launcher {
    position: fixed; z-index: 50;
    right: clamp(1rem, 3vw, 1.8rem);
    bottom: clamp(1rem, 3vw, 1.8rem);
    display: inline-flex; align-items: center; gap: 0.55rem;
    padding: 0.7rem 1.05rem 0.7rem 0.85rem;
    background: var(--gold); color: #1a1206;
    border-radius: 999px; text-decoration: none;
    overflow: hidden; /* clip the shimmer sweep to the pill */
    font-family: var(--font-mono); font-size: 0.82rem; font-weight: 500;
    letter-spacing: 0.04em;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45);
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .launcher:hover, .launcher:focus-visible {
    transform: translateY(-2px);
    box-shadow: 0 14px 38px rgba(0, 0, 0, 0.55);
  }
  /* Keep the icon + label above the shimmer sweep. */
  .launcher__icon, .launcher__label { position: relative; z-index: 1; }
  .launcher__icon { width: 19px; height: 19px; flex: none; }

  /* A bright sheen sweeping across the gold pill, plus a soft attention pulse,
     so the launcher draws the eye. Motion-allowed only — under reduced motion
     it stays a plain gold pill (the sheen never renders, the pulse never plays). */
  @media (prefers-reduced-motion: no-preference) {
    .launcher { animation: launcher-pulse 3.4s ease-in-out infinite; }
    .launcher::before {
      content: '';
      position: absolute; inset: 0; z-index: 0;
      pointer-events: none;
      background: linear-gradient(
        120deg,
        transparent 35%,
        rgba(255, 246, 228, 0.6) 50%,
        transparent 65%
      );
      background-size: 250% 100%;
      animation: launcher-shimmer 3.6s linear infinite;
    }
  }
  @keyframes launcher-shimmer {
    from { background-position: 150% 0; }
    to   { background-position: -50% 0; }
  }
  @keyframes launcher-pulse {
    0%, 100% { box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45); }
    50%      { box-shadow: 0 10px 30px rgba(0, 0, 0, 0.45),
                           0 0 0 5px rgba(224, 163, 62, 0.16); }
  }

  /* Tighten to an icon-only pill on small screens to avoid covering content. */
  @media (max-width: 30rem) {
    .launcher__label { display: none; }
    .launcher { padding: 0.7rem; }
  }
</style>
