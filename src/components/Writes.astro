---
/**
 * Writes — ONE tall transparent-glass card (chatbot-width, the shared
 * [data-spotlight] card treatment) holding every write as a numbered list
 * (01, 02, 03…). The list scrolls INSIDE the card only — the scroll is captured
 * there (overscroll-behavior: contain) so paging through writes never scrolls the
 * section. Each numbered row links to its own on-site detail page (/writes/<slug>).
 */
import { WRITES } from '../lib/timeline';
---

<section class="section section--scene section--stack writes" id="writes" aria-label="Writes">
  <div class="section__inner">
    <h2 class="writes__head" data-reveal>Writing</h2>

    <!-- The single card carries the glass + spotlight treatment; the inner list
         is the only scroll surface. -->
    <div class="writes__card" data-spotlight data-reveal>
      <ol class="writes__list">
        {WRITES.map((w, i) => (
          <li class="wrow" transition:name={`write-${w.slug}`}>
            <a class="wrow__link" href={`/writes/${w.slug}`}>
              <span class="wrow__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
              <span class="wrow__text">
                <span class="wrow__title">{w.title}</span>
                <span class="wrow__summary">{w.summary}</span>
              </span>
              <span class="wrow__arrow" aria-hidden="true">→</span>
            </a>
          </li>
        ))}
      </ol>
    </div>
  </div>
</section>

<style>
  .writes { display: flex; flex-direction: column; justify-content: center; }
  /* Left-anchor the whole block (header + card) to the hero's content inset
     (--pad-x + 2.5vw) so WRITING lines up under TONG NIE and EXPERIENCE instead
     of floating centred in the middle of the page. Mirrors Experience's anchor.
     The translateY nudge (on this no-reveal wrapper, so it never clashes with the
     reveal animation) lifts the block a touch above dead-centre. */
  .writes .section__inner {
    /* margin-right:0 (not auto) keeps the flex item STRETCHED to --maxw instead
       of shrink-wrapping to its content — so the card holds the full width even
       when the inner text is capped. margin-left is the hero inset. */
    width: 100%; max-width: var(--maxw);
    margin-left: 2.5vw; margin-right: 0;
    transform: translateY(clamp(-4rem, -8vh, -1.5rem));
  }
  /* Promoted section heading — confident Bricolage title, no kicker. */
  .writes__head {
    font-family: var(--font-display); font-weight: 800;
    font-size: var(--t-lg); line-height: var(--lh-tight);
    text-transform: uppercase; letter-spacing: var(--track-machine);
    color: var(--ink); margin: 0 0 var(--space-md);
  }

  /* The one card — transparent glass over the scene, width-matched to the chatbot
     composer. overflow: hidden keeps the spotlight ring on its own border (the
     inner list, not this box, is what scrolls). Caps at a max height, then the
     list inside scrolls. */
  .writes__card {
    width: 100%;
    /* Widen to the Experience block's measure (--maxw) so, left-anchored, the
       card's right edge meets EXPERIENCE's — both stacked sections share one
       aligned column instead of leaving a right-side gutter. */
    max-width: var(--maxw);
    background: transparent;
    /* Thicker, brighter rim + lit-from-above lip — the Projects gallery-card
       "variant B" edge, so this card reads as the same defined glass pane. */
    border: 1.5px solid var(--card-edge);
    border-radius: 18px;
    box-shadow: var(--card-top-glow);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    overflow: hidden;
    /* Tall card; the list within scrolls once content exceeds this. */
    max-height: min(62vh, 36rem);
    display: flex;
  }

  /* The only scroll surface. Scroll is contained so it never bubbles to the page
     / sticky section while you page through the writes. */
  .writes__list {
    list-style: none;
    width: 100%;
    overflow-y: auto;
    overscroll-behavior: contain;
    -webkit-overflow-scrolling: touch;
    padding: clamp(0.5rem, 2vw, 1rem) clamp(0.75rem, 2.5vw, 1.5rem);
    scrollbar-width: thin;
  }
  .writes__list::-webkit-scrollbar { width: 6px; }
  .writes__list::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }

  /* Each write is a numbered row; a hairline separates them. */
  .wrow + .wrow .wrow__link { border-top: 1px solid var(--line); }
  .wrow__link {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: start;
    gap: clamp(0.9rem, 2.5vw, 1.6rem);
    padding: clamp(1.3rem, 3.2vw, 1.9rem) clamp(0.4rem, 1.5vw, 0.9rem);
    color: inherit; text-decoration: none;
    transition: background 0.2s ease;
  }
  .wrow__link:hover { background: rgba(245, 239, 227, 0.04); }

  /* Index — mono gold numeral, the "01 / 02 / 03" list marker. */
  .wrow__num {
    font-family: var(--font-mono); font-size: var(--t-label); letter-spacing: var(--track-label);
    font-variant-numeric: tabular-nums;
    color: var(--gold); padding-top: 0.5rem; line-height: 1;
  }

  /* Cap the text measure so the now-wide row keeps a readable line length
     (~75ch); the arrow stays pushed to the far right by the 1fr column, giving
     a wide editorial-list row (index · text · arrow) rather than over-long lines. */
  .wrow__text { display: block; max-width: 46rem; }
  .wrow__title {
    display: block;
    font-family: var(--font-display); font-weight: 500;
    font-size: var(--t-sm); line-height: var(--lh-snug);
    color: var(--ink); margin-bottom: 0.5rem;
  }
  /* Per-letter gold wave on the title when its row is hovered/focused — the same
     mechanism as the Projects card titles. scroll.ts splits each title into .char
     spans carrying their index in --i; the trigger here is pure CSS, so under
     reduced motion (no split) the title simply stays ink — graceful, not broken. */
  .wrow__title :global(.char) {
    transition: color 0.42s ease;
    transition-delay: calc(var(--i, 0) * 18ms);
  }
  .wrow__link:hover .wrow__title :global(.char),
  .wrow__link:focus-visible .wrow__title :global(.char) { color: var(--gold); }
  .wrow__summary {
    display: block;
    font-family: var(--font-body); font-size: var(--t-body);
    line-height: var(--lh-body); color: var(--ink-dim);
  }

  /* Arrow advances on row hover — the clickable affordance. */
  .wrow__arrow {
    font-family: var(--font-mono); color: var(--gold);
    padding-top: 0.4rem; transition: transform 0.25s ease;
  }
  .wrow__link:hover .wrow__title { color: var(--ink); }
  .wrow__link:hover .wrow__arrow { transform: translateX(4px); }
</style>
