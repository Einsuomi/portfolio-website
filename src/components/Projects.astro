---
/**
 * Projects — horizontal-scroll gallery of 4 curated cards (visual, image-forward
 * treatment via a number/gradient motif until real shots land). Scrolls only
 * within its own bounds (no page-level horizontal overflow), touch + drag friendly.
 * Deliberately distinct from the vertical Writes list below it.
 */
import { PROJECTS } from '../lib/timeline';
---

<section class="section section--scene section--stack proj" id="projects" aria-label="Projects">
  <div class="section__inner">
    <p class="kicker" data-reveal>Projects · built</p>
  </div>

  <!-- The strip is the only thing that scrolls horizontally; the page never does. -->
  <ul class="proj__strip" data-reveal>
    {PROJECTS.map((p, i) => (
      <li class="card">
        <div class="card__top" aria-hidden="true">
          <span class="card__num">{String(i + 1).padStart(2, '0')}</span>
        </div>
        <div class="card__body">
          <h3 class="card__name">{p.name}</h3>
          <p class="card__summary">{p.summary}</p>
          <ul class="card__stack">
            {p.stack.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        {p.url ? (
          <a class="card__link" href={p.url} target="_blank" rel="noopener noreferrer">
            View repo <span aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="card__link card__link--muted">Case study</span>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  /* Center the gallery in the pinned panel. */
  .proj { display: flex; flex-direction: column; justify-content: center; }

  .proj__strip {
    list-style: none;
    display: flex;
    gap: clamp(1rem, 2.5vw, 1.6rem);
    /* Self-contained horizontal scroll — does not push the page body. */
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0.5rem var(--pad-x) 1.5rem;
    scrollbar-width: thin;
  }
  .proj__strip::-webkit-scrollbar { height: 6px; }
  .proj__strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }

  .card {
    scroll-snap-align: start;
    flex: 0 0 auto;
    width: clamp(17rem, 78vw, 23rem);
    display: flex;
    flex-direction: column;
    background: var(--bg-raise);
    border: 1px solid var(--line);
    border-radius: 14px;
    overflow: hidden;
  }
  .card__top {
    height: clamp(7rem, 16vh, 9.5rem);
    display: flex; align-items: flex-end; padding: 1rem 1.2rem;
    /* Image slot for later; for now a warm gradient echoing the gold accent. */
    background:
      radial-gradient(120% 140% at 100% 0%, rgba(224,163,62,0.22), rgba(16,13,11,0) 60%),
      linear-gradient(160deg, #15110d, #0c0a09);
  }
  .card__num {
    font-family: var(--font-display);
    font-size: clamp(2.4rem, 6vw, 3.4rem);
    line-height: 1; color: var(--ink-faint);
  }

  .card__body { padding: 1.3rem 1.3rem 0.6rem; flex: 1; }
  .card__name {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(1.4rem, 3.6vw, 1.9rem);
    line-height: 1; text-transform: uppercase; color: var(--ink);
    margin-bottom: 0.7rem;
  }
  .card__summary {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2.2vw, 1.12rem);
    line-height: 1.4; color: var(--ink-dim);
  }
  .card__stack {
    list-style: none; display: flex; flex-wrap: wrap; gap: 0.4rem;
    margin-top: 1rem;
  }
  .card__stack li {
    font-family: var(--font-mono); font-size: 0.66rem; letter-spacing: 0.05em;
    color: var(--ink-faint); padding: 0.26rem 0.6rem;
    border: 1px solid var(--line); border-radius: 999px;
  }

  .card__link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.05em;
    color: var(--gold); text-decoration: none;
    padding: 1.1rem 1.3rem 1.3rem;
  }
  .card__link span { transition: transform 0.25s ease; }
  .card__link:hover span { transform: translateX(4px); }
  .card__link--muted { color: var(--ink-faint); }
</style>
