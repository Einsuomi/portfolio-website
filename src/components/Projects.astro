---
/**
 * Projects — horizontal-scroll gallery of 4 curated cards (visual, image-forward
 * treatment via a number/gradient motif until real shots land). Scrolls only
 * within its own bounds (no page-level horizontal overflow), touch + drag friendly.
 * Deliberately distinct from the vertical Writes list below it.
 */
import { PROJECTS } from '../lib/timeline';
---

<section class="section section--scene section--stack proj" id="projects" aria-label="Projects">
  <div class="section__inner">
    <p class="kicker" data-reveal>Projects · built</p>
  </div>

  <!-- The strip is the only thing that scrolls horizontally; the page never does. -->
  <ul class="proj__strip" data-reveal>
    {PROJECTS.map((p, i) => (
      <li class="card" data-spotlight>
        <!-- Ghosted index watermark — structural numbering, gallery feel. -->
        <span class="card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
        <div class="card__body">
          <h3 class="card__name">{p.name}</h3>
          <p class="card__summary">{p.summary}</p>
          <ul class="card__stack">
            {p.stack.map((s) => <li>{s}</li>)}
          </ul>
        </div>
        {p.url ? (
          <a class="card__link" href={p.url} target="_blank" rel="noopener noreferrer">
            View repo <span aria-hidden="true">→</span>
          </a>
        ) : (
          <span class="card__link card__link--muted">Case study</span>
        )}
      </li>
    ))}
  </ul>
</section>

<style>
  /* Header sits up top; the gallery rides below it in the pinned panel. */
  .proj { display: flex; flex-direction: column; justify-content: flex-start; }
  .proj > .section__inner { margin-top: 0; }

  .proj__strip {
    list-style: none;
    display: flex;
    /* More air between cards — the breathing room that reads as premium. */
    gap: clamp(1.4rem, 3vw, 2.4rem);
    /* Self-contained horizontal scroll — does not push the page body. */
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0.5rem var(--pad-x) 1.5rem;
    /* Drop the cards a little below the kicker. */
    margin-top: clamp(1.5rem, 6vh, 4rem);
    scrollbar-width: thin;
  }
  .proj__strip::-webkit-scrollbar { height: 6px; }
  .proj__strip::-webkit-scrollbar-thumb { background: var(--line); border-radius: 999px; }

  /* Smaller, crystal-glass cards with more negative space — gallery feel.
     Glass tokens give the clear-glass look while the dim keeps text legible. */
  .card {
    scroll-snap-align: start;
    flex: 0 0 auto;
    width: clamp(15rem, 76vw, 23rem);
    position: relative;
    display: flex;
    flex-direction: column;
    /* Transparent card — frosted blur + edge over the scene; the gold-flow ring
       and ghosted index stay. Legibility carried by the scrim + text-shadow. */
    background: transparent;
    border: 1px solid var(--glass-edge);
    border-radius: 16px;
    backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    overflow: hidden;
    padding-top: clamp(2.4rem, 6vh, 3.2rem); /* room under the ghosted index */
  }
  /* Ghosted index — large semi-opaque Anton watermark, top-right. A faint INK
     mark, deliberately distinct from Experience's serif GOLD year numerals so a
     sequence index never reads as a date. */
  .card__num {
    position: absolute; top: 0.3rem; right: 0.95rem;
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(2.8rem, 7vw, 4rem); line-height: 1;
    /* Same treatment as the Experience year: faint fill + thin gold outline. */
    color: rgba(245, 239, 227, 0.05);
    -webkit-text-stroke: 1px rgba(224, 163, 62, 0.28);
    pointer-events: none; user-select: none;
  }

  .card__body { padding: 1.3rem 1.3rem 0.6rem; flex: 1; }
  .card__name {
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(1.4rem, 3.6vw, 1.9rem);
    line-height: 1; text-transform: uppercase; color: var(--ink);
    margin-bottom: 0.7rem;
  }
  .card__summary {
    font-family: var(--font-serif);
    font-size: clamp(1rem, 2.2vw, 1.12rem);
    line-height: 1.4; color: var(--ink-dim);
  }
  /* Tags on a single left-aligned row (no wrap), flush with the card text.
     padding: 0 removes the default <ul> 40px indent so the first tag lines up. */
  .card__stack {
    list-style: none; padding: 0; display: flex; flex-wrap: nowrap;
    justify-content: flex-start; gap: 0.22rem; margin-top: 1rem;
  }
  .card__stack li {
    font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0;
    color: var(--ink-faint); padding: 0.2rem 0.34rem;
    border: 1px solid var(--line); border-radius: 999px;
    white-space: nowrap; flex: none;
  }

  .card__link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono); font-size: 0.78rem; letter-spacing: 0.05em;
    color: var(--gold); text-decoration: none;
    padding: 1.1rem 1.3rem 1.3rem;
  }
  .card__link span { transition: transform 0.25s ease; }
  .card__link:hover span { transform: translateX(4px); }
  .card__link--muted { color: var(--ink-faint); }
</style>
