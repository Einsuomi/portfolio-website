---
/**
 * Projects — horizontal-scroll gallery of 4 curated cards (visual, image-forward
 * treatment via a number/gradient motif until real shots land). Scrolls only
 * within its own bounds (no page-level horizontal overflow), touch + drag friendly.
 * Deliberately distinct from the vertical Writes list below it.
 */
import { PROJECTS } from '../lib/timeline';
---

<section class="section section--scene section--stack proj" id="projects" aria-label="Projects">
  <div class="section__inner">
    <h2 class="proj__head" data-reveal>Selected Work</h2>
  </div>

  <!-- The strip is the only thing that scrolls horizontally; the page never does. -->
  <ul class="proj__strip" data-reveal>
    {PROJECTS.map((p, i) => {
      // The whole card is a single real anchor (not a stretched-link overlay) so
      // a click anywhere navigates — robust even after a view transition leaves a
      // lingering view-transition-name on the card. Inert when there's no link.
      const href = p.slug ? `/projects/${p.slug}` : p.url;
      const external = !p.slug && !!p.url;
      const Inner = href ? 'a' : 'div';
      return (
        <!-- transition:name lives on the <li> (a static element, so the directive
             compiles); the card with a detail page shares it with that page's hero
             for the morph. Other cards get a unique scoped name (harmless). -->
        <li class="card" data-spotlight transition:name={`card-${p.slug ?? `i${i}`}`}>
          <Inner
            class="card__full"
            href={href}
            target={external ? '_blank' : undefined}
            rel={external ? 'noopener noreferrer' : undefined}
          >
            <!-- Ghosted index watermark — structural numbering, gallery feel. -->
            <span class="card__num" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            <div class="card__body">
              <h3 class="card__name">{p.name}</h3>
              <p class="card__summary">{p.summary}</p>
              <ul class="card__stack">
                {p.stack.map((s) => <li>{s}</li>)}
              </ul>
            </div>
            <span class:list={['card__link', { 'card__link--muted': !href }]}>
              {p.slug ? 'View case study' : p.url ? 'View repo' : 'Case study'}
              {href && <span aria-hidden="true"> →</span>}
            </span>
          </Inner>
        </li>
      );
    })}
  </ul>
</section>

<style>
  /* Header sits up top; the gallery rides below it in the pinned panel.
     Trimmed top padding lifts the whole block up a little within the panel. */
  .proj { display: flex; flex-direction: column; justify-content: flex-start; padding-top: var(--space-xl); }
  /* Drop the auto-centering so the heading left-aligns to the same gutter (pad-x)
     as the cards below it, instead of floating to the middle of the panel. */
  .proj > .section__inner { margin-top: 0; margin-inline: 0; max-width: none; }
  /* Promoted heavy machine heading — stands alone, no kicker. */
  .proj__head {
    font-family: var(--font-display); font-weight: 800;
    font-size: var(--t-lg); line-height: var(--lh-tight);
    text-transform: uppercase; letter-spacing: var(--track-machine);
    color: var(--ink); margin: 0;
  }

  .proj__strip {
    list-style: none;
    display: flex;
    /* More air between cards — the breathing room that reads as premium. */
    gap: clamp(1.4rem, 3vw, 2.4rem);
    /* Self-contained horizontal scroll — does not push the page body. */
    overflow-x: auto;
    overscroll-behavior-x: contain;
    scroll-snap-type: x mandatory;
    -webkit-overflow-scrolling: touch;
    padding: 0.5rem var(--pad-x) 1.5rem;
    /* Drop the cards a little below the kicker. */
    margin-top: clamp(1.5rem, 6vh, 4rem);
    /* Hide the native scrollbar — scroll stays fully functional (wheel, drag,
       snap, touch), it just isn't drawn. Cleaner than a styled bar at this size. */
    scrollbar-width: none;
  }
  .proj__strip::-webkit-scrollbar { display: none; }

  /* Smaller, crystal-glass cards with more negative space — gallery feel.
     Glass tokens give the clear-glass look while the dim keeps text legible. */
  .card {
    scroll-snap-align: start;
    flex: 0 0 auto;
    width: clamp(15rem, 76vw, 23rem);
    position: relative;
    display: flex;
    flex-direction: column;
    /* Gallery glass (variant B): a thick bright rim + soft diagonal fill + a
       lit-from-above top highlight give the card a defined, premium glass pane.
       The gold-flow ring and ghosted index stay; legibility still carried by the
       scrim + text-shadow under the fill. */
    background: var(--card-fill);
    border: 1.5px solid var(--card-edge);
    border-radius: 16px;
    box-shadow: var(--card-top-glow);
    backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    overflow: hidden;
    padding-top: clamp(2.4rem, 6vh, 3.2rem); /* room under the ghosted index */
  }
  /* Ghosted index — Anton watermark, top-right. Matched to the Experience year in
     PRESENCE (same faint fill + bold gold outline) so the two watermark systems
     feel like one family; kept DISTINCT by weight (heavy Bricolage caps vs lighter year)
     and value (01 vs 2021), so a sequence index never reads as a date. */
  .card__num {
    position: absolute; top: 0.6rem; right: 0.95rem;
    font-family: var(--font-display); font-weight: 700;
    font-size: clamp(2.4rem, 6vw, 3.4rem); line-height: 1;
    font-variant-numeric: tabular-nums;
    /* Same strength as the Experience year: faint fill + bold gold outline. */
    color: rgba(245, 239, 227, 0.06);
    -webkit-text-stroke: 1.25px rgba(224, 163, 62, 0.55);
    pointer-events: none; user-select: none;
  }
  /* Hover/focus gold flow (matches the Experience keyword wave, pointer-driven).
     scroll.ts splits the watermark into .char spans carrying their index in --i;
     on hover each digit fills solid gold left→right (the gold stroke is already
     there, so a gold fill reads as a solid gold numeral), then reverts on leave. */
  .card__num :global(.char) {
    transition: color 0.42s ease;
    transition-delay: calc(var(--i, 0) * 70ms);
  }
  .card:hover .card__num :global(.char),
  .card:focus-within .card__num :global(.char) { color: var(--gold); }

  .card__body { padding: 1.3rem 1.3rem 0.6rem; flex: 1; }
  .card__name {
    font-family: var(--font-display); font-weight: 700;
    font-size: var(--t-sm);
    line-height: var(--lh-tight); text-transform: uppercase;
    letter-spacing: var(--track-machine-sm); color: var(--ink);
    margin-bottom: 0.7rem;
  }
  /* Same per-letter gold wave on the title when the card is hovered/focused. */
  .card__name :global(.char) {
    transition: color 0.42s ease;
    transition-delay: calc(var(--i, 0) * 22ms);
  }
  .card:hover .card__name :global(.char),
  .card:focus-within .card__name :global(.char) { color: var(--gold); }
  .card__summary {
    font-family: var(--font-body);
    font-size: var(--t-body);
    line-height: var(--lh-body); color: var(--ink-dim);
  }
  /* Stack as a single mono "spec line" on one row — no pill borders (they read
     cramped at this width). Tags sit at the --t-micro floor with tracking at the
     0.05em mono minimum so all four fit one line; gold-disc separators between
     them carry the accent. padding: 0 removes the default <ul> 40px indent.
     Extra margin-top sets the tag row apart from the summary above it. */
  .card__stack {
    list-style: none; padding: 0; margin-top: 1.75rem;
    display: flex; flex-wrap: nowrap; align-items: center; gap: 0.42rem;
    font-family: var(--font-mono); font-size: var(--t-micro);
    letter-spacing: 0.05em; text-transform: uppercase;
    color: var(--ink-dim);
  }
  .card__stack li {
    display: flex; align-items: center; gap: 0.42rem; flex: none; white-space: nowrap;
  }
  /* A small gold disc separates each tag from the next (not before the first). */
  .card__stack li + li::before {
    content: ''; width: 4px; height: 4px; border-radius: 50%;
    background: var(--gold); flex: none;
  }

  /* The whole card IS the link: this anchor fills the card and holds all the
     content, so a click anywhere navigates (no overlay/z-index trick that a view
     transition could disturb). Inert cards render this as a <div>. */
  .card__full {
    display: flex; flex-direction: column; flex: 1;
    color: inherit; text-decoration: none;
  }

  .card__link {
    display: inline-flex; align-items: center; gap: 0.4rem;
    font-family: var(--font-mono); font-size: var(--t-label); letter-spacing: var(--track-label);
    color: var(--gold); text-decoration: none;
    padding: 1.1rem 1.3rem 1.3rem;
  }
  .card__link span { transition: transform 0.25s ease; }
  /* Arrow advances when the whole card is hovered, not just the label. */
  a.card__full:hover .card__link span { transform: translateX(4px); }
  /* Muted (inert) link carries reading text → ink-dim for the 4.5:1 floor, not faint. */
  .card__link--muted { color: var(--ink-dim); }

  /* Continuous "flow" while the card is hovered: a brighter gold band sweeps
     left→right across the label on a loop (clipped to the text), echoing the
     title/number gold flow but ongoing rather than one-shot. Real links only
     (inert cards render a <div>, so this never fires). Motion-gated. */
  @media (prefers-reduced-motion: no-preference) {
    a.card__full:hover .card__link {
      background: linear-gradient(100deg,
        var(--gold) 0%, var(--gold) 38%, #f6dca0 50%, var(--gold) 62%, var(--gold) 100%);
      background-size: 220% 100%;
      -webkit-background-clip: text; background-clip: text;
      -webkit-text-fill-color: transparent; color: transparent;
      text-shadow: none; /* clipped text + a glyph shadow would smear */
      animation: cardLinkFlow 1.7s linear infinite;
    }
  }
  @keyframes cardLinkFlow {
    from { background-position: 120% 0; }
    to   { background-position: -120% 0; }
  }
</style>
