<!-- TrackBeacon: fires one page-view beacon per page load via sendBeacon.
     No cookies, no localStorage, no fetch fallback.
     Silently absent when JS is disabled or sendBeacon is unavailable. -->
<script is:inline>
  // Guard against double-fire (e.g. if the component is accidentally included twice).
  if (!window.__trackFired) {
    window.__trackFired = true;

    // Feature-detect sendBeacon; do nothing if the browser lacks it.
    if (navigator.sendBeacon) {
      navigator.sendBeacon(
        '/api/track',
        JSON.stringify({
          path: location.pathname,
          referrer: document.referrer || null,
        })
      );
    }
  }
</script>
