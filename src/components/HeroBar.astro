---
/**
 * Hero boundary bar — a slim marquee strip that sits where the video hero ends
 * and the still-background body begins, so the change of backdrop reads as an
 * intentional seam, not a brightness jump. Carries the certifications by name,
 * scrolling slowly to the right. Under reduced motion it sits still and scrolls
 * natively. Content is duplicated once so the loop is seamless.
 */
import { CERTS } from '../lib/timeline';
const ITEMS = [...CERTS, ...CERTS]; // doubled for a seamless -50% loop
---

<div class="bar" role="presentation">
  <!-- Gold flow glow drifting behind the names — marks the seam as intentional. -->
  <div class="bar__flow" aria-hidden="true"></div>
  <div class="bar__track">
    <span class="bar__lead">Certified</span>
    {ITEMS.map((c) => (
      <>
        <span class="bar__dot" aria-hidden="true">✦</span>
        <span class="bar__item">{c}</span>
      </>
    ))}
    <span class="bar__dot" aria-hidden="true">✦</span>
  </div>
</div>

<style>
  .bar {
    position: relative;
    overflow: hidden;
    background: var(--bg);
    border-block: 1px solid var(--line);
    padding-block: 0.85rem;
  }
  .bar__track {
    position: relative;
    z-index: 1; /* names sit above the gold flow glow */
    display: inline-flex;
    align-items: center;
    gap: 1.4rem;
    white-space: nowrap;
    will-change: transform;
    /* Slow drift to the right. */
    animation: bar-marquee 38s linear infinite;
  }

  /* Gold gradient flow drifting behind the names — the Banner "flow" effect in
     our warm gold theme (not rainbow), masked to fade toward the strip edges so
     it reads as a glow, not a band. Purely presentational, never interactive. */
  .bar__flow {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    background-image: repeating-linear-gradient(
      70deg,
      rgba(224, 163, 62, 0) 0%,
      rgba(224, 163, 62, 0.42) 14%,
      rgba(224, 163, 62, 0) 30%,
      rgba(224, 163, 62, 0.26) 44%,
      rgba(224, 163, 62, 0) 60%
    );
    background-size: 200% 100%;
    /* Soft top-anchored fade across the full strip width (the slim bar is too
       short for a radial spot — that would shrink the glow to a dot). */
    -webkit-mask: linear-gradient(to bottom, #000 0%, rgba(0, 0, 0, 0.15) 100%);
    mask: linear-gradient(to bottom, #000 0%, rgba(0, 0, 0, 0.15) 100%);
    animation: bar-flow 20s linear infinite;
  }
  .bar__lead {
    font-family: var(--font-mono); font-size: 0.72rem;
    letter-spacing: 0.2em; text-transform: uppercase; color: var(--gold);
    padding-right: 0.6rem;
  }
  .bar__item {
    font-family: var(--font-mono); font-size: 0.82rem;
    letter-spacing: 0.04em; color: var(--ink-dim);
  }
  .bar__dot { color: var(--gold); font-size: 0.6rem; opacity: 0.8; }

  @keyframes bar-marquee {
    from { transform: translateX(-50%); }
    to   { transform: translateX(0); }
  }
  @keyframes bar-flow {
    from { background-position: 0% 0; }
    to   { background-position: 200% 0; }
  }

  /* No drift under reduced motion — names sit still, the glow holds static. */
  @media (prefers-reduced-motion: reduce) {
    .bar { overflow-x: auto; }
    .bar__track { animation: none; }
    .bar__flow { animation: none; }
  }
</style>
