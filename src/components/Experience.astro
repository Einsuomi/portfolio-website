---
/**
 * Experience — a single vertical "spine" timeline. The intro holds sticky on the
 * left while a gold line draws down the right, igniting each year's node as it
 * passes: the beat at the frontier lights brightest, past beats stay lit, future
 * ones rest dim. The year anchors each rung (no watermark), and the stack tags
 * live in the Projects section — so each beat carries only year · keyword · role ·
 * one outcome. A soft gold "reading light" tracks the cursor over the hovered beat.
 *
 * Progressive enhancement: the scroll/cursor behaviour is added by scroll.ts
 * (which adds `.is-live`). Without JS or under reduced motion every beat renders
 * fully lit and static, and the page stays a plain readable list.
 */
import { EXPERIENCE } from '../lib/timeline';
---

<section class="section section--scene exp" id="experience" aria-label="Experience">
  <div class="exp__grid">
    <!-- Left: intro, held centered while the spine scrolls past it. -->
    <div class="exp__intro-col">
      <div>
        <h2 class="exp__head" data-reveal>Experience</h2>
        <p class="exp__intro" data-reveal>
          From a data-governance master's to governance across 1,000+ pipelines —
          five years, each one compounding on the last.
        </p>
      </div>
    </div>

    <!-- Right: the spine. Each beat = year (anchor) · node · keyword · role · outcome. -->
    <ol class="exp__spine">
      <!-- The gold line that draws down as you scroll (height driven by --p). -->
      <div class="exp__fill" aria-hidden="true"></div>
      {EXPERIENCE.map((b) => (
        <li class="exp__beat">
          <p class="exp__year">{b.year}</p>
          <span class="exp__node" aria-hidden="true"></span>
          <div class="exp__body">
            <span class="exp__glow" aria-hidden="true"></span>
            <h3 class="exp__kw" set:html={b.keyword} />
            <p class="exp__role">{b.role}</p>
            <p class="exp__out" set:html={b.outcome} />
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .exp__grid {
    display: grid;
    /* Intro column widened so the paragraph reads in ~3 lines, not 4; the spine
       still keeps a wide-enough track for one-line keywords. */
    grid-template-columns: 1.4fr 1.3fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    max-width: var(--maxw);
    /* Left-anchor to the hero's content inset (the hero is nudged 2.5vw right of
       --pad-x) so EXPERIENCE lines up under TONG NIE and the intro under the
       tagline on every width — not centered, which drifts right on wide screens. */
    margin-left: 2.5vw;
    margin-right: auto;
    align-items: start;
  }

  /* Left intro stays centered in view while the spine scrolls. */
  .exp__intro-col {
    position: sticky; top: 0;
    min-height: 100svh;
    display: flex; align-items: center;
  }
  /* Promoted heavy machine heading — aligned with Projects/Writes (uppercase). */
  .exp__head {
    font-family: var(--font-display); font-weight: 800;
    font-size: var(--t-lg); line-height: var(--lh-tight);
    text-transform: uppercase; letter-spacing: var(--track-machine);
    color: var(--ink); margin: 0 0 var(--space-md);
  }
  .exp__intro {
    font-family: var(--font-body);
    font-size: var(--t-sm); line-height: 1.4;
    color: var(--ink-dim); max-width: 42ch; margin-top: 0;
  }

  /* ── The spine ──────────────────────────────────────────────────────
     A 3-column grid per beat: [year] [rail] [body]. The track + gold fill
     sit at the centre of the rail column, so year, line, node and copy never
     overlap. */
  .exp__spine {
    --col-year: clamp(3rem, 6vw, 5rem);
    --col-rail: clamp(2.8rem, 4.8vw, 3.8rem); /* wider rail = year sits clear of the dot */
    --line-x: calc(var(--col-year) + var(--col-rail) / 2);
    /* Slide the whole timeline horizontally toward the doorway. Positive = right
       (screen-right). Tune this one value to land the keywords where you want them
       relative to the door; negative would move them left. */
    --exp-shift: 0vw;
    list-style: none; margin: 0; padding: 0;
    position: relative;
    transform: translateX(var(--exp-shift));
  }
  /* Faint full-height track — always present (a quiet vertical line). */
  .exp__spine::before {
    content: ''; position: absolute; top: 0.6rem; bottom: 0.6rem;
    left: var(--line-x); width: 2px; transform: translateX(-50%);
    background: rgba(245, 239, 227, 0.16);
  }
  /* Gold fill — its height is set in px by scroll.ts as the line draws. 0 by
     default, so without JS it stays invisible and the quiet track shows through.
     (px, not %, because the spine's height is auto and a % would collapse to 0.) */
  .exp__fill {
    position: absolute; top: 0.6rem;
    left: var(--line-x); width: 2px; transform: translateX(-50%);
    height: 0;
    background: linear-gradient(var(--gold), rgba(224, 163, 62, 0.4));
    box-shadow: 0 0 12px rgba(224, 163, 62, 0.5);
  }

  .exp__beat {
    display: grid;
    grid-template-columns: var(--col-year) var(--col-rail) 1fr;
    align-items: start;
    padding: clamp(2rem, 6vh, 4rem) 0;
  }
  /* Live (JS + motion) starts beats dimmed; scroll then lights them. */
  .exp__spine.is-live .exp__beat {
    opacity: 0.32; filter: saturate(0.7);
    transition: opacity 0.55s ease, filter 0.55s ease;
  }
  .exp__spine.is-live .exp__beat.is-lit { opacity: 1; filter: none; }

  .exp__year {
    grid-column: 1; text-align: right;
    padding-right: clamp(0.9rem, 2.2vw, 1.6rem); /* sit the year further left of the line */
    font-family: var(--font-display); font-weight: 700;
    font-variant-numeric: tabular-nums;
    font-size: clamp(1.5rem, 1rem + 2vw, 2.4rem); line-height: 1;
    color: var(--ink-dim); margin: 0;
    text-shadow: 0 1px 14px rgba(0, 0, 0, 0.6);
    transition: color 0.55s ease;
  }
  /* Lit years turn gold (the "achieved" marker); the current one scales a touch. */
  .exp__spine.is-live .exp__beat.is-lit .exp__year { color: var(--gold); }
  .exp__beat.is-current .exp__year { scale: 1.06; }

  .exp__node {
    grid-column: 2; justify-self: center; margin-top: 0.22em;
    width: 13px; height: 13px; border-radius: 50%;
    background: var(--bg); border: 2px solid rgba(224, 163, 62, 0.5);
    transition: background 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease, scale 0.45s ease;
  }
  /* Live: nodes rest dim until the fill reaches them, then ignite gold. */
  .exp__spine.is-live .exp__node { border-color: rgba(245, 239, 227, 0.3); }
  .exp__spine.is-live .exp__beat.is-lit .exp__node {
    background: var(--gold); border-color: var(--gold);
    box-shadow: 0 0 14px rgba(224, 163, 62, 0.8);
  }
  .exp__beat.is-current .exp__node { scale: 1.3; }

  .exp__body {
    grid-column: 3; position: relative;
    /* No overflow clip here: the long keyword (GOVERNANCE AT SCALE) is nowrap and
       must be free to use the space to its right. The glow is sized to the body
       (inset 0) so it can't spill, so clipping isn't needed. */
    padding-left: clamp(0.6rem, 1.4vw, 1.1rem); max-width: 44ch;
  }
  /* Cursor "reading light": a soft gold hotspot that follows the pointer over
     the hovered beat (--gx/--gy set by scroll.ts). Gated to fine-pointer + motion. */
  .exp__glow {
    position: absolute; inset: 0; z-index: 0; pointer-events: none;
    opacity: 0; transition: opacity 0.45s ease;
    background: radial-gradient(220px circle at var(--gx, 50%) var(--gy, 50%),
                rgba(224, 163, 62, 0.14), transparent 68%);
  }
  @media (hover: hover) and (prefers-reduced-motion: no-preference) {
    .exp__beat:hover .exp__glow { opacity: 1; }
  }
  .exp__kw, .exp__role, .exp__out { position: relative; z-index: 1; }

  .exp__kw {
    font-family: var(--font-display); font-weight: 800;
    font-size: var(--t-md); line-height: var(--lh-tight);
    text-transform: uppercase; letter-spacing: var(--track-machine-sm);
    color: var(--ink); margin: 0 0 0.4rem;
    text-shadow: 0 2px 22px rgba(0, 0, 0, 0.45);
    white-space: nowrap; /* keep each keyword on one line (e.g. GOVERNANCE AT SCALE) */
  }
  /* Per-letter gold flow: scroll.ts splits the keyword into .char spans (each
     carrying its index in --i). When the beat becomes current, the letters turn
     gold left→right in a staggered wave; scrolling past reverses them to white.
     Solid color per letter (no gradient-text), staggered via transition-delay. */
  .exp__kw :global(.char) {
    color: var(--ink);
    transition: color 0.42s ease;
    transition-delay: calc(var(--i, 0) * 26ms);
  }
  .exp__beat.is-current .exp__kw :global(.char) { color: var(--gold); }
  .exp__role {
    font-family: var(--font-mono); font-size: var(--t-label);
    letter-spacing: var(--track-label); color: var(--ink-dim); margin: 0 0 0.7rem;
  }
  .exp__out {
    font-family: var(--font-body); font-size: var(--t-lead);
    line-height: var(--lh-body); color: var(--ink); margin: 0;
    text-shadow: 0 1px 16px rgba(0, 0, 0, 0.5);
  }
  .exp__out :global(strong) { color: var(--gold); font-weight: 500; }

  /* Phones: single readable column, intro on top, year above each beat, no
     sticky, no stagger. Keywords may wrap here (narrow), which is fine. */
  @media (max-width: 48rem) {
    .exp__grid { grid-template-columns: 1fr; gap: 2rem; }
    .exp__intro-col { position: static; min-height: 0; display: block; }
    .exp__spine { --col-year: 1; --exp-shift: 0; }
    .exp__beat {
      grid-template-columns: clamp(1.4rem, 7vw, 2.4rem) 1fr;
      column-gap: clamp(0.8rem, 3vw, 1.4rem); padding: 1.4rem 0;
    }
    .exp__year { grid-column: 2; text-align: left; margin-bottom: 0.5rem; font-size: 1.5rem; }
    .exp__node { grid-column: 1; margin-top: 0.5rem; }
    .exp__body { grid-column: 2; padding-left: 0; }
    .exp__spine::before, .exp__fill { left: clamp(0.7rem, 3.5vw, 1.2rem); }
    .exp__kw { white-space: normal; }
  }
</style>
