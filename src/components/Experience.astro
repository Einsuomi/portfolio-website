---
/**
 * Experience — intro held at the left while a staggered "ladder" of year rungs
 * cascades on the right (à la the Tres Mares numbers): two columns, the right
 * one dropped half a step so the rungs alternate upper-left / lower-right. This
 * leaves room for more years over time. Rides the continuous scene backdrop and
 * reveals rung-by-rung; on phones it flattens to a plain readable stack.
 */
import { EXPERIENCE } from '../lib/timeline';

// Split into the two alternating columns by chronological position.
const colA = EXPERIENCE.filter((_, i) => i % 2 === 0); // 2021, 2024, 2026
const colB = EXPERIENCE.filter((_, i) => i % 2 === 1); // 2023, 2025
---

<section class="section section--scene exp" id="experience" aria-label="Experience">
  <div class="exp__grid">
    <!-- Left: intro, held centered while the ladder scrolls past. -->
    <div class="exp__intro-col">
      <div>
        <p class="kicker" data-reveal>Experience</p>
        <p class="exp__intro" data-reveal>
          From a data-governance master's to governance across 1,000+ pipelines —
          five years, each one compounding on the last.
        </p>
      </div>
    </div>

    <!-- Right: the alternating ladder, two columns, the second dropped down. -->
    <div class="ladder">
      <div class="ladder__col">
        {colA.map((b) => (
          <article class="rung" data-reveal data-spotlight>
            <p class="rung__year">{b.year}</p>
            <h3 class="rung__kw" set:html={b.keyword} />
            <p class="rung__role">{b.role}</p>
            <p class="rung__outcome" set:html={b.outcome} />
            <ul class="rung__stack" aria-label="Stack">
              {b.stack.map((s) => <li>{s}</li>)}
            </ul>
          </article>
        ))}
      </div>
      <div class="ladder__col ladder__col--drop">
        {colB.map((b) => (
          <article class="rung" data-reveal data-spotlight>
            <p class="rung__year">{b.year}</p>
            <h3 class="rung__kw" set:html={b.keyword} />
            <p class="rung__role">{b.role}</p>
            <p class="rung__outcome" set:html={b.outcome} />
            <ul class="rung__stack" aria-label="Stack">
              {b.stack.map((s) => <li>{s}</li>)}
            </ul>
          </article>
        ))}
      </div>
    </div>
  </div>
</section>

<style>
  .exp__grid {
    display: grid;
    /* Intro gets more room (fewer lines); ladder is narrower and pushed right. */
    grid-template-columns: 1fr 1.2fr;
    gap: clamp(1.5rem, 4vw, 4rem);
    max-width: var(--maxw);
    margin-inline: auto;
    align-items: start;
  }

  /* Left intro stays centered in view while the ladder scrolls. */
  .exp__intro-col {
    position: sticky; top: 0;
    min-height: 100svh;
    display: flex; align-items: center;
  }
  .exp__intro {
    font-family: var(--font-serif);
    font-size: clamp(1.4rem, 2.6vw, 2.1rem); line-height: 1.3;
    color: var(--ink); max-width: 28ch; margin-top: 0.6rem;
  }

  /* Two alternating columns; the second is dropped half a rung. */
  .ladder {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(1rem, 2vw, 1.6rem);
    padding-block: clamp(3rem, 10vh, 7rem);
  }
  /* min-width: 0 keeps both columns equal width — without it a long keyword or a
     one-line tag row makes its column wider than the other. */
  .ladder__col { display: flex; flex-direction: column; gap: clamp(1rem, 2vw, 1.6rem); min-width: 0; }
  .ladder__col--drop { margin-top: clamp(4rem, 16vh, 11rem); }

  /* Each rung: clear bright crystal glass over the scene — luminous sheen + bright
     edge riding a LIGHT local dim that still keeps text legible. Compact (less
     tall) and lively. Pairs with [data-spotlight] for the gold flow on hover. */
  .rung {
    position: relative; min-width: 0;
    overflow: hidden; /* clip the ghosted year watermark to the card */
    padding: clamp(1.1rem, 2vw, 1.6rem) clamp(1.3rem, 2.4vw, 2rem);
    /* Transparent card — just a frosted blur + edge over the scene; legibility
       carried by the section scrim + text-shadow. Keeps the gold-flow ring. */
    background: transparent;
    border: 1px solid var(--glass-edge);
    border-radius: 16px;
    backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
    -webkit-backdrop-filter: blur(var(--glass-blur)) saturate(1.05);
  }
  /* Year = a large semi-opaque ghosted serif watermark behind the content (the
     same device as the Projects index), so the KEYWORD can lead. */
  .rung__year {
    position: absolute; top: -0.2rem; right: 0.7rem; z-index: 0;
    font-family: var(--font-luxe); font-weight: 460;
    font-optical-sizing: auto;
    font-size: clamp(2.3rem, 4.6vw, 3.6rem); line-height: 1;
    /* Ghosted, but given a thin gold outline so the numerals read as a crisp
       watermark rather than a vague blur. */
    color: rgba(245, 239, 227, 0.05);
    -webkit-text-stroke: 1px rgba(224, 163, 62, 0.30);
    margin: 0; pointer-events: none; user-select: none;
  }
  /* Keyword = the bold Anton front title (the highlight). */
  .rung__kw {
    position: relative; z-index: 1;
    font-family: var(--font-display); font-weight: 400;
    font-size: clamp(1.7rem, 3.4vw, 2.5rem); line-height: 1;
    text-transform: uppercase; letter-spacing: 0.01em;
    color: var(--ink); margin-bottom: 0.7rem;
  }
  /* Keep the rest of the rung content above the watermark. */
  .rung__role, .rung__outcome, .rung__stack { position: relative; z-index: 1; }
  .rung__role {
    font-family: var(--font-mono);
    font-size: clamp(0.72rem, 1.3vw, 0.82rem); letter-spacing: 0.03em;
    color: var(--ink-dim); margin-bottom: 0.6rem;
  }
  .rung__outcome {
    font-family: var(--font-serif);
    font-size: clamp(1.05rem, 1.9vw, 1.35rem); line-height: 1.32;
    color: var(--ink);
  }
  .rung__outcome :global(strong) { color: var(--gold); font-weight: 400; }
  /* Tags on a single row, left-aligned flush with the card text. padding: 0
     removes the browser's default <ul> 40px indent so the first tag lines up
     with the keyword/outcome above it. */
  .rung__stack {
    list-style: none; padding: 0; display: flex; flex-wrap: nowrap;
    justify-content: flex-start; gap: 0.22rem; margin-top: 1rem;
  }
  .rung__stack li {
    font-family: var(--font-mono); font-size: 0.5rem; letter-spacing: 0;
    color: var(--ink-dim); padding: 0.2rem 0.34rem;
    border: 1px solid var(--line); border-radius: 999px;
    white-space: nowrap; flex: none;
  }

  /* Phones: single readable column, intro on top, no stagger, no sticky. */
  @media (max-width: 48rem) {
    .exp__grid { grid-template-columns: 1fr; gap: 2rem; }
    .exp__intro-col { position: static; min-height: 0; display: block; }
    .ladder { grid-template-columns: 1fr; padding-block: 1rem; }
    .ladder__col--drop { margin-top: 0; }
  }
</style>
