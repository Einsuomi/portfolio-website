      .chapter.intro { border-top: none; padding-bottom: 3rem; }
      .head { padding: 0; }
      .ch-num { position: static; margin-bottom: 0.8rem; }
      .ch-credits { position: static; text-align: left !important; margin-top: 1.4rem; }
      .chapter.right .par, .chapter.right .ch-copy,
      .chapter.right .ch-kicker, .chapter.right h2,
      .chapter.content.right .ch-sub { text-align: left !important; margin-left: 0 !important; }
      .manifesto .ln, .actions { opacity: 1 !important; }
      .scroll-hint { position: static; margin-top: 1.4rem; }
      .stage-meta { display: none; }
    }
  </style>

