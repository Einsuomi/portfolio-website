---
/**
 * Home page — LIGHT treatment (Phase 1b).
 *
 * The light projection of the SAME story as dark.astro — identical chapter
 * structure and copy — but its OWN grammar, distilled from the Anton
 * Skvortsov reference (antonskvor.webflow.io): near-white surfaces, oversized
 * black display type, generous whitespace, numbered sections (001/002…) as
 * quiet mono chrome, and motion carried by media / poster cards rather than a
 * full-bleed background scene.
 *
 *  - The page scrolls NORMALLY (Lenis inertia only). No pinned stage, no
 *    canvas, no frame sequence — each chapter is a real <section> with its
 *    own scroll rhythm.
 *  - Numbered sections are a single deliberate narrative sequence (001→007),
 *    not per-section eyebrow scaffolding: consistent placement, mono type.
 *  - Two full-BLACK contrast bands act as film cuts where the story earns
 *    them: THE PROOF (the work) and the TALK finale. At most these two.
 *  - Motion attention goes to the poster / chapter visuals: scroll reveals,
 *    hover lift, and a restrained parallax drift on the giant display words.
 *    Section entrances are varied, not a uniform fade-up reflex.
 *
 * Legibility is law: body text sits on white/near-white at ≥4.5:1; on the
 * black cut bands the type inverts. With reduced motion or JS off, every line
 * is simply present and the whole document is readable as a static stack.
 */
import '@fontsource/anton/index.css';
import { icons } from '../lib/lucide-icons.js';
import TrackBeacon from '../components/TrackBeacon.astro';

function icon(data: any[], size = 16, cls = ''): string {
  if (!data) return '';
  const inner = (data as [string, Record<string,string>][])
    .map(([tag, attrs]) =>
      `<${tag} ${Object.entries(attrs).map(([k,v]) => `${k}="${v}"`).join(' ')}/>`
    ).join('');
  const c = cls ? ` class="${cls}"` : '';
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"${c} aria-hidden="true">${inner}</svg>`;
}

const GithubData: [string, Record<string,string>][] = [
  ["path",{"d":"M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"}],
  ["path",{"d":"M9 18c-4.51 2-5-2-7-2"}],
];
const LinkedinData: [string, Record<string,string>][] = [
  ["path",{"d":"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"}],
  ["rect",{"width":"4","height":"12","x":"2","y":"9"}],
  ["circle",{"cx":"4","cy":"4","r":"2"}],
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Tong Nie — Data Engineer. Three industries, one craft. An engineer who moves data by day; a builder who teaches it to speak by night." />
  <meta name="generator" content={Astro.generator} />
  <title>Tong Nie — Data Engineer</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* near-white surfaces, true off-white — no cream / sand / beige */
      --paper:     #ffffff;
      --paper-2:   #fafafa;
      --paper-3:   #f4f4f4;
      --ink:       #0a0a0a;   /* display + body on light: ~20:1 */
      --ink-2:     #3a3a3a;   /* secondary body on light: ~11:1 */
      --ink-3:     #555555;   /* muted meta on light: ~7.4:1 (>4.5 law) */
      --line:      #e4e4e4;
      --line-2:    #d2d2d2;
      /* inverted scale for the black cut bands */
      --void:      #0a0a0a;
      --void-paper:#f6f6f4;   /* type on black */
      --void-2:    #b3b3b3;   /* muted on black: ~6.6:1 */
      --void-line: #2a2a2a;
      --accent:    #0a0a0a;   /* the "accent" in this grammar IS pure contrast */
      --display:   'Anton','Arial Narrow',sans-serif;
      --mono:      ui-monospace,'Cascadia Code','JetBrains Mono','Fira Code',monospace;
      --sans:      'Helvetica Neue',Helvetica,'Arial Nova',Arial,sans-serif;
      --px:        clamp(1.5rem, 6vw, 7rem);
      --ease:      cubic-bezier(0.22,1,0.36,1);
    }

    html { background: var(--paper); }
    body {
      background: var(--paper); color: var(--ink);
      font-family: var(--sans);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    :focus-visible { outline: 2px solid var(--ink); outline-offset: 3px; }
    a { color: inherit; }

    /* ── fixed mono chrome: wordmark + section index, top corners ──── */
    .chrome {
      position: fixed; top: 0; left: 0; right: 0; z-index: 50;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1.15rem var(--px);
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 600; letter-spacing: 0.2em;
      color: var(--ink); text-transform: uppercase;
      mix-blend-mode: difference;            /* legible over white AND black cuts */
      pointer-events: none;
    }
    .chrome a { pointer-events: auto; text-decoration: none; }
    .chrome .dim { opacity: 0.55; }
    /* mix-blend-difference inverts paper→black text; force light glyphs */
    .chrome, .chrome a { color: #ffffff; }
    .chrome-nav { display: flex; gap: 1.5rem; }
    .chrome-nav a { position: relative; }
    .chrome-nav a::after {
      content: ''; position: absolute; left: 0; right: 100%; bottom: -3px;
      height: 1px; background: currentColor; transition: right 0.3s var(--ease);
    }
    .chrome-nav a:hover::after { right: 0; }

    /* running section index, fixed bottom-right (mono chrome) */
    .index {
      position: fixed; right: var(--px); bottom: 1.1rem; z-index: 50;
      font-family: var(--mono);
      font-size: 0.62rem; font-weight: 600; letter-spacing: 0.18em;
      color: var(--ink); text-transform: uppercase;
      mix-blend-mode: difference; color: #ffffff;
      pointer-events: none;
      display: flex; align-items: baseline; gap: 0.5ch;
    }
    .index .cur { font-size: 0.82rem; }
    .index .dim { opacity: 0.55; }

    /* ── shared section frame ──────────────────────────────────────── */
    section { position: relative; padding: clamp(4.5rem, 11vh, 8.5rem) var(--px); }
    /* the small mono number that opens each chapter (001/002…) */
    .seq-mark {
      font-family: var(--mono);
      font-size: 0.7rem; font-weight: 600; letter-spacing: 0.32em;
      text-transform: uppercase; color: var(--ink-3);
      display: flex; align-items: center; gap: 0.9rem;
      margin-bottom: clamp(1.4rem, 4vh, 2.6rem);
    }
    .seq-mark .num { color: var(--ink); font-weight: 700; }
    .seq-mark .bar { flex: 0 0 clamp(28px, 4vw, 54px); height: 1px; background: var(--line-2); }

    /* the giant display word — the heavy lifter */
    .display {
      font-family: var(--display); font-weight: 400;
      text-transform: uppercase; color: var(--ink);
      line-height: 0.82; letter-spacing: 0.005em;
      text-wrap: balance;
      will-change: transform;
    }

    /* ── 000 · HERO ────────────────────────────────────────────────── */
    .hero {
      min-height: 100svh;
      display: flex; flex-direction: column; justify-content: center;
      padding-top: clamp(7rem, 17vh, 10rem); padding-bottom: clamp(3rem, 8vh, 5rem);
    }
    .hero-kicker {
      font-family: var(--mono);
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.34em;
      text-transform: uppercase; color: var(--ink-3); margin-bottom: clamp(1.4rem, 4vh, 2.4rem);
    }
    .hero h1 {
      font-family: var(--display); font-weight: 400;
      font-size: clamp(2.5rem, 6.6vw, 6.8rem);
      line-height: 0.94; letter-spacing: 0.003em;
      text-transform: uppercase; color: var(--ink);
      text-wrap: balance; max-width: 18ch;
    }
    .hero h1 .ln { display: block; overflow: hidden; }
    .hero h1 .ln > span { display: inline-block; will-change: transform; }
    .hero h1 .quiet { color: var(--ink-3); }   /* the third manifesto line, lighter */
    .hero-sub {
      margin-top: clamp(1.8rem, 5vh, 3rem);
      max-width: 60ch;
      font-size: clamp(1rem, 1.5vw, 1.2rem); line-height: 1.65; color: var(--ink-2);
    }
    .hero-ctas { display: flex; gap: 0.9rem; margin-top: clamp(2rem, 5vh, 2.8rem); flex-wrap: wrap; align-items: center; }
    .btn {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.9rem 1.7rem;
      font-family: var(--mono); font-size: 0.72rem; font-weight: 600;
      letter-spacing: 0.12em; text-transform: uppercase; text-decoration: none;
      transition: background 0.25s, color 0.25s, transform 0.18s, border-color 0.25s;
    }
    .btn-solid { background: var(--ink); color: var(--paper); }
    .btn-solid:hover { transform: translateY(-2px); background: #222; }
    .btn-ghost { border: 1px solid var(--line-2); color: var(--ink); }
    .btn-ghost:hover { border-color: var(--ink); }
    .scroll-cue {
      margin-top: clamp(2.4rem, 7vh, 4rem);
      font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.2em;
      text-transform: uppercase; color: var(--ink-3);
      display: inline-flex; align-items: center; gap: 0.45rem;
    }
    .scroll-cue svg { animation: bob 2.6s ease-in-out infinite; }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(4px); } }

    /* ── career chapters (001–003) — display word + meta block ─────── */
    .career { border-top: 1px solid var(--line); }
    .career.paper2 { background: var(--paper-2); }
    .career .display { font-size: clamp(3.4rem, 13vw, 11rem); }
    .career-grid {
      display: grid; grid-template-columns: 1fr; gap: clamp(1.6rem, 4vh, 2.8rem);
      align-items: end;
    }
    @media (min-width: 880px) {
      .career-grid { grid-template-columns: minmax(0, 1.3fr) minmax(0, 1fr); gap: 3.5rem; }
      /* alternating placement: even chapters flip the meta to the left */
      .career.flip .career-word { order: 2; }
      .career.flip .career-meta { order: 1; }
      .career.flip .seq-mark { justify-content: flex-end; }
    }
    .career-meta { max-width: 46ch; }
    .career-dek {
      font-family: var(--sans);
      font-size: clamp(1.25rem, 2.4vw, 1.75rem); font-weight: 600;
      line-height: 1.2; color: var(--ink); margin-bottom: 1rem; text-wrap: balance;
    }
    .career-role {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink-3);
      margin-bottom: 1.2rem;
    }
    .career-copy { font-size: clamp(0.98rem, 1.3vw, 1.1rem); line-height: 1.7; color: var(--ink-2); max-width: 52ch; }
    .career-tools {
      margin-top: 1.6rem; padding-top: 1.1rem; border-top: 1px solid var(--line);
      font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.1em;
      text-transform: uppercase; color: var(--ink-3); line-height: 1.9;
    }
    .career-tools b { display: block; color: var(--ink); font-weight: 700; font-size: 0.58rem; margin-bottom: 0.2rem; }

    /* ════════ BLACK CONTRAST CUT — wraps THE PROOF ══════════════════ */
    .cut { background: var(--void); color: var(--void-paper); }
    .cut .seq-mark { color: var(--void-2); }
    .cut .seq-mark .num { color: var(--void-paper); }
    .cut .seq-mark .bar { background: var(--void-line); }
    .cut .display { color: var(--void-paper); }

    .proof-head { max-width: 60ch; margin-bottom: clamp(2.6rem, 6vh, 4rem); }
    .proof-head .display { font-size: clamp(3rem, 11vw, 8rem); margin-bottom: 1.4rem; }
    .proof-head p { font-size: clamp(1rem, 1.4vw, 1.18rem); line-height: 1.65; color: var(--void-2); max-width: 56ch; }

    /* poster cards — the motion carriers */
    .poster-grid {
      display: grid; grid-template-columns: 1fr; gap: 1.4rem;
    }
    @media (min-width: 760px) { .poster-grid { grid-template-columns: repeat(3, 1fr); } }
    .poster {
      display: flex; flex-direction: column;
      background: #111114; border: 1px solid var(--void-line);
      text-decoration: none; color: var(--void-paper);
      transition: transform 0.45s var(--ease), border-color 0.35s, box-shadow 0.45s;
      will-change: transform;
    }
    .poster:hover {
      transform: translateY(-8px);
      border-color: #4a4a4a;
      box-shadow: 0 26px 60px rgba(0,0,0,0.6);
    }
    .poster-art { aspect-ratio: 16 / 10; overflow: hidden; border-bottom: 1px solid var(--void-line); }
    .poster-art svg { width: 100%; height: 100%; display: block; transition: transform 0.6s var(--ease); }
    .poster:hover .poster-art svg { transform: scale(1.04); }
    .poster-body { padding: 1.3rem 1.4rem 1.5rem; }
    .poster-title {
      font-family: var(--display); font-weight: 400; font-size: 1.4rem;
      letter-spacing: 0.015em; text-transform: uppercase; line-height: 1.05;
      margin-bottom: 0.5rem; color: var(--void-paper);
    }
    .poster-line { font-size: 0.85rem; line-height: 1.55; color: var(--void-2); margin-bottom: 0.9rem; }
    .poster-credits {
      font-family: var(--mono); font-size: 0.58rem; letter-spacing: 0.12em;
      text-transform: uppercase; color: #a6a6a6;   /* ~5.7:1 on #111 — body-grade */
    }
    .proof-more {
      margin-top: 2rem;
      font-family: var(--mono); font-size: 0.7rem; letter-spacing: 0.06em; color: var(--void-2);
    }
    .proof-more a { color: var(--void-paper); text-decoration: none; border-bottom: 1px solid #4a4a4a; transition: border-color 0.2s; }
    .proof-more a:hover { border-color: var(--void-paper); }

    /* ── 005 · DECISIONS — essays on paper ─────────────────────────── */
    .decisions { border-top: 1px solid var(--line); background: var(--paper-2); }
    .decisions-head { max-width: 60ch; margin-bottom: clamp(2.4rem, 6vh, 3.6rem); }
    .decisions-head .display { font-size: clamp(2.6rem, 8vw, 6rem); margin-bottom: 1.2rem; }
    .decisions-head p { font-size: clamp(1rem, 1.4vw, 1.15rem); line-height: 1.65; color: var(--ink-2); max-width: 56ch; }
    .essay-grid { display: grid; grid-template-columns: 1fr; gap: 1.2rem; }
    @media (min-width: 760px) { .essay-grid { grid-template-columns: 1fr 1fr; } }
    .essay {
      display: flex; flex-direction: column; justify-content: space-between;
      padding: clamp(1.6rem, 3vw, 2.4rem);
      background: var(--paper); border: 1px solid var(--line);
      text-decoration: none; color: var(--ink);
      transition: transform 0.4s var(--ease), border-color 0.3s, box-shadow 0.4s;
    }
    .essay:hover { transform: translateY(-6px); border-color: var(--ink); box-shadow: 0 22px 48px rgba(0,0,0,0.1); }
    .essay-idx { font-family: var(--mono); font-size: 0.64rem; letter-spacing: 0.2em; color: var(--ink-3); margin-bottom: 1.4rem; }
    .essay-title {
      font-family: var(--sans); font-weight: 700; font-size: clamp(1.3rem, 2.2vw, 1.75rem);
      line-height: 1.18; letter-spacing: -0.01em; margin-bottom: 0.8rem; text-wrap: balance;
    }
    .essay-desc { font-size: 0.92rem; line-height: 1.6; color: var(--ink-2); max-width: 48ch; }
    .essay-read {
      margin-top: 1.6rem; font-family: var(--mono); font-size: 0.66rem; font-weight: 600;
      letter-spacing: 0.18em; text-transform: uppercase; color: var(--ink);
      display: inline-flex; align-items: center; gap: 0.4rem;
      transition: gap 0.25s;
    }
    .essay:hover .essay-read { gap: 0.9rem; }

    /* ════════ BLACK CONTRAST CUT — the TALK finale ═════════════════ */
    .talk { background: var(--void); color: var(--void-paper); text-align: center; }
    .talk-inner { max-width: 72ch; margin: 0 auto; }
    .talk .seq-mark { justify-content: center; color: var(--void-2); }
    .talk .seq-mark .num { color: var(--void-paper); }
    .talk .seq-mark .bar { background: var(--void-line); }
    .talk h2 {
      font-family: var(--display); font-weight: 400;
      font-size: clamp(2.8rem, 10vw, 8.5rem); line-height: 0.95;
      text-transform: uppercase; color: var(--void-paper); text-wrap: balance;
    }
    .talk h2 .em { color: #8a8a8a; }
    .talk-sub { margin: clamp(1.4rem, 4vh, 2.2rem) auto 0; max-width: 56ch; font-size: clamp(1rem, 1.4vw, 1.15rem); line-height: 1.65; color: var(--void-2); }
    .ask-bar {
      display: flex; align-items: center; gap: 1rem;
      width: min(620px, 100%); margin: clamp(2rem, 5vh, 3rem) auto 0;
      padding: 1.05rem 1.4rem;
      border: 1px solid var(--void-line); background: #111114;
      transition: border-color 0.3s;
    }
    .ask-bar:focus-within, .ask-bar:hover { border-color: #4a4a4a; }
    .ask-input {
      flex: 1; min-width: 0; background: transparent; border: none; outline: none;
      color: var(--void-2); font-family: var(--mono); font-size: 0.85rem; cursor: not-allowed;
    }
    .ask-input::placeholder { color: #6a6a6a; }
    .ask-status {
      display: flex; align-items: center; gap: 0.45rem;
      font-family: var(--mono); font-size: 0.58rem; font-weight: 600; letter-spacing: 0.18em;
      color: var(--void-paper); text-transform: uppercase; white-space: nowrap;
    }
    .badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--void-paper); animation: pulse 2.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 0.35; } 50% { opacity: 1; } }
    .talk-note { margin-top: 1.4rem; font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.04em; color: var(--void-2); }
    .talk-note a { color: var(--void-paper); text-decoration: none; border-bottom: 1px solid #4a4a4a; }
    .talk-note a:hover { border-color: var(--void-paper); }

    /* ── FOOTER ────────────────────────────────────────────────────── */
    footer { background: var(--paper); border-top: 1px solid var(--line); padding: 3rem var(--px); }
    .footer-inner {
      max-width: 1280px; margin: 0 auto;
      display: flex; justify-content: space-between; align-items: flex-start;
      flex-wrap: wrap; gap: 1.6rem;
    }
    .footer-name { font-family: var(--display); font-weight: 400; font-size: 1.1rem; letter-spacing: 0.03em; text-transform: uppercase; color: var(--ink); margin-bottom: 0.2rem; }
    .footer-role { font-family: var(--mono); font-size: 0.65rem; color: var(--ink-3); letter-spacing: 0.06em; }
    .footer-links { display: flex; gap: 0.6rem; list-style: none; }
    .footer-icon-link {
      display: flex; align-items: center; justify-content: center;
      width: 38px; height: 38px; color: var(--ink-3);
      border: 1px solid var(--line-2); text-decoration: none;
      transition: color 0.2s, border-color 0.2s;
    }
    .footer-icon-link:hover { color: var(--ink); border-color: var(--ink); }
    .footer-bottom {
      width: 100%; padding-top: 1.4rem; margin-top: 0.4rem; border-top: 1px solid var(--line);
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.4rem;
    }
    .footer-bottom p { font-family: var(--mono); font-size: 0.6rem; color: var(--ink-3); letter-spacing: 0.03em; }

    /* ── reveal primitives (GSAP sets the final state; these are the
          resting / pre-reveal states, neutralised under reduced-motion) ── */
    .reveal { opacity: 0; transform: translateY(28px); }
    .reveal-word { opacity: 0; transform: translateY(8%); }

    /* ── responsive ────────────────────────────────────────────────── */
    @media (max-width: 760px) {
      .chrome-nav { display: none; }
      .career-tools { display: none; }       /* keep career chapters tight on phones */
      .poster-art { aspect-ratio: 16 / 9; }
    }
    @media (max-width: 480px) {
      .index { display: none; }
      .hero-ctas { gap: 0.7rem; }
    }

    /* reduced motion: no transforms, everything present; cards lose lift */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .reveal, .reveal-word { opacity: 1 !important; transform: none !important; }
      .hero h1 .ln > span { transform: none !important; }
      .poster:hover, .essay:hover, .btn-solid:hover { transform: none; }
    }
  </style>
  <TrackBeacon />
</head>

<body>
  <!-- fixed mono chrome — wordmark + nav, blends over white and black cuts -->
  <header class="chrome">
    <a href="/light"><span>Tong.Nie</span> <span class="dim">/ data engineer</span></a>
    <nav class="chrome-nav">
      <a href="#proof">Proof</a>
      <a href="#decisions">Decisions</a>
      <a href="#talk">Talk</a>
      <a href="/cv">CV</a>
    </nav>
  </header>

  <!-- running section index, bottom-right -->
  <div class="index" id="index" aria-hidden="true">
    <span class="cur">000</span><span class="dim">/ 007</span>
  </div>

  <main>

    <!-- ═══ 000 · HERO ════════════════════════════════════════════════ -->
    <section class="hero" id="hero" data-idx="000">
      <p class="hero-kicker reveal">Tong Nie — Data Engineer &amp; Builder</p>
      <h1>
        <span class="ln"><span data-line>An engineer who</span></span>
        <span class="ln"><span data-line>moves data by day.</span></span>
        <span class="ln"><span data-line>A builder who teaches</span></span>
        <span class="ln quiet"><span data-line>it to speak by night.</span></span>
