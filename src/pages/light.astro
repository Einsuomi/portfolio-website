    .footer-bottom {
      width: 100%; padding-top: 1.5rem; margin-top: 1rem; border-top: 1px solid #1e1e1e;
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.35rem;
    }
    .footer-bottom p { font-family: var(--mono); font-size: 0.6rem; color: #8a8a8a; letter-spacing: 0.03em; }

    /* ── responsive ────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .poster-row { flex-direction: column; }
      .poster-art { aspect-ratio: 21 / 9; }
      .essay-row { flex-direction: column; }
      /* mirrored right chapter reads left again on narrow screens */
      .chapter.right .par,
      .chapter.right .ch-copy { margin-left: 0; text-align: left; }
      .chapter.right .ch-kicker, .chapter.right h2 { text-align: left; }
      .chapter.content.right .ch-sub { margin-left: 0; text-align: left; }
      .chapter.finale .par { text-align: center; }
    }

    @media (max-width: 720px) {
      /* phone: drop the section nav (scroll drives the film); keep a compact
         chrome row of just the pill + live page marker so it stays short and
         can't overlap the chapters beneath */
      .chrome { align-items: center; justify-content: space-between; gap: 1rem; }
      .nav { display: none; }
      .chrome-right { flex-direction: row; align-items: center; gap: 1rem; }
      .head { max-width: none; padding-top: clamp(6.5rem, 16vh, 9rem); }
      .stage-meta, .chapter.intro .stage-meta { display: none; }   /* avoid colliding with scroll hint on a phone */
      /* chapters clear the compact chrome row above them */
      .chapter:not(.intro) { padding-top: clamp(6rem, 15vh, 9rem); }
      .chapter.content { padding-top: clamp(7rem, 17vh, 10rem); }
      /* on a phone the page-marker already carries the beat number, and the
         stacked posters/essays fill the frame down to where ch-num sits */
      .chapter.content .ch-num, .ch-credits { display: none; }
      .ghost { display: none; }
      .ghost { display: none; }   /* watermark crowds a phone */
    }

    /* short viewports: compact content beats so they can't clip in the pin */
    @media (max-height: 760px) {
      .chapter h2 { font-size: clamp(2.4rem, 7vw, 4.5rem); }
      .chapter.content h2 { font-size: clamp(2rem, 5vw, 3.4rem); }
      .ch-copy, .chapter.content .ch-sub { margin-top: 0.8rem; }
      .poster-art { aspect-ratio: 21 / 6; }
      .poster-line { display: none; }
      .ch-credits { display: none; }
      .ghost { display: none; }
    }

    /* reduced motion AND no-JS: no pin, no canvas — chapters stack as
       readable static sections so every beat stays reachable */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .dots, .ghost { display: none; }
      .stage { height: auto; overflow: visible; }
      .chrome { position: static; }
      .chapter, .chapter:not(.intro) {
        position: relative; inset: auto;
        opacity: 1 !important; visibility: visible !important;
        display: flex !important;
        min-height: 0; height: auto;
        padding: clamp(3rem, 7vh, 5rem) var(--px);
