---
/**
 * Light version — FULL BUILD.
 *
 * v3's complete choreography (index.astro) re-skinned in the APPROVED light
 * grammar from hero-light.astro (the direction gate). The whole page is ONE
 * pinned cinematic stage; scroll scrubs seven beats that crossfade in place:
 *   00 INTRO    — the approved hero, carried in essentially verbatim
 *   01 ENERGY   — Neste
 *   02 LOGISTICS— PostNord
 *   03 SCALE    — Basware
 *   04 THE PROOF— three premium light media cards
 *   05 DECISIONS WRITTEN DOWN — two essay cards
 *   06 TALK     — the finale + disabled chat shell
 * Only the footer scrolls after the film ends.
 *
 * BACKGROUND across the whole pin is the dot-field canvas from the approved
 * hero (no image sequence, no corridor frames). The field evolves per beat —
 * density, drift direction, parallax depth shift slowly so the background
 * never hard-cuts, the same continuity law v3 had with its frame sequence,
 * just a different medium.
 *
 * SKIN: light, not inverted dark. Surfaces #fff/#fafafa/#f4f4f4, ink
 * #0a0a0a–#1a1a1a, secondary #595959 floor (AA on #fafafa), one accent —
 * solid #000 blocks/pills. Chapter display words in heavy neutral grotesk,
 * hard ceiling 6rem desktop / 2.75rem mobile. Numbered-section chrome
 * (001/002/…) alternating placement per beat.
 *
 * Visibility law: NAME + ROLE are server-rendered and visible immediately
 * (data-hero-critical). The manifesto types in as embellishment. Reduced
 * motion AND no-JS → chapters stack as readable static sections, canvas
 * hidden. GSAP lazy-loaded after first paint.
 */
import { icons } from '../lib/lucide-icons.js';
import TrackBeacon from '../components/TrackBeacon.astro';

function icon(data: any[], size = 16, cls = ''): string {
  if (!data) return '';
  const inner = (data as [string, Record<string, string>][])
    .map(([tag, attrs]) =>
      `<${tag} ${Object.entries(attrs).map(([k, v]) => `${k}="${v}"`).join(' ')}/>`
    ).join('');
  const c = cls ? ` class="${cls}"` : '';
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"${c} aria-hidden="true">${inner}</svg>`;
}

const GithubData: [string, Record<string, string>][] = [
  ["path",{"d":"M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"}],
  ["path",{"d":"M9 18c-4.51 2-5-2-7-2"}],
];
const LinkedinData: [string, Record<string, string>][] = [
  ["path",{"d":"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"}],
  ["rect",{"width":"4","height":"12","x":"2","y":"9"}],
  ["circle",{"cx":"4","cy":"4","r":"2"}],
];
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Tong Nie — Data Engineer. Three industries, one craft. An engineer who moves data by day; a builder who teaches it to speak by night." />
  <meta name="generator" content={Astro.generator} />
  <title>Tong Nie — Data Engineer</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      /* surfaces only from the verified Skvortsov palette */
      --bg:        #ffffff;
      --surface:   #fafafa;
      --surface-2: #f4f4f4;
      /* type: pure-black primary, mid-grey secondary (AA on #fafafa) */
      --ink:       #0a0a0a;
      --ink-2:     #1a1a1a;
      --ink-soft:  #595959;   /* secondary — no lighter than this (AA) */
      --rule:      #e4e4e4;
      --rule-2:    #d4d4d4;
      /* one accent maximum: the solid-black pill/blocks */
      --pill:      #000000;
      --grotesk:   'Helvetica Neue', 'Helvetica', 'Arial', sans-serif;
      --mono:      ui-monospace, 'Cascadia Code', 'JetBrains Mono', 'Fira Code', monospace;
      --px:        clamp(1.5rem, 5vw, 4rem);
      --ease:      cubic-bezier(0.22, 1, 0.36, 1);
    }

    html { background: var(--bg); }
    body {
      background: var(--bg); color: var(--ink);
      font-family: var(--grotesk);
      line-height: 1.6;
      -webkit-font-smoothing: antialiased;
      text-rendering: optimizeLegibility;
      overflow-x: hidden;
    }
    :focus-visible { outline: 2px solid #000; outline-offset: 3px; }

    /* ── pinned stage ──────────────────────────────────────────────── */
    .stage {
      position: relative;
      height: 100svh;
      overflow: hidden;
      background: var(--bg);
    }
    /* drifting-dot field sits under every beat; text never relies on it */
    .dots {
      position: absolute; inset: 0; z-index: 0;
      width: 100%; height: 100%;
      display: block;
      pointer-events: none;
    }

    /* ── top chrome: numbered nav (left) + pill CTA (right) ─────────── */
    .chrome {
      position: absolute; top: 0; left: 0; right: 0; z-index: 30;
      display: flex; align-items: flex-start; justify-content: space-between;
      gap: 1.5rem;
      padding: clamp(1.4rem, 3vw, 2.4rem) var(--px) 0;
      pointer-events: none;
    }
    .chrome > * { pointer-events: auto; }

    /* numbered nav — sections, thin rule above each like the reference */
    .nav {
      display: flex; gap: clamp(1.4rem, 4vw, 3.2rem);
      list-style: none; flex-wrap: wrap;
    }
    .nav a {
      display: grid; gap: 0.5rem;
      min-width: clamp(7rem, 13vw, 10rem);
      padding-top: 0.55rem;
      border-top: 1px solid var(--ink);
      text-decoration: none;
      color: var(--ink);
    }
    .nav .row {
      display: flex; align-items: baseline; justify-content: space-between;
      gap: 0.8rem;
    }
    .nav .label {
      font-family: var(--grotesk);
      font-weight: 700; font-size: 0.78rem; letter-spacing: 0.04em;
      text-transform: uppercase;
      transition: opacity 0.2s;
    }
    .nav .num {
      font-family: var(--mono);
      font-size: 0.68rem; font-weight: 500; letter-spacing: 0.08em;
      color: var(--ink-soft);
    }
    .nav a:hover .label { opacity: 0.55; }

    /* right cluster: black pill + live page marker stacked beneath it.
       gap kept tight so the marker stays inside the chrome band and never
       reaches down into chapter content */
    .chrome-right {
      display: flex; flex-direction: column; align-items: flex-end;
      gap: clamp(0.9rem, 2vh, 1.4rem);
    }
    .pill {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.5rem;
      background: var(--pill); color: #fff;
      border-radius: 999px;
      font-family: var(--grotesk);
      font-weight: 700; font-size: 0.76rem; letter-spacing: 0.04em;
      text-transform: uppercase; text-decoration: none;
      white-space: nowrap;
      transition: transform 0.18s var(--ease), opacity 0.18s;
    }
    .pill:hover { transform: translateY(-1px); opacity: 0.9; }
    .page-marker {
      font-family: var(--mono);
      font-size: 0.74rem; font-weight: 600; letter-spacing: 0.06em;
      color: var(--ink);
    }

    /* ── chapters — every beat shares this one mechanism ───────────── */
    .chapter {
      position: absolute; inset: 0; z-index: 6;
      display: flex; flex-direction: column; justify-content: center;
      padding: clamp(5rem, 11vh, 8rem) var(--px) clamp(4rem, 9vh, 6rem);
      pointer-events: none;
      opacity: 0;
    }
    .chapter:not(.intro) { visibility: hidden; }
    .chapter .par { width: 100%; max-width: 60rem; }

    /* ghost watermark word behind a chapter — the reference's faded
       "SELECTED WORKS". Barely-there on white, vertically centred behind the
       display word so it never enters the top chrome band or sits over body
       copy in any frame. Decorative only (aria-hidden, no text the harness
       can collide with that matters — it's behind everything at z-index -1). */
    .ghost {
      position: absolute; z-index: -1;
      top: 50%; transform: translateY(-50%);
      font-family: var(--grotesk);
      font-weight: 800; line-height: 0.9;
      font-size: clamp(9rem, 30vw, 26rem);
      letter-spacing: -0.04em; text-transform: uppercase;
      color: #f3f3f3;
      user-select: none; pointer-events: none; white-space: nowrap;
    }
    /* ghost sits on the OPPOSITE edge from the content so the big faint
       numeral never overlaps the live copy in any frame */
    .chapter.left  .ghost { right: -2%; }
    .chapter.right .ghost { left: -2%; }

    /* the chapter numeral marker — pinned to the BOTTOM corner, clear of the
       fixed top chrome (nav + pill + page-marker live up there) */
    .ch-num {
      position: absolute;
      bottom: clamp(1.6rem, 4.5vh, 2.8rem);
      font-family: var(--mono);
      font-size: clamp(0.74rem, 1.1vw, 0.9rem); font-weight: 600;
      letter-spacing: 0.14em; color: var(--ink-soft);
    }
    /* film-credit kicker: company · role · years */
    .ch-kicker {
      font-family: var(--mono);
      font-size: 0.72rem; font-weight: 600; letter-spacing: 0.22em;
      color: var(--ink-soft); text-transform: uppercase; margin-bottom: 1.2rem;
    }
    /* the heavy display word — hard ceiling 6rem / 2.75rem mobile */
    .chapter h2 {
      font-family: var(--grotesk);
      font-weight: 800;
      font-size: clamp(2.75rem, 9vw, 6rem);
      line-height: 0.92;
      letter-spacing: -0.035em;
      text-transform: uppercase;
      color: var(--ink);
    }
    /* exactly two lines of copy per career chapter */
    .ch-copy {
      max-width: 42rem; margin-top: 1.5rem;
      font-size: clamp(1rem, 1.45vw, 1.2rem); line-height: 1.65;
      color: var(--ink-soft);
    }
    .ch-copy .accent { color: var(--ink); font-weight: 600; }
    /* tools as end-credits, opposite corner */
    .ch-credits {
      position: absolute; bottom: clamp(2.4rem, 7vh, 5rem);
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 500; letter-spacing: 0.14em;
      color: var(--ink-soft); text-transform: uppercase;
      line-height: 2.2;
    }
    .ch-credits b { display: block; color: var(--ink); font-weight: 700; font-size: 0.58rem; }

    /* placement variants — alternate corners so beats never repeat.
       left chapters: numeral top-right, credits bottom-right.
       right chapters: content right-aligned, numeral top-left, credits left. */
    /* left chapters: numeral bottom-left, tool credits bottom-right */
    .chapter.left  .ch-num     { left: var(--px); }
    .chapter.left  .ch-credits { right: var(--px); text-align: right; }
    /* right chapters: content right-aligned, numeral bottom-right, credits left */
    .chapter.right .par        { margin-left: auto; text-align: right; }
    .chapter.right .ch-kicker,
    .chapter.right h2          { text-align: right; }
    .chapter.right .ch-copy    { margin-left: auto; text-align: right; }
    .chapter.right .ch-num     { right: var(--px); }
    .chapter.right .ch-credits { left: var(--px); text-align: left; }
    /* content chapters: numeral always bottom-left (header owns the top) */
    .chapter.content .ch-num   { left: var(--px); right: auto; }

    /* content chapters (04–06): header starts below the top chrome band
       (nav + pill + page-marker), content fills the rest of the frame */
    .chapter.content { justify-content: flex-start; padding-top: clamp(7.5rem, 16vh, 11rem); }
    .chapter.content .par { max-width: none; }
    .chapter.content h2 { font-size: clamp(2.4rem, 6vw, 4.5rem); }
    .chapter.content .ch-sub {
      margin: 1rem 0 2rem;
      font-size: clamp(0.95rem, 1.3vw, 1.1rem); color: var(--ink-soft);
      max-width: 52ch; line-height: 1.6;
    }
    .chapter.content.right .ch-sub { margin-left: auto; text-align: right; }

    /* ── INTRO chapter — the approved hero, carried in verbatim ─────── */
    .chapter.intro {
      justify-content: flex-start;
      padding: 0;
      opacity: 1;
    }
    .head {
      position: relative; z-index: 2;
      padding: clamp(6rem, 14vh, 9rem) var(--px) 0;
      max-width: 46rem;   /* widened so the manifesto sits one line/sentence */
    }
    .name {
      font-family: var(--grotesk);
      font-weight: 800;
      font-size: clamp(2.5rem, 9.5vw, 6rem);  /* ≤ 6rem desktop / ≤ 2.75rem @390 */
      line-height: 0.9;
      letter-spacing: -0.035em;
      text-transform: uppercase;
      color: var(--ink);
    }
    .name .ln { display: block; }
    .role {
      margin-top: clamp(1.1rem, 2.6vh, 1.7rem);
      font-family: var(--grotesk);
      font-weight: 700;
      font-size: clamp(1.05rem, 1.5vw, 1.25rem);  /* role 18–22px band */
      line-height: 1.25;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--ink-2);
    }
    .role .ln { display: block; }
    .manifesto {
      margin-top: clamp(1.3rem, 3vh, 2rem);
      font-family: var(--grotesk);
      font-weight: 400;
      font-size: clamp(1rem, 1.45vw, 1.25rem);   /* body 16–20px */
      line-height: 1.6;
      color: var(--ink-soft);
      max-width: 42rem;
    }
    .manifesto .ln { display: block; }
    .manifesto .accent { color: var(--ink); font-weight: 600; }
    .actions {
      display: flex; align-items: center; gap: 1.5rem;
      margin-top: clamp(1.6rem, 3.5vh, 2.4rem);
      flex-wrap: wrap;
      pointer-events: auto;
    }
    .link-cta {
      display: inline-flex; align-items: center; gap: 0.45rem;
      font-family: var(--grotesk);
      font-weight: 700; font-size: 0.82rem; letter-spacing: 0.02em;
      text-transform: uppercase; text-decoration: none;
      color: var(--ink);
      padding-bottom: 0.25rem;
      border-bottom: 1.5px solid var(--ink);
      transition: gap 0.2s var(--ease);
    }
    .link-cta:hover { gap: 0.75rem; }

    /* scroll hint pinned bottom-left of the viewport */
    .scroll-hint {
      position: absolute; left: var(--px);
      bottom: clamp(1.4rem, 4vh, 2.4rem); z-index: 2;
      display: inline-flex; align-items: center; gap: 0.5rem;
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 500; letter-spacing: 0.18em;
      text-transform: uppercase; text-decoration: none;
      color: var(--ink-soft);
      pointer-events: auto;
    }
    .scroll-hint svg { animation: bob 2.6s ease-in-out infinite; }
    @keyframes bob { 0%, 100% { transform: translateY(0); } 50% { transform: translateY(4px); } }

    /* section marker bottom-right — quiet mono chrome */
    .stage-meta {
      position: absolute; right: var(--px);
      bottom: clamp(1.4rem, 4vh, 2.4rem); z-index: 2;
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 500; letter-spacing: 0.14em;
      text-transform: uppercase; color: var(--ink-soft);
      text-align: right;
    }
    .chapter.intro .scroll-hint,
    .chapter.intro .stage-meta { display: inline-flex; }

    /* manifesto + actions start hidden for the type-in; NAME/ROLE always shown */
    .manifesto .ln, .actions { opacity: 0; }

    /* ── 04 THE PROOF — premium light media cards ──────────────────── */
    .poster-row {
      display: flex; gap: clamp(1rem, 2vw, 1.6rem);
      pointer-events: auto;
      width: 100%;
      margin-top: 0.4rem;
    }
    .poster {
      flex: 1; min-width: 0;
      display: flex; flex-direction: column;
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 14px;
      overflow: hidden;
      text-decoration: none;
      box-shadow: 0 1px 2px rgba(0,0,0,0.03);
      transition: transform 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s;
    }
    .poster:hover {
      transform: translateY(-6px);
      border-color: var(--rule-2);
      box-shadow: 0 24px 50px -18px rgba(0,0,0,0.22);
    }
    .poster-art {
      aspect-ratio: 16 / 9; min-height: 0; overflow: hidden;
      background: var(--surface-2);
      border-bottom: 1px solid var(--rule);
    }
    .poster-art svg { width: 100%; height: 100%; display: block; }
    .poster-body { padding: clamp(1.1rem, 1.6vw, 1.5rem); }
    .poster-title {
      font-family: var(--grotesk);
      font-weight: 800; font-size: clamp(1.05rem, 1.4vw, 1.2rem);
      letter-spacing: -0.01em; text-transform: uppercase;
      color: var(--ink); line-height: 1.1; margin-bottom: 0.45rem;
    }
    .poster-line {
      font-size: 0.86rem; color: var(--ink-soft); line-height: 1.55;
      margin-bottom: 0.9rem;
    }
    .poster-credits {
      font-family: var(--mono);
      font-size: 0.6rem; letter-spacing: 0.1em; text-transform: uppercase;
      color: var(--ink-soft);
    }
    .builds-more {
      margin-top: clamp(1.2rem, 2.5vh, 1.8rem);
      font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.04em;
      color: var(--ink-soft);
      pointer-events: auto;
    }
    .builds-more a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); }
    .builds-more a:hover { opacity: 0.6; }

    /* ── 05 DECISIONS — two essay cards, same family ───────────────── */
    .essay-row {
      display: flex; gap: clamp(1rem, 2vw, 1.6rem);
      width: 100%; margin-top: 0.4rem;
      pointer-events: auto;
      align-items: stretch;
    }
    .essay-card {
      flex: 1; min-width: 0;
      display: flex; flex-direction: column; justify-content: space-between;
      padding: clamp(1.4rem, 2.2vw, 2rem);
      background: var(--surface);
      border: 1px solid var(--rule);
      border-radius: 14px;
      text-decoration: none; text-align: left;   /* body always reads left */
      box-shadow: 0 1px 2px rgba(0,0,0,0.03);
      transition: transform 0.3s var(--ease), box-shadow 0.3s, border-color 0.3s;
    }
    .essay-card:hover {
      transform: translateY(-6px);
      border-color: var(--rule-2);
      box-shadow: 0 24px 50px -18px rgba(0,0,0,0.22);
    }
    .essay-num {
      font-family: var(--mono); font-size: 0.66rem; font-weight: 600;
      letter-spacing: 0.12em; color: var(--ink-soft); margin-bottom: 1rem;
    }
    .essay-title {
      font-family: var(--grotesk);
      font-weight: 800; font-size: clamp(1.25rem, 2.2vw, 1.7rem);
      letter-spacing: -0.02em; text-transform: uppercase;
      color: var(--ink); line-height: 1.1; margin-bottom: 0.7rem;
    }
    .essay-desc { font-size: 0.9rem; color: var(--ink-soft); line-height: 1.6; }
    .essay-read {
      margin-top: 1.4rem;
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 700; letter-spacing: 0.14em;
      color: var(--ink); text-transform: uppercase;
      transition: transform 0.25s; display: inline-block;
    }
    .essay-card:hover .essay-read { transform: translateX(6px); }

    /* ── 06 TALK — the end title card, centered ────────────────────── */
    .chapter.finale { justify-content: center; }
    .chapter.finale .par {
      max-width: 56rem; margin: 0 auto;
      display: flex; flex-direction: column; align-items: center; text-align: center;
    }
    .chapter.finale .ch-kicker { text-align: center; }
    .chapter.finale h2 {
      font-size: clamp(2.5rem, 7vw, 5.5rem);
      line-height: 1.0; text-align: center;
    }
    .talk-line em { font-style: normal; }
    .chapter.finale .ch-sub {
      margin: 1.4rem auto 2.4rem;
      max-width: 50ch; text-align: center;
    }
    /* the ask bar — a command line waiting for the recruiter */
    .ask-bar {
      pointer-events: auto;
      display: flex; align-items: center; gap: 1.1rem;
      width: min(640px, 100%);
      margin: 0 auto;
      padding: 1.05rem 1.4rem;
      background: var(--surface);
      border: 1px solid var(--rule-2);
      border-radius: 999px;
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .ask-bar:hover {
      border-color: var(--ink);
      box-shadow: 0 12px 30px -16px rgba(0,0,0,0.2);
    }
    .ask-input {
      flex: 1; min-width: 0;
      background: transparent; border: none; outline: none;
      color: var(--ink-2);
      font-family: var(--mono); font-size: 0.85rem;
      cursor: not-allowed;
    }
    .ask-input::placeholder { color: var(--ink-soft); }
    .ask-status {
      display: flex; align-items: center; gap: 0.45rem;
      font-family: var(--mono);
      font-size: 0.58rem; font-weight: 700; letter-spacing: 0.16em;
      color: var(--ink); text-transform: uppercase;
      white-space: nowrap;
    }
    .badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--ink); animation: pulse 2.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 0.35; } 50% { opacity: 1; } }
    .chat-note {
      margin-top: 1.2rem; font-family: var(--mono); font-size: 0.7rem; color: var(--ink-soft);
      letter-spacing: 0.02em; pointer-events: auto; text-align: center;
    }
    .chat-note a { color: var(--ink); text-decoration: none; border-bottom: 1px solid var(--ink); }
    .chat-note a:hover { opacity: 0.6; }

    /* ── FOOTER — dark contrast block as punctuation (reference step 10) ─ */
    footer {
      position: relative; z-index: 7;
      background: #0a0a0a; color: #f4f4f4;
      padding: clamp(3rem, 7vh, 5rem) 0 clamp(2rem, 5vh, 3rem);
    }
    .footer-inner {
      max-width: 1180px; margin: 0 auto; padding: 0 var(--px);
      display: flex; justify-content: space-between; align-items: flex-start;
      flex-wrap: wrap; gap: 1.5rem;
    }
    .footer-name { font-family: var(--grotesk); font-weight: 800; font-size: 1.1rem; letter-spacing: -0.01em; text-transform: uppercase; color: #fff; margin-bottom: 0.25rem; }
    .footer-role { font-family: var(--mono); font-size: 0.65rem; color: #b8b8b8; letter-spacing: 0.07em; }
