  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPT — Lenis inertia scroll + GSAP scroll reveals. No canvas,
       no pinned stage. Motion is carried by card reveals, the display-
       word lift, and a restrained parallax drift; everything degrades
       to a static, fully-readable document under reduced-motion / no-JS.
  ═══════════════════════════════════════════════════════════════════ -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    if (!reduceMotion) {
      // smooth inertia scroll (the page scrolls normally — no pin)
      const lenis = new Lenis({ lerp: 0.1 });
      (window as any).__lenis = lenis;
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add(t => lenis.raf(t * 1000));
      gsap.ticker.lagSmoothing(0);

      // anchor links route through Lenis so the inertia stays consistent
      document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach(a => {
        a.addEventListener('click', e => {
          const id = a.getAttribute('href')!;
          const el = document.querySelector(id);
          if (!el) return;
          e.preventDefault();
          lenis.scrollTo(el as HTMLElement, { offset: 0, duration: 1.3 });
        });
      });

      // ── HERO: the manifesto lines rise from their clipped masks.
      //    Real text is already in the DOM — this only moves it, never gates it.
      gsap.set('.hero h1 .ln > span', { yPercent: 110 });
      gsap.to('.hero h1 .ln > span', {
        yPercent: 0, duration: 1, stagger: 0.09, ease: 'power3.out', delay: 0.15,
      });
      gsap.set(['.hero-kicker', '.hero-sub', '.hero-ctas', '.scroll-cue'], { opacity: 0, y: 22 });
      gsap.timeline({ delay: 0.1 })
        .to('.hero-kicker', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' })
        .to('.hero-sub',   { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, 0.8)
        .to('.hero-ctas',  { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, 0.95)
        .to('.scroll-cue', { opacity: 1, y: 0, duration: 0.6, ease: 'power2.out' }, 1.1);

      // ── per-section reveals — VARIED, not a uniform fade-up reflex.
      //    .reveal blocks rise + fade; .reveal-word (display words) lift on a
      //    slightly longer, slower curve so the type leads each chapter.
      gsap.utils.toArray<HTMLElement>('section:not(.hero)').forEach(section => {
        const words = section.querySelectorAll<HTMLElement>('.reveal-word');
        const blocks = section.querySelectorAll<HTMLElement>('.reveal');

        if (words.length) {
          gsap.fromTo(words,
            { opacity: 0, yPercent: 14 },
            { opacity: 1, yPercent: 0, duration: 1.1, ease: 'power3.out',
              stagger: 0.08,
              scrollTrigger: { trigger: section, start: 'top 78%', once: true } });
        }
        if (blocks.length) {
          // poster / essay cards stagger as a group; meta blocks just settle in
          gsap.fromTo(blocks,
            { opacity: 0, y: 30 },
            { opacity: 1, y: 0, duration: 0.85, ease: 'power2.out',
              stagger: 0.1,
              scrollTrigger: { trigger: section, start: 'top 72%', once: true } });
        }
      });

      // ── restrained parallax: each giant display word drifts a little
      //    slower than the scroll, so the type feels anchored a layer back.
      gsap.utils.toArray<HTMLElement>('.career .display').forEach(word => {
        gsap.fromTo(word, { yPercent: 6 }, {
          yPercent: -6, ease: 'none',
          scrollTrigger: { trigger: word.closest('section'), start: 'top bottom', end: 'bottom top', scrub: true },
        });
      });

      // ── running section index, bottom-right — updates as chapters pass
      const indexCur = document.querySelector<HTMLElement>('.index .cur')!;
      gsap.utils.toArray<HTMLElement>('section[data-idx]').forEach(section => {
        ScrollTrigger.create({
          trigger: section, start: 'top 55%', end: 'bottom 55%',
          onToggle: self => { if (self.isActive) indexCur.textContent = section.dataset.idx!; },
        });
      });
    }
    // reduced motion: CSS neutralises .reveal/.reveal-word; nothing to run.
  </script>
</body>
