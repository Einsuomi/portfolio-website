  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPT — dot-field canvas + Lenis + GSAP pin/scrub
  ═══════════════════════════════════════════════════════════════════ -->
  <script>
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── drifting black-dot field — carried from the approved hero, but the
    // field now EVOLVES per beat: density/drift-direction/parallax depth
    // ease between targets so the background never hard-cuts between beats.
    const canvas = document.getElementById('dots') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;

    let W = 0, H = 0, dpr = 1;
    const MAX = 70;                 // pool size; active count varies per beat
    type Dot = { x: number; y: number; r: number; big: boolean; alpha: number; depth: number; spd: number; };
    let dots: Dot[] = [];

    function rand(a: number, b: number) { return a + Math.random() * (b - a); }

    // per-beat field targets — count, drift angle (radians), speed scale,
    // parallax strength. These ease in, so the field morphs, never cuts.
    const FIELDS = [
      { count: 50, ang: 0.00,            speed: 1.0,  par: 1.0 },  // 00 intro — calm, like the hero
      { count: 44, ang: -0.35,           speed: 1.25, par: 1.2 },  // 01 energy — rising drift
      { count: 58, ang: Math.PI * 0.5,   speed: 1.1,  par: 0.9 },  // 02 logistics — lateral flow
      { count: 64, ang: Math.PI * 0.85,  speed: 1.4,  par: 1.3 },  // 03 scale — dense, fast
      { count: 38, ang: 0.15,            speed: 0.7,  par: 0.7 },  // 04 proof — sparse, content room
      { count: 34, ang: -0.15,           speed: 0.65, par: 0.6 },  // 05 thinking — quietest
      { count: 46, ang: Math.PI * 1.5,   speed: 0.9,  par: 1.0 },  // 06 talk — settling
    ];
    // live, eased field state
    const field = { count: 50, ang: 0, speed: 1.0, par: 1.0 };

    function build() {
      dots = [];
      const bigCount = 10;
      for (let i = 0; i < MAX; i++) {
        const big = i < bigCount;
        dots.push({
          x: rand(0, W), y: rand(0, H),
          r: big ? rand(6, 12) : rand(2, 4),
          big,
          alpha: big ? rand(0.06, 0.14) : rand(0.55, 0.95),
          depth: big ? rand(0.6, 1.0) : rand(0.15, 0.5),
          spd: big ? rand(0.02, 0.06) : rand(0.04, 0.12),   // base per-frame speed
        });
      }
    }

    function resize() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);   // capped per CLAUDE.md
      W = canvas.offsetWidth;
      H = canvas.offsetHeight;
      canvas.width = W * dpr;
      canvas.height = H * dpr;
      ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
      build();
    }

    // mouse parallax offset (eased toward target)
    let mx = 0, my = 0, tmx = 0, tmy = 0;
    if (!reduceMotion) {
      window.addEventListener('mousemove', e => {
        tmx = (e.clientX / window.innerWidth - 0.5) * 24;
        tmy = (e.clientY / window.innerHeight - 0.5) * 18;
      });
    }

    function drawDot(d: Dot, ox: number, oy: number) {
      const x = d.x + ox * d.depth * field.par;
      const y = d.y + oy * d.depth * field.par;
      ctx.beginPath();
      if (d.big) {
        const g = ctx.createRadialGradient(x, y, 0, x, y, d.r);
        g.addColorStop(0, `rgba(0,0,0,${d.alpha})`);
        g.addColorStop(1, 'rgba(0,0,0,0)');
        ctx.fillStyle = g;
        ctx.arc(x, y, d.r, 0, Math.PI * 2);
      } else {
        ctx.fillStyle = `rgba(0,0,0,${d.alpha})`;
        ctx.arc(x, y, d.r, 0, Math.PI * 2);
      }
      ctx.fill();
    }

    function frame() {
      ctx.clearRect(0, 0, W, H);
      void raf;   // rAF handle kept for symmetry; not cancelled (stage lives for the page)
      mx += (tmx - mx) * 0.05;
      my += (tmy - my) * 0.05;
      const dirx = Math.cos(field.ang), diry = Math.sin(field.ang);
      const activeCount = Math.round(field.count);
      for (let i = 0; i < dots.length; i++) {
        const d = dots[i];
        // direction + speed come from the live (eased) field state
        d.x += dirx * d.spd * field.speed;
        d.y += diry * d.spd * field.speed;
        const m = d.r + 2;
        if (d.x < -m) d.x = W + m; else if (d.x > W + m) d.x = -m;
        if (d.y < -m) d.y = H + m; else if (d.y > H + m) d.y = -m;
        // dots beyond the active count for this beat are skipped (density fade)
        if (i < activeCount) drawDot(d, mx, my);
      }
      raf = requestAnimationFrame(frame);
    }

    let raf = 0;
    window.addEventListener('resize', resize);
    resize();

    if (reduceMotion) {
      // static field, drawn once, full intro density
      for (let i = 0; i < 50; i++) drawDot(dots[i], 0, 0);
    } else {
      raf = requestAnimationFrame(frame);

      // ── intro type-in + pin/scrub — GSAP lazy-loaded after first paint so
      // the hero (name + role) is never gated on JS. ──────────────────────
      Promise.all([
        import('gsap'),
        import('gsap/ScrollTrigger'),
        import('lenis'),
      ]).then(([{ gsap }, { ScrollTrigger }, { default: Lenis }]) => {
        gsap.registerPlugin(ScrollTrigger);

        // intro manifesto type-in (≤300ms before motion)
        const introTl = gsap.timeline({ delay: 0.25 });
        introTl.fromTo('.manifesto .ln',
            { opacity: 0, y: 14 },
            { opacity: 1, y: 0, stagger: 0.22, duration: 0.6, ease: 'power2.out' })
          .to('.actions',
            { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2');
        gsap.set('.actions', { y: 10 });

        // smooth inertia scroll
        const lenis = new Lenis({ lerp: 0.09 });
        (window as any).__lenis = lenis;   // exposed for screenshot tooling only
        lenis.on('scroll', ScrollTrigger.update);
        gsap.ticker.add((t: number) => lenis.raf(t * 1000));
        gsap.ticker.lagSmoothing(0);

        const marker = document.getElementById('page-marker')!;

        // ── ONE pinned scrub for the whole film: 7 beats over 760% ──────
        const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
        const tl = gsap.timeline({
          scrollTrigger: {
            trigger: '#stage',
            start: 'top top',
            end: '+=760%',
            pin: true,
            scrub: true,
            onUpdate: self => {
              const p = self.progress;
              // active beat index = whichever beat's HOLD window contains p.
              // thresholds are the midpoints between adjacent hold centres, so
              // the marker flips exactly when one beat hands off to the next.
              const active =
                p < 0.105 ? 0 : p < 0.248 ? 1 : p < 0.391 ? 2 : p < 0.534 ? 3 :
                p < 0.677 ? 4 : p < 0.820 ? 5 : 6;
              marker.textContent = `(00${active + 1})`;
              // ease the live field toward the active beat's target —
              // density / drift / parallax morph, the background never cuts
              const f = FIELDS[active];
              field.count += (f.count - field.count) * 0.04;
              field.ang   += (f.ang   - field.ang)   * 0.04;
              field.speed += (f.speed - field.speed) * 0.04;
              field.par   += (f.par   - field.par)   * 0.04;
            },
          },
        });

        // Seven evenly-spaced beats over the pin. Each beat: [fadeInStart,
        // fadeOutEnd] in PROGRESS units (0–1). A trailing zero-tween pins the
        // timeline's total duration to exactly 1.0 so progress maps linearly to
        // these positions (no scrub skew). Holds are wide so each beat reads.
        const FADE = 0.03;
        const windows: [HTMLElement, number, number][] = [
          [chapters[0], 0.000, 0.090],
          [chapters[1], 0.105, 0.233],
          [chapters[2], 0.248, 0.376],
          [chapters[3], 0.391, 0.519],
          [chapters[4], 0.534, 0.662],
          [chapters[5], 0.677, 0.805],
          [chapters[6], 0.820, 1.000],   // finale holds to the very end
        ];
        // autoAlpha = opacity + visibility, so hidden chapters can't catch clicks
        for (const [el, a, b] of windows) {
          if (a > 0) tl.fromTo(el, { autoAlpha: 0, y: 40 }, { autoAlpha: 1, y: 0, duration: FADE }, a);
          if (b < 1) tl.to(el, { autoAlpha: 0, y: -40, duration: FADE }, b - FADE);
        }
        // anchor total duration to exactly 1.0 (a no-op tween at t=1.0)
        tl.set({}, {}, 1.0);

        // nav links + pill + scroll hint jump to a point inside the film
        const st = tl.scrollTrigger!;
        document.querySelectorAll<HTMLAnchorElement>('a[data-jump]').forEach(a => {
          a.addEventListener('click', e => {
            e.preventDefault();
            const frac = Number(a.dataset.jump);
            lenis.scrollTo(st.start + (st.end - st.start) * frac, { duration: 1.6 });
          });
        });

        // text parallax: content drifts gently against the field
        window.addEventListener('mousemove', e => {
          const nx = (e.clientX / innerWidth - 0.5), ny = (e.clientY / innerHeight - 0.5);
          gsap.to('.par', { x: nx * -8, y: ny * -6, duration: 0.6, ease: 'power2.out', overwrite: 'auto' });
        });

        // footer reveal — the only scrolled content after the film
        gsap.from('.footer-inner > *', {
          scrollTrigger: { trigger: 'footer', start: 'top 92%', once: true },
          opacity: 0, y: 14, stagger: 0.1, duration: 0.6, ease: 'power2.out',
        });
      });
    }
  </script>
</body>
</html>
