---
/**
 * /scroll-demo — Option A prototype: scroll-scrubbed image sequence.
 *
 * A pinned full-viewport canvas plays public/seq/frame_000..119.jpg as the
 * user scrolls (scroll position = camera position). Chapter typography
 * fades in over the canvas at fixed scroll windows, like the reference
 * scrollytelling sites. Frames are code-rendered placeholders — swap the
 * /public/seq folder for AI-generated cinematic frames later, nothing
 * else changes.
 */
const FRAMES = 120;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Scroll demo — Tong Nie</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:     #07070a;
      --text:   #edeae2;
      --text-2: #b5b0a8;
      --text-3: #6e6a65;
      --accent: #c9a35a;
      --mono:   ui-monospace,'Cascadia Code','JetBrains Mono','Fira Code',monospace;
      --sans:   'Helvetica Neue',Helvetica,'Arial Nova',Arial,sans-serif;
    }

    html { background: var(--bg); }
    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--sans);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* film grain over everything, same trick as the home page */
    .grain {
      position: fixed; inset: -100%; z-index: 50; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 240 240' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.05;
      animation: grain 8s steps(10) infinite;
    }
    @keyframes grain {
      0%,100% { transform: translate(0,0); }      20% { transform: translate(-3%,2%); }
      40%     { transform: translate(2%,-3%); }   60% { transform: translate(-2%,-2%); }
      80%     { transform: translate(3%,3%); }
    }

    /* loading veil — lifts once the sequence is in memory */
    .loader {
      position: fixed; inset: 0; z-index: 60;
      background: var(--bg);
      display: grid; place-items: center;
      font-family: var(--mono); font-size: 0.72rem; letter-spacing: 0.3em;
      color: var(--text-3);
      transition: opacity 0.6s, visibility 0.6s;
    }
    .loader.done { opacity: 0; visibility: hidden; }
    .loader .bar {
      display: block; width: 180px; height: 1px; margin-top: 1rem;
      background: #222230; position: relative; overflow: hidden;
    }
    .loader .bar i {
      position: absolute; inset: 0; transform-origin: left;
      background: var(--accent); transform: scaleX(0);
    }

    /* the pinned stage: canvas + chapters live here for 500vh of scroll */
    .stage { position: relative; height: 100vh; overflow: hidden; }
    .stage canvas { position: absolute; inset: 0; width: 100%; height: 100%; display: block; }

    /* chapter overlays — hidden by default, GSAP drives opacity/position */
    .chapter {
      position: absolute; inset: 0; z-index: 10;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: clamp(1.5rem, 6vw, 6rem);
      pointer-events: none;
      opacity: 0;
    }
    .chapter .num {
      position: absolute; top: clamp(1.5rem, 8vh, 5rem); left: clamp(1.5rem, 6vw, 6rem);
      font-weight: 200; font-size: clamp(3rem, 8vw, 7rem); line-height: 1;
      color: var(--text);
    }
    .chapter .kicker {
      font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.4em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1rem;
    }
    .chapter h2 {
      font-weight: 700; letter-spacing: -0.03em; line-height: 0.92;
      font-size: clamp(3.5rem, 13vw, 11rem);
      text-transform: uppercase;
    }
    .chapter p {
      max-width: 34ch; margin-top: 1.2rem;
      font-size: clamp(0.95rem, 1.4vw, 1.15rem); line-height: 1.6;
      color: var(--text-2);
    }
    /* alternate chapters push text to the right, like the reference */
    .chapter.right { align-items: flex-end; text-align: right; }
    .chapter.right .num { left: auto; right: clamp(1.5rem, 6vw, 6rem); }

    /* intro overlay sits centered */
    .chapter.intro { justify-content: center; align-items: flex-start; }
    .chapter.intro h1 {
      font-weight: 700; letter-spacing: -0.03em; line-height: 0.92;
      font-size: clamp(3.5rem, 12vw, 10rem); text-transform: uppercase;
    }
    .chapter.intro .kicker { margin-top: 1.4rem; margin-bottom: 0; }
    .scroll-hint {
      position: absolute; bottom: 2rem; left: 50%; transform: translateX(-50%);
      font-family: var(--mono); font-size: 0.65rem; letter-spacing: 0.35em;
      color: var(--text-3);
    }

    /* mono HUD so we can judge the mechanics while testing */
    .hud {
      position: fixed; bottom: 1.2rem; left: 1.4rem; z-index: 40;
      font-family: var(--mono); font-size: 0.62rem; letter-spacing: 0.18em;
      color: var(--text-3); pointer-events: none;
    }

    /* plain section after the pin so you feel the hand-off back to normal flow */
    .after {
      min-height: 70vh; display: grid; place-items: center;
      padding: 4rem clamp(1.5rem, 6vw, 6rem); text-align: center;
    }
    .after p { max-width: 52ch; color: var(--text-2); line-height: 1.7; }
    .after .kicker {
      font-family: var(--mono); font-size: 0.68rem; letter-spacing: 0.4em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.2rem;
    }
    .after a { color: var(--accent); }
  </style>
</head>

<body>
  <div class="grain"></div>

  <div class="loader" id="loader">
    <div>
      LOADING SEQUENCE <span id="load-count">000</span>/{FRAMES}
      <span class="bar"><i id="load-bar"></i></span>
    </div>
  </div>

  <main>
    <section class="stage" id="stage">
      <canvas id="seq"></canvas>

      <!-- 00 · intro -->
      <div class="chapter intro" data-ch="0">
        <h1>Tong Nie</h1>
        <div class="kicker">Data Engineer — scroll to run the pipeline</div>
        <div class="scroll-hint">SCROLL ▾</div>
      </div>

      <!-- 01 · bronze -->
      <div class="chapter" data-ch="1">
        <div class="num">01</div>
        <div class="kicker">Bronze — Raw</div>
        <h2>Ingest</h2>
        <p>Fifteen sources, one stream. Everything lands raw, immutable, replayable.</p>
      </div>

      <!-- 02 · silver -->
      <div class="chapter right" data-ch="2">
        <div class="num">02</div>
        <div class="kicker">Silver — Refined</div>
        <h2>Refine</h2>
        <p>Where raw becomes reliable. Cleansed, conformed, tested on every run.</p>
      </div>

      <!-- 03 · gold -->
      <div class="chapter" data-ch="3">
        <div class="num">03</div>
        <div class="kicker">Gold — Served</div>
        <h2>Serve</h2>
        <p>One source of truth, a thousand questions. Dashboards, models, decisions.</p>
      </div>
    </section>

    <section class="after">
      <div>
        <div class="kicker">End of demo</div>
        <p>
          That was 120 code-rendered placeholder frames scrubbed by scroll.
          Swap <code>/public/seq</code> for AI-generated cinematic frames and the
          mechanics stay identical. <a href="/">Back to the current home page →</a>
        </p>
      </div>
    </section>
  </main>

  <div class="hud" id="hud">FRAME 000/{FRAMES} · 0.0 MB</div>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';

    gsap.registerPlugin(ScrollTrigger);

    const FRAMES = 120;
    const canvas = document.getElementById('seq') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const hud = document.getElementById('hud')!;

    // ── preload the whole sequence, tracking bytes for the HUD ──────────
    const images: HTMLImageElement[] = [];
    let loaded = 0;
    let bytes = 0;
    const src = (i: number) => `/seq/frame_${String(i).padStart(3, '0')}.jpg`;

    const loadAll = Promise.all(
      Array.from({ length: FRAMES }, (_, i) => {
        // fetch → blob so we can count real transfer size, then decode
        return fetch(src(i))
          .then(r => r.blob())
          .then(blob => new Promise<void>(resolve => {
            bytes += blob.size;
            const img = new Image();
            img.onload = () => { loaded++; onProgress(); resolve(); };
            img.src = URL.createObjectURL(blob);
            images[i] = img;
          }));
      })
    );

    function onProgress() {
      (document.getElementById('load-count')!).textContent = String(loaded).padStart(3, '0');
      (document.getElementById('load-bar')!).style.transform = `scaleX(${loaded / FRAMES})`;
    }

    // ── canvas: draw a frame with cover-crop so any viewport works ──────
    let current = 0;
    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width = innerWidth * dpr;
      canvas.height = innerHeight * dpr;
      draw(current);
    }
    function draw(i: number) {
      const img = images[i];
      if (!img) return;
      current = i;
      const cw = canvas.width, ch = canvas.height;
      const scale = Math.max(cw / img.width, ch / img.height);
      const w = img.width * scale, h = img.height * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
      hud.textContent = `FRAME ${String(i).padStart(3, '0')}/${FRAMES} · ${(bytes / 1048576).toFixed(1)} MB`;
    }

    // ── boot once everything is decoded ─────────────────────────────────
    loadAll.then(() => {
      document.getElementById('loader')!.classList.add('done');
      resize();
      addEventListener('resize', resize);

      // Lenis gives the scrub its inertia; GSAP reads the smoothed scroll
      const lenis = new Lenis({ lerp: 0.09 });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add(t => lenis.raf(t * 1000));
      gsap.ticker.lagSmoothing(0);

      // one scrubbed timeline: pins the stage for 5 viewport-heights,
      // maps progress → frame index, and slots chapter fades along it
      const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#stage',
          start: 'top top',
          end: '+=500%',
          pin: true,
          scrub: true,
          onUpdate: self => draw(Math.round(self.progress * (FRAMES - 1))),
        },
      });

      // [element, fade-in at, fade-out at] as fractions of the pin
      const windows: [HTMLElement, number, number][] = [
        [chapters[0], 0.00, 0.12],
        [chapters[1], 0.16, 0.38],
        [chapters[2], 0.46, 0.66],
        [chapters[3], 0.76, 1.01],   // last chapter holds to the end
      ];
      for (const [el, a, b] of windows) {
        if (a > 0) tl.fromTo(el, { opacity: 0, y: 40 }, { opacity: 1, y: 0, duration: 0.06 }, a);
        else tl.set(el, { opacity: 1 }, 0);
        if (b <= 1) tl.to(el, { opacity: 0, y: -40, duration: 0.06 }, b - 0.06);
      }
    });
  </script>
</body>
</html>
