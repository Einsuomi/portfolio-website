---
/**
 * Home page — DARK treatment (Phase 1b).
 *
 * Evolves the v3 pinned-stage homepage into the cinematic word-overlap
 * grammar distilled from the reference video (reference/README.md):
 *
 *  - Hero manifesto TYPES in line-by-line over a nearly-still scene.
 *  - A dedicated WORD LAYER carries each chapter's giant display word on
 *    a vertical track: the incoming word slides up from below while the
 *    outgoing one rises and fades — the two briefly coexist. Chapter
 *    numbers / year markers arrive slightly offset, BEFORE the word lands.
 *  - The frame sequence drifts CONTINUOUSLY (slow zoom) — never a hard cut.
 *  - Chrome (number / meta) placement ALTERNATES corners per chapter.
 *  - Projects are compact POSTER cards with mouse-parallax drift.
 *
 * The supporting copy (kicker / body / posters / essays) still crossfades
 * per beat; only the display word is lifted into the travelling layer so
 * the signature overlap reads cleanly.
 *
 * Five-second hero & legibility are law: with JS off or reduced-motion the
 * word layer collapses into the static stacked chapters and every line of
 * copy is simply present. First paint shows the inlined poster frame; the
 * rest of the sequence streams in after load.
 */
import '@fontsource/anton/index.css';
import { icons } from '../lib/lucide-icons.js';
import TrackBeacon from '../components/TrackBeacon.astro';

function icon(data: any[], size = 16, cls = ''): string {
  if (!data) return '';
  const inner = (data as [string, Record<string,string>][])
    .map(([tag, attrs]) =>
      `<${tag} ${Object.entries(attrs).map(([k,v]) => `${k}="${v}"`).join(' ')}/>`
    ).join('');
  const c = cls ? ` class="${cls}"` : '';
  return `<svg xmlns="http://www.w3.org/2000/svg" width="${size}" height="${size}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"${c} aria-hidden="true">${inner}</svg>`;
}

const GithubData: [string, Record<string,string>][] = [
  ["path",{"d":"M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"}],
  ["path",{"d":"M9 18c-4.51 2-5-2-7-2"}],
];
const LinkedinData: [string, Record<string,string>][] = [
  ["path",{"d":"M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"}],
  ["rect",{"width":"4","height":"12","x":"2","y":"9"}],
  ["circle",{"cx":"4","cy":"4","r":"2"}],
];

const FRAMES = 120;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="icon" href="/favicon.ico" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content="Tong Nie — Data Engineer. Three industries, one craft. An engineer who moves data by day; a builder who teaches it to speak by night." />
  <meta name="generator" content={Astro.generator} />
  <title>Tong Nie — Data Engineer</title>

  <!-- Mark the document as JS-capable BEFORE first paint. Every pre-reveal
       hidden state (opacity:0 / visibility:hidden awaiting GSAP) is scoped
       under html.js, so with JS disabled the whole film renders as a
       readable static stack — same un-hiding the reduced-motion stack does. -->
  <script is:inline>document.documentElement.classList.add('js');</script>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:        #07070a;
      --surface:   #0f0f14;
      --surface-2: #15151c;
      --border:    #222230;
      --border-dim:#1a1a24;
      --text:      #edeae2;
      --text-2:    #b5b0a8;
      --text-3:    #8a857d;   /* muted mono chrome — 5.49:1 on --bg, 5.22:1 on --surface (≥4.5 law) */
      --accent:    #c9a35a;
      --accent-dim:#a08040;
      --accent-bg: rgba(201,163,90,0.07);
      --display:   'Anton','Arial Narrow',sans-serif;
      --mono:      ui-monospace,'Cascadia Code','JetBrains Mono','Fira Code',monospace;
      --sans:      'Helvetica Neue',Helvetica,'Arial Nova',Arial,sans-serif;
      --px:        clamp(1.5rem, 5.5vw, 5rem);
      --ease:      cubic-bezier(0.22,1,0.36,1);
    }

    html { background: var(--bg); }
    body {
      background: var(--bg); color: var(--text);
      font-family: var(--sans);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }
    :focus-visible { outline: 2px solid var(--accent); outline-offset: 3px; }

    /* film grain over everything */
    .grain {
      position: fixed; inset: -100%; z-index: 90; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 240 240' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.045;
      animation: grain 8s steps(10) infinite;
    }
    @keyframes grain {
      0%,100% { transform: translate(0,0); }      20% { transform: translate(-3%,2%); }
      40%     { transform: translate(2%,-3%); }   60% { transform: translate(-2%,-2%); }
      80%     { transform: translate(3%,3%); }
    }

    /* ── HUD bar — film-credit chrome instead of a conventional nav ── */
    .hud-bar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 40;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1rem clamp(1.2rem, 4vw, 3rem);
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 700; letter-spacing: 0.22em;
      color: var(--text); text-transform: uppercase;
      background: linear-gradient(to bottom, rgba(7,7,10,0.88), transparent);
    }
    .hud-bar .dim { color: var(--text-3); font-weight: 400; }
    .hud-bar em { color: var(--accent); font-style: normal; }
    .hud-links { display: flex; gap: 1.6rem; }
    .hud-links a { color: var(--text); text-decoration: none; transition: color 0.2s; }
    .hud-links a:hover { color: var(--accent); }

    /* ── chapter progress rail, right edge ─────────────────────────── */
    .rail {
      position: fixed; right: clamp(0.9rem, 2vw, 1.6rem); top: 50%;
      transform: translateY(-50%); z-index: 40;
      display: flex; flex-direction: column; gap: 1.3rem;
      font-family: var(--mono);
      font-size: 0.58rem; font-weight: 700; letter-spacing: 0.2em;
      color: var(--text-3); text-transform: uppercase;
      opacity: 0; transition: opacity 0.4s;
      pointer-events: none;
    }
    .rail.on { opacity: 1; }
    .rail span { writing-mode: vertical-rl; transition: color 0.3s; }
    .rail span.active { color: var(--accent); }

    /* ── pinned stage ──────────────────────────────────────────────── */
    .stage { position: relative; height: 100svh; overflow: hidden; }
    .stage canvas {
      position: absolute; inset: 0; width: 100%; height: 100%;
      /* poster frame is the first paint — inline as a background so the
         canvas area is never an empty black box before JS draws frame 0 */
      background: #07070a url('/seq2/frame_000.jpg') center/cover no-repeat;
    }

    /* cinematic letterbox bars */
    .bar { position: absolute; left: 0; right: 0; height: clamp(18px, 3.5vh, 40px); background: #000; z-index: 5; }
    .bar.top { top: 0; }
    .bar.bottom { bottom: 0; }

    /* ════════════════════════════════════════════════════════════════
       WORD LAYER — the travelling giant display word.
       One word per chapter lives here; GSAP slides each on a vertical
       track so the incoming word rises into place while the outgoing one
       lifts away and fades. This is the signature overlap.
    ════════════════════════════════════════════════════════════════ */
    .wordstage {
      position: absolute; inset: 0; z-index: 7;
      pointer-events: none; overflow: hidden;
    }
    .word {
      position: absolute; left: 0; right: 0;
      /* resting band sits in the upper-middle so the career copy can live
         in the lower third without colliding with the giant word.
         The display word's own baseline lands around 50% of the viewport;
         outgoing words travel UP out of this band so an exiting and an
         entering word occupy different heights while both are on screen. */
      top: 38%;
      display: flex; flex-direction: column;
      padding: 0 clamp(2.5rem, 7vw, 7rem);
      will-change: transform, opacity;
    }
    /* pre-reveal hidden — only when JS will animate it in (see html.js gate) */
    html.js .word { opacity: 0; }
    .word .word-display {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(4rem, 15vw, 14rem);
      line-height: 0.86;
      letter-spacing: 0.005em;
      text-transform: uppercase;
      color: var(--text);
      text-shadow: 0 2px 40px rgba(0,0,0,0.55);
    }
    /* chapter number / year marker — quiet mono chrome, arrives offset */
    .word .word-mark {
      font-family: var(--mono);
      font-size: clamp(0.62rem, 1vw, 0.78rem);
      font-weight: 700; letter-spacing: 0.42em;
      color: var(--accent); text-transform: uppercase;
      margin-bottom: 0.9rem;
      will-change: transform, opacity;
    }
    html.js .word .word-mark { opacity: 0; }
    /* alternating horizontal anchor per chapter */
    .word.anchor-left  { align-items: flex-start; text-align: left; }
    .word.anchor-right { align-items: flex-end;  text-align: right; }
    .word.anchor-center{ align-items: center;    text-align: center; }

    /* ── chapters — supporting copy crossfades over the scene ───────── */
    .chapter {
      position: absolute; inset: 0; z-index: 8;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: clamp(2.5rem, 7vw, 7rem);
      pointer-events: none;
    }
    /* pre-reveal hidden states — gated on JS so a no-JS load shows every
       chapter; with JS the GSAP timeline fades them in/out per beat */
    html.js .chapter { opacity: 0; }
    html.js .chapter:not(.intro) { visibility: hidden; }
    /* readability scrim — type must stay legible over any frame */
    .chapter::before {
      content: '';
      position: absolute; inset: 0; z-index: -1;
      background: linear-gradient(to top,
        rgba(7,7,10,0.9) 0%, rgba(7,7,10,0.4) 38%, transparent 66%);
    }
    /* career-chapter meta block (kicker + body), corner-anchored ───── */
    .ch-kicker {
      font-family: var(--mono);
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.4em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.1rem;
    }
    /* exactly two lines of copy per chapter — the discipline is the design */
    .ch-copy {
      max-width: 44ch; margin-top: 1.3rem;
      font-size: clamp(0.95rem, 1.4vw, 1.15rem); line-height: 1.7;
      color: var(--text);
      text-shadow: 0 1px 14px rgba(0,0,0,0.85);
    }
    .ch-dek {
      font-family: var(--sans);
      font-size: clamp(1.1rem, 1.8vw, 1.45rem); font-weight: 600;
      color: var(--text); margin-bottom: 0.6rem;
      text-shadow: 0 1px 14px rgba(0,0,0,0.85);
    }
    /* tools as end-credits, opposite corner */
    .ch-credits {
      position: absolute; bottom: clamp(3rem, 9vh, 7rem); right: clamp(2.5rem, 7vw, 7rem);
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 500; letter-spacing: 0.22em;
      color: var(--text-2); text-transform: uppercase; text-align: right;
      line-height: 2.2;
      text-shadow: 0 1px 14px rgba(0,0,0,0.9);
    }
    .ch-credits b { display: block; color: var(--text-3); font-weight: 700; font-size: 0.56rem; }

    /* career chapters: meta block bottom-anchored, corner alternates */
    .chapter.career .par { max-width: 52ch; }
    .chapter.career.right { align-items: flex-end; text-align: right; }
    .chapter.career.right .par { text-align: right; }
    .chapter.career.right .ch-credits { right: auto; left: clamp(2.5rem, 7vw, 7rem); text-align: left; }
    /* body copy never right-aligns even when the block is right-anchored */
    .chapter.career.right .ch-copy { margin-left: auto; }

    /* content chapters (04–06): header high, content fills the frame */
    .chapter.content { justify-content: flex-start; padding-top: clamp(8rem, 20vh, 11rem); }
    .chapter.content h2 {
      font-family: var(--display); font-weight: 400;
      font-size: clamp(2.6rem, 7.5vw, 6rem); line-height: 0.95;
      text-transform: uppercase; color: var(--text);
    }
    .chapter.content .par {
      display: flex; flex-direction: column;
      flex: 1; min-height: 0; width: 100%;
    }
    .chapter.content.right .ch-kicker,
    .chapter.content.right h2 { text-align: right; }
    .chapter.content.right .ch-sub { margin-left: auto; text-align: right; }
    .chapter.content .ch-sub {
      margin: 0.9rem 0 1.8rem;
      font-size: 0.92rem; color: var(--text-2); max-width: 54ch;
      text-shadow: 0 1px 16px rgba(0,0,0,0.85);
    }

    /* ── intro chapter — name + manifesto, bottom-left like the ref ── */
    .chapter.intro { justify-content: flex-end; opacity: 1; }
    .chapter.intro::before {
      background: linear-gradient(90deg, rgba(7,7,10,0.82) 0%, rgba(7,7,10,0.3) 52%, transparent 80%),
                  linear-gradient(to top, rgba(7,7,10,0.7) 0%, transparent 45%);
    }
    .intro-kicker {
      font-family: var(--mono);
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.5em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.4rem;
    }
    /* the manifesto — three lines, typed in; large grotesk like the ref */
    .manifesto {
      font-size: clamp(1.5rem, 4vw, 3.1rem);
      line-height: 1.18;
      font-weight: 600;
      color: var(--text);
      max-width: 20ch;
      letter-spacing: -0.01em;
      text-shadow: 0 1px 18px rgba(0,0,0,0.85);
    }
    .manifesto .ln { display: block; position: relative; }
    .manifesto .rule-line { color: var(--accent); }
    /* the blinking caret that rides the end of the active typed line */
    .caret {
      display: inline-block; width: 0.06em; height: 0.95em;
      margin-left: 0.06em; vertical-align: -0.08em;
      background: var(--accent);
      animation: blink 1s steps(1) infinite;
    }
    @keyframes blink { 0%,50% { opacity: 1; } 50.01%,100% { opacity: 0; } }
    /* tiny chip top-right of hero, the floating-poster-card stand-in */
    .hero-chip {
      position: absolute; top: clamp(5rem, 14vh, 8rem); right: clamp(2.5rem, 7vw, 7rem);
      font-family: var(--mono);
      font-size: 0.66rem; line-height: 2.1; letter-spacing: 0.22em;
      color: var(--text-2); text-transform: uppercase; text-align: right;
      will-change: transform, opacity;
      text-shadow: 0 1px 14px rgba(0,0,0,0.9);
    }
    html.js .hero-chip { opacity: 0; }
    .hero-chip b { color: var(--accent); font-weight: 700; }

    .intro-ctas { display: flex; gap: 1rem; margin-top: 2.2rem; flex-wrap: wrap; align-items: center; }
    .chapter.intro .intro-ctas { pointer-events: auto; }
    .btn-a {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.6rem; background: var(--accent); color: #07070a;
      font-family: var(--mono);
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
    }
    .btn-a:hover { background: var(--accent-dim); transform: translateY(-1px); box-shadow: 0 8px 24px rgba(201,163,90,0.3); }
    .btn-b {
      display: inline-flex; align-items: center; gap: 0.5rem;
      padding: 0.85rem 1.6rem; border: 1px solid rgba(237,234,226,0.35); color: var(--text);
      font-family: var(--mono);
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      transition: border-color 0.2s;
    }
    .btn-b:hover { border-color: var(--accent); }
    .scroll-nudge {
      font-family: var(--mono);
      font-size: 0.64rem; color: var(--text-3); letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      display: inline-flex; align-items: center; gap: 0.35rem;
      animation: bob 2.8s ease-in-out infinite;
    }
    .scroll-nudge:hover { color: var(--text); }
    @keyframes bob { 0%,100% { transform: translateY(0); } 50% { transform: translateY(5px); } }

    /* GSAP owns the intro entrance — start hidden to avoid the flash, but
       only when JS is present (no-JS keeps kicker / CTAs / chip visible) */
    html.js .intro-kicker, html.js .intro-ctas, html.js .hero-chip { opacity: 0; }

    /* ── 04 BUILDS — compact poster row inside the chapter ─────────── */
    .poster-row {
      display: flex; gap: 1rem;
      pointer-events: auto;
      flex: 1; min-height: 0;
      margin-top: 0.6rem;
    }
    .poster {
      flex: 1; min-width: 0;
      display: flex; flex-direction: column;
      border: 1px solid var(--border);
      background: rgba(15,15,20,0.92);
      text-decoration: none;
      transition: transform 0.3s var(--ease), border-color 0.3s, box-shadow 0.3s;
      will-change: transform;
    }
    .poster:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
      box-shadow: 0 18px 44px rgba(0,0,0,0.5), 0 0 24px rgba(201,163,90,0.08);
    }
    .poster-art { flex: 1; min-height: 90px; overflow: hidden; border-bottom: 1px solid var(--border-dim); }
    .poster-art svg { width: 100%; height: 100%; display: block; }
    .poster-body { flex-shrink: 0; }
    .builds-more { flex-shrink: 0; }
    #thinking .essay-list { flex: 1; display: flex; flex-direction: column; justify-content: center; }
    #thinking .essay-link { padding: 1.7rem 0.5rem; }
    .poster-body { padding: 0.9rem 1rem 1rem; }
    .poster-title {
      font-family: var(--display);
      font-weight: 400; font-size: 1.1rem; letter-spacing: 0.02em;
      text-transform: uppercase; color: var(--text); line-height: 1.1;
      margin-bottom: 0.35rem;
      transition: color 0.2s;
    }
    .poster:hover .poster-title { color: var(--accent); }
    .poster-line { font-size: 0.78rem; color: var(--text-2); line-height: 1.5; margin-bottom: 0.7rem; }
    .poster-credits {
      font-family: var(--mono);
      font-size: 0.56rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--text-3);
    }
    .builds-more {
      margin-top: 1.1rem;
      font-family: var(--mono); font-size: 0.66rem; letter-spacing: 0.08em;
      color: var(--text-3);
      pointer-events: auto;
      text-shadow: 0 1px 14px rgba(0,0,0,0.9);
    }
    .builds-more a { color: var(--text-2); text-decoration: none; border-bottom: 1px solid var(--border); }
    .builds-more a:hover { color: var(--accent); border-color: var(--accent); }

    /* ── 05 THINKING — two essay cards, same family as the posters ─── */
    .essay-row {
      display: flex; gap: 1rem;
      flex: 1; min-height: 0; margin-top: 0.6rem;
      pointer-events: auto;
      align-items: stretch;
    }
    .essay-card {
      flex: 1; min-width: 0;
      display: flex; flex-direction: column; justify-content: space-between;
      padding: 1.5rem 1.6rem;
      border: 1px solid var(--border);
      background: rgba(15,15,20,0.92);
      text-decoration: none; text-align: left;
      transition: transform 0.3s var(--ease), border-color 0.3s, box-shadow 0.3s;
    }
    .essay-card:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
      box-shadow: 0 18px 44px rgba(0,0,0,0.5), 0 0 24px rgba(201,163,90,0.08);
    }
    .essay-title {
      font-family: var(--display);
      font-weight: 400; font-size: clamp(1.25rem, 2.4vw, 1.8rem);
      letter-spacing: 0.02em; text-transform: uppercase;
      color: var(--text); line-height: 1.15; margin-bottom: 0.6rem;
      transition: color 0.2s;
    }
    .essay-card:hover .essay-title { color: var(--accent); }
    .essay-desc { font-size: 0.86rem; color: var(--text-2); line-height: 1.6; }
    .essay-read {
      margin-top: 1.2rem;
      font-family: var(--mono);
      font-size: 0.66rem; font-weight: 700; letter-spacing: 0.25em;
      color: var(--accent); text-transform: uppercase;
      transition: transform 0.25s; display: inline-block;
    }
    .essay-card:hover .essay-read { transform: translateX(6px); }

    /* ── 06 TALK — the end title card ──────────────────────────────── */
    .chapter.finale { justify-content: center; }
    .chapter.finale .par {
      flex: 0 1 auto;
      align-items: center; text-align: center;
    }
    .chapter.finale h2 {
      padding: 0;
      font-size: clamp(3rem, 9vw, 8rem);
      line-height: 1.02;
      /* clear the tall display line-box so the sub below never tucks under
         the descenders of "Interview it." */
      margin-bottom: clamp(2rem, 4vh, 3rem);
    }
    .talk-line em { font-style: normal; color: var(--accent); }
    .chapter.finale .ch-sub {
      margin: 0 auto 2.4rem;
      max-width: 52ch;
    }
    .ask-bar {
      pointer-events: auto;
      display: flex; align-items: center; gap: 1.1rem;
      width: min(640px, 100%);
      margin: 0 auto;
      padding: 1.05rem 1.4rem;
      border: 1px solid rgba(201,163,90,0.35);
      background: rgba(15,15,20,0.85);
      transition: border-color 0.3s, box-shadow 0.3s;
    }
    .ask-bar:hover {
      border-color: var(--accent);
      box-shadow: 0 0 34px rgba(201,163,90,0.14);
    }
    .ask-input {
      flex: 1; min-width: 0;
      background: transparent; border: none; outline: none;
      color: var(--text-2);
      font-family: var(--mono); font-size: 0.85rem;
      cursor: not-allowed;
    }
    .ask-input::placeholder { color: var(--text-3); }
    .ask-status {
      display: flex; align-items: center; gap: 0.45rem;
      font-family: var(--mono);
      font-size: 0.58rem; font-weight: 700; letter-spacing: 0.18em;
      color: var(--accent); text-transform: uppercase;
      white-space: nowrap;
    }
    .badge-dot { width: 5px; height: 5px; border-radius: 50%; background: var(--accent); animation: pulse 2.5s ease-in-out infinite; }
    @keyframes pulse { 0%,100% { opacity: 0.4; } 50% { opacity: 1; } }
    .chat-note {
      margin-top: 1.1rem; font-family: var(--mono); font-size: 0.64rem; color: var(--text-3);
      letter-spacing: 0.04em; pointer-events: auto;
      text-shadow: 0 1px 14px rgba(0,0,0,0.9);
    }
    /* in-prose link: underlined so it's distinguishable beyond colour (a11y law) */
    .chat-note a { color: var(--accent); text-decoration: underline; text-underline-offset: 0.18em; }
    .chat-note a:hover { text-decoration-thickness: 2px; }

    /* ── FOOTER — the only thing after the film ────────────────────── */
    footer { border-top: 1px solid var(--border); padding: 2.75rem 0; position: relative; z-index: 9; background: var(--bg); }
    .footer-inner {
      max-width: 1180px; margin: 0 auto; padding: 0 var(--px);
      display: flex; justify-content: space-between; align-items: flex-start;
      flex-wrap: wrap; gap: 1.5rem;
    }
    .footer-name { font-family: var(--display); font-weight: 400; font-size: 1rem; letter-spacing: 0.04em; text-transform: uppercase; color: var(--text-2); margin-bottom: 0.2rem; }
    .footer-role { font-family: var(--mono); font-size: 0.65rem; color: var(--text-2); letter-spacing: 0.07em; }
    .footer-links { display: flex; gap: 0.6rem; list-style: none; }
    .footer-icon-link {
      display: flex; align-items: center; justify-content: center;
      width: 36px; height: 36px;
      color: var(--text-3); border: 1px solid var(--border);
      text-decoration: none;
      transition: color 0.2s, border-color 0.2s, box-shadow 0.2s;
    }
    .footer-icon-link:hover { color: var(--accent); border-color: var(--accent); box-shadow: 0 0 12px rgba(201,163,90,0.15); }
    .footer-bottom {
      width: 100%; padding-top: 1.25rem; border-top: 1px solid var(--border-dim);
      display: flex; justify-content: space-between; flex-wrap: wrap; gap: 0.35rem;
    }
    .footer-bottom p { font-family: var(--mono); font-size: 0.6rem; color: var(--text-3); letter-spacing: 0.03em; }

    /* ── responsive ────────────────────────────────────────────────── */
    @media (max-width: 900px) {
      .poster-row { flex-direction: column; gap: 0.6rem; }
      .poster-art { display: none; }
      .poster-body { padding: 0.75rem 0.9rem; }
      .poster-line { display: none; }
      .essay-row { flex-direction: column; gap: 0.6rem; }
      .essay-card { padding: 1rem 1.1rem; }
      .chapter.content.right .ch-kicker,
      .chapter.content.right h2,
      .chapter.content.right .ch-sub { text-align: left; margin-left: 0; }
      /* word display shrinks a touch so a long word can't overflow a phone */
      .word .word-display { font-size: clamp(3.4rem, 16vw, 9rem); }
    }
    @media (max-height: 620px) {
      .chapter.content h2 { font-size: clamp(2.2rem, 6vw, 4rem); }
      .chapter.content .ch-sub { margin: 0.6rem 0 1.1rem; }
      .poster-art { display: none; }
      .poster-line { display: none; }
      .chapter.content { padding-top: clamp(5rem, 14vh, 8rem); }
    }
    @media (max-width: 640px) {
      .ch-credits { display: none; }
      .hero-chip { display: none; }
      .rail { display: none; }
      .hud-links { display: none; }
      .intro-ctas { gap: 0.75rem; }
      .ask-bar { padding: 0.85rem 1rem; }
      /* keep the manifesto from crowding the giant word on a tall phone */
      .word { top: 42%; }
    }

    /* ── STATIC STACK fallback ──────────────────────────────────────────
       Used in TWO cases that share the exact same layout:
         (a) prefers-reduced-motion — the user opted out of motion;
         (b) no JS (html:not(.js)) — GSAP never runs, so the pinned film
             can't play; the chapters must stack as a readable document.
       In both, the pinned stage unpins, the canvas/word-layer drop out,
       and every chapter becomes a normal-flow section with its static
       word + all copy simply present. */
    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
    }
    @media (prefers-reduced-motion: reduce) {
      .grain, .rail, .bar, .wordstage, .caret { display: none; }
      .stage { height: auto; overflow: visible; }
      .stage canvas { display: none; }
      .chapter, .chapter:not(.intro) {
        position: relative; inset: auto;
        opacity: 1 !important; visibility: visible !important;
        display: flex !important;
        min-height: 0;
        padding: 4rem var(--px) 4rem;
        border-top: 1px solid var(--border);
      }
      .chapter::before { display: none; }
      .ch-staticword { display: block !important; }
      .ch-credits { position: static; text-align: left; margin-top: 1.2rem; }
      .hero-chip { position: static; display: block; text-align: left; margin-top: 1.4rem; opacity: 1 !important; }
      .intro-kicker, .manifesto, .intro-ctas { opacity: 1 !important; }
      .chapter.career.right { align-items: flex-start; text-align: left; }
      .chapter.career.right .par, .chapter.career.right .ch-copy { text-align: left; margin-left: 0; }
      /* unpin the HUD so the static document never scrolls under it */
      .hud-bar { position: absolute; }
    }
    /* no-JS branch of the same static stack (cannot live in the media query
       above because it keys off the .js class, not a media feature) */
    html:not(.js) .grain,
    html:not(.js) .rail,
    html:not(.js) .bar,
    html:not(.js) .wordstage,
    html:not(.js) .caret { display: none; }
    html:not(.js) .stage { height: auto; overflow: visible; }
    html:not(.js) .stage canvas { display: none; }
    html:not(.js) .chapter,
    html:not(.js) .chapter:not(.intro) {
      position: relative; inset: auto;
      opacity: 1 !important; visibility: visible !important;
      display: flex !important;
      min-height: 0;
      padding: 4rem var(--px) 4rem;
      border-top: 1px solid var(--border);
    }
    html:not(.js) .chapter::before { display: none; }
    html:not(.js) .ch-staticword { display: block !important; }
    html:not(.js) .ch-credits { position: static; text-align: left; margin-top: 1.2rem; }
    html:not(.js) .hero-chip { position: static; display: block; text-align: left; margin-top: 1.4rem; opacity: 1 !important; }
    html:not(.js) .intro-kicker,
    html:not(.js) .manifesto,
    html:not(.js) .intro-ctas { opacity: 1 !important; }
    html:not(.js) .chapter.career.right { align-items: flex-start; text-align: left; }
    html:not(.js) .chapter.career.right .par,
    html:not(.js) .chapter.career.right .ch-copy { text-align: left; margin-left: 0; }
    /* the fixed HUD over a static document would overlap content — pin it
       to the top of the flow instead so nothing scrolls illegibly under it */
    html:not(.js) .hud-bar { position: absolute; }

    /* the in-chapter static word is hidden by default (the animated word
       layer carries it); reduced-motion turns it back on above */
    .ch-staticword {
      display: none;
      font-family: var(--display); font-weight: 400;
      font-size: clamp(3rem, 12vw, 7rem); line-height: 0.9;
      text-transform: uppercase; color: var(--text);
      margin: 0.4rem 0 1rem;
    }
    .ch-staticmark {
      font-family: var(--mono); font-size: 0.7rem; font-weight: 700;
      letter-spacing: 0.4em; color: var(--accent); text-transform: uppercase;
    }
  </style>
