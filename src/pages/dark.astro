  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';

    gsap.registerPlugin(ScrollTrigger);

    const FRAMES = 120;
    const canvas = document.getElementById('seq') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const hudSeq = document.getElementById('hud-seq')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── frame loading — DEFERRED until after first paint so the inlined
    //    poster (CSS background on the canvas) is the LCP, not a frame fetch
    const images: HTMLImageElement[] = [];
    const ready: boolean[] = [];
    let current = 0;
    let framesLoaded = false;

    function loadFrame(i: number) {
      const img = new Image();
      img.onload = () => { ready[i] = true; if (i === current) draw(i); };
      img.src = `/seq2/frame_${String(i).padStart(3, '0')}.jpg`;
      images[i] = img;
    }
    function loadAllFrames() {
      if (framesLoaded) return;
      framesLoaded = true;
      for (let i = 0; i < FRAMES; i++) loadFrame(i);
    }
    // kick the sequence off only once the page has actually painted
    if (document.readyState === 'complete') requestIdleStart();
    else window.addEventListener('load', requestIdleStart, { once: true });
    function requestIdleStart() {
      const ric = (window as any).requestIdleCallback as
        | ((cb: () => void) => void) | undefined;
      if (ric) ric(loadAllFrames); else setTimeout(loadAllFrames, 200);
    }

    function nearest(i: number): number {
      if (ready[i]) return i;
      for (let d = 1; d < FRAMES; d++) {
        if (ready[i - d]) return i - d;
        if (ready[i + d]) return i + d;
      }
      return -1;
    }

    // continuous slow zoom: scale ramps with scroll progress so the scene
    // breathes across the whole film instead of cutting between chapters
    let zoom = 1;
    function draw(target: number) {
      const i = nearest(target);
      if (i < 0) return;
      current = target;
      const img = images[i];
      const cw = canvas.width, ch = canvas.height;
      const base = Math.max(cw / img.width, ch / img.height);
      const scale = base * zoom;
      const w = img.width * scale, h = img.height * scale;
      ctx.clearRect(0, 0, cw, ch);
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
      hudSeq.textContent = `SEQ ${String(target).padStart(3, '0')} / ${FRAMES}`;
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width  = canvas.offsetWidth * dpr;
      canvas.height = canvas.offsetHeight * dpr;
      draw(current);
    }
    window.addEventListener('resize', resize);
    resize();

    // ── smooth inertia scroll ───────────────────────────────────────
    const lenis = new Lenis({ lerp: 0.09 });
    // expose for the screenshot harness (and any deep-link tooling); harmless
    (window as any).__lenis = lenis;
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(t => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);

    const railEl = document.getElementById('rail')!;
    const railItems = Array.from(railEl.querySelectorAll('span'));

    if (!reduceMotion) {
      railEl.classList.add('on');
      const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
      const words = gsap.utils.toArray<HTMLElement>('.word');

      // ── ONE pinned scrub for the whole film ───────────────────────
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#stage',
          start: 'top top',
          end: '+=820%',
          pin: true,
          scrub: true,
          onUpdate: self => {
            const p = self.progress;
            // continuous slow zoom (1.0 → ~1.12) across the whole film,
            // independent of which beat is active — the "never a hard cut"
            zoom = 1 + p * 0.12;
            draw(Math.round(p * (FRAMES - 1)));
            const active =
              p < 0.095 ? 0 : p < 0.235 ? 1 : p < 0.375 ? 2 : p < 0.515 ? 3 :
              p < 0.665 ? 4 : p < 0.805 ? 5 : 6;
            railItems.forEach((el, i) => el.classList.toggle('active', i === active));
            railEl.classList.toggle('on', self.isActive);
          },
        },
      });

      // [chapter, fade-in at, fade-out at] for the SUPPORTING copy blocks.
      // Career copy (01–03) is tuned to fade in just as its word lands and
      // hold through the word's rest, so word + kicker + body share screen.
      const windows: [HTMLElement, number, number][] = [
        [chapters[0], 0.000, 0.070],   // intro
        [chapters[1], 0.150, 0.250],   // 01 energy   (word rests ~0.175–0.235)
        [chapters[2], 0.290, 0.390],   // 02 logistics(word rests ~0.315–0.375)
        [chapters[3], 0.430, 0.530],   // 03 scale    (word rests ~0.455–0.515)
        [chapters[4], 0.560, 0.710],   // 04 builds
        [chapters[5], 0.760, 0.860],   // 05 thinking
        [chapters[6], 0.900, 1.010],   // 06 talk (longest hold)
      ];
      for (const [el, a, b] of windows) {
        if (a > 0) tl.fromTo(el, { autoAlpha: 0, y: 50 }, { autoAlpha: 1, y: 0, duration: 0.04 }, a);
        if (b <= 1) tl.to(el, { autoAlpha: 0, y: -50, duration: 0.04 }, b - 0.04);
      }

      // ── WORD LAYER — the travelling giant words (career beats 01–03).
      //    Each word slides up THROUGH the centre as its chapter arrives.
      //    Adjacent windows overlap so the incoming word rises while the
      //    outgoing one is still lifting away — the signature coexistence.
      //    The mono mark arrives slightly BEFORE the word settles.
      // entry/exit travel spans ~0.07 of the timeline each, and the next
      // word's ENTRY starts BEFORE the previous word's EXIT finishes — that
      // overlap (~0.04 of timeline, hundreds of px of scroll) is the
      // signature coexistence: two giant words on screen at once.
      const ENTER = 0.07, HOLD = 0.06, EXIT = 0.07;
      const wordStarts = [0.105, 0.245, 0.385];   // ENERGY, LOGISTICS, SCALE
      words.forEach((el, idx) => {
        const a = wordStarts[idx];
        const mark = el.querySelector('.word-mark');
        // word rises up from below into centre…
        tl.fromTo(el,
          { autoAlpha: 0, yPercent: 70 },
          { autoAlpha: 1, yPercent: 0, duration: ENTER, ease: 'power2.out' }, a);
        // mark arrives offset, a hair before the word lands
        if (mark) {
          tl.fromTo(mark,
            { autoAlpha: 0, y: 28 },
            { autoAlpha: 1, y: 0, duration: ENTER * 0.6, ease: 'power2.out' }, a - 0.018);
        }
        // …holds, then lifts away — first to a dim GHOST high in the frame
        // (this is the coexistence: a faint outgoing word above the rising
        // incoming one, exactly the reference feel), then fully gone.
        const exitAt = a + ENTER + HOLD;
        tl.to(el,
          { opacity: 0.16, yPercent: -55, duration: EXIT * 0.6, ease: 'power1.in' },
          exitAt);
        tl.to(el,
          { autoAlpha: 0, yPercent: -85, duration: EXIT * 0.4, ease: 'power1.in' },
          exitAt + EXIT * 0.6);
      });

      // HUD links + intro CTAs jump to a point inside the film
      const st = tl.scrollTrigger!;
      document.querySelectorAll<HTMLAnchorElement>('a[data-jump]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const pj = Number(a.dataset.jump);
          lenis.scrollTo(st.start + (st.end - st.start) * pj, { duration: 1.6 });
        });
      });

      // mouse parallax: scene drifts with the cursor; words & copy drift
      // against it (depth). Words drift a touch more than body copy.
      const xc = gsap.quickTo(canvas, 'x', { duration: 0.6, ease: 'power2.out' });
      const yc = gsap.quickTo(canvas, 'y', { duration: 0.6, ease: 'power2.out' });
      window.addEventListener('mousemove', e => {
        const nx = (e.clientX / innerWidth - 0.5), ny = (e.clientY / innerHeight - 0.5);
        xc(nx * 14); yc(ny * 10);
        gsap.to('.par', { x: nx * -10, y: ny * -7, duration: 0.6, ease: 'power2.out', overwrite: 'auto' });
        gsap.to('.word-display', { x: nx * -18, duration: 0.7, ease: 'power2.out', overwrite: 'auto' });
      });

      // poster cards — independent mouse-parallax drift (depth in the row)
      gsap.utils.toArray<HTMLElement>('.poster').forEach((card, i) => {
        const depth = (i - 1) * 8;   // -8, 0, 8 across the three cards
        window.addEventListener('mousemove', e => {
          const nx = (e.clientX / innerWidth - 0.5);
          const ny = (e.clientY / innerHeight - 0.5);
          gsap.to(card, { x: nx * depth, y: ny * (depth * 0.5),
            duration: 0.8, ease: 'power2.out', overwrite: 'auto' });
        });
      });
    } else {
      // reduced motion: words fold into chapters via CSS; nothing to do
    }

    // ── intro entrance: kicker, then the manifesto TYPES line by line ──
    //    Typing never gates meaning — the real text is already in the DOM
    //    (data-text) and shown in full if anything fails. We only animate
    //    when motion is allowed; otherwise the lines are simply present.
    const lines = Array.from(document.querySelectorAll<HTMLElement>('.manifesto .ln'));

    if (reduceMotion) {
      gsap.set(['.intro-kicker', '.intro-ctas', '.hero-chip'], { opacity: 1, y: 0 });
    } else {
      // start the lines empty so the typewriter can fill them; the data-text
      // attribute keeps the full string available for the no-JS fallback
      const full = lines.map(el => el.getAttribute('data-text') || el.textContent || '');
      lines.forEach(el => { el.textContent = ''; });

      gsap.set(['.intro-kicker', '.intro-ctas', '.hero-chip'], { y: 14 });

      const heroTl = gsap.timeline({ delay: 0.2 });
      heroTl.to('.intro-kicker', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' });

      // type each line character-by-character, then drop a caret to the next
      lines.forEach((el, idx) => {
        const text = full[idx];
        const state = { n: 0 };
        // place a live caret at the end of the line being typed
        const caret = document.createElement('span');
        caret.className = 'caret';
        heroTl.add(() => { el.textContent = ''; el.appendChild(caret); });
        heroTl.to(state, {
          n: text.length,
          duration: Math.max(0.5, text.length * 0.028),
          ease: 'none',
          onUpdate: () => {
            const k = Math.round(state.n);
            el.textContent = text.slice(0, k);
            el.appendChild(caret);
          },
        });
        // remove the caret from finished lines except the last
        if (idx < lines.length - 1) {
          heroTl.add(() => { if (caret.parentNode) caret.remove(); });
        }
      });

      heroTl.to('.hero-chip', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.8');
      heroTl.to('.intro-ctas', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2');
    }

    // footer reveal — the only scrolled content after the film
    gsap.from('.footer-inner > *', {
      scrollTrigger: { trigger: 'footer', start: 'top 92%', once: true },
      opacity: 0, y: 14, stagger: 0.1, duration: 0.6, ease: 'power2.out',
    });
  </script>
</body>
</html>
