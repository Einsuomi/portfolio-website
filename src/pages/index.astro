  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPT — Lenis + GSAP + SplitType + Canvas
       Bundled by Vite — only runs in browser
  ═══════════════════════════════════════════════════════════════════ -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import SplitType from 'split-type';

    gsap.registerPlugin(ScrollTrigger);

    // ── Smooth inertia scroll ──────────────────────────────────────
    const lenis = new Lenis({ lerp: 0.09 });
    gsap.ticker.add((t) => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);
    // Connect Lenis scroll to ScrollTrigger updates
    lenis.on('scroll', ScrollTrigger.update);

    // ── Theme toggle ───────────────────────────────────────────────
    const root   = document.documentElement;
    const btn    = document.getElementById('theme-btn')!;
    const sunEl  = document.getElementById('icon-sun')!;
    const moonEl = document.getElementById('icon-moon')!;

    function applyTheme(t: string) {
      root.setAttribute('data-theme', t);
      sunEl.style.display  = t === 'dark' ? 'block' : 'none';
      moonEl.style.display = t === 'dark' ? 'none'  : 'block';
    }
    applyTheme(localStorage.getItem('theme') ??
      (window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark'));
    btn.addEventListener('click', () => {
      const next = root.getAttribute('data-theme') === 'dark' ? 'light' : 'dark';
      applyTheme(next);
      localStorage.setItem('theme', next);
    });

    // ── Canvas particle network ─────────────────────────────────────
    const canvas = document.getElementById('hero-canvas') as HTMLCanvasElement;
    const ctx    = canvas.getContext('2d')!;
    const hero   = document.getElementById('hero')!;

    function resizeCanvas() {
      canvas.width  = hero.offsetWidth;
      canvas.height = hero.offsetHeight;
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    const N = 65;
    type P = { x:number; y:number; vx:number; vy:number; r:number };
    let pts: P[] = [];
    const mouse = { x: -9999, y: -9999 };

    function spawnParticles() {
      pts = Array.from({ length: N }, () => ({
        x:  Math.random() * canvas.width,
        y:  Math.random() * canvas.height,
        vx: (Math.random() - 0.5) * 0.22,
        vy: (Math.random() - 0.5) * 0.22,
        r:  Math.random() * 1.4 + 0.5,
      }));
    }
    spawnParticles();
    window.addEventListener('resize', spawnParticles);

    canvas.addEventListener('mousemove', e => {
      const r = canvas.getBoundingClientRect();
      mouse.x = e.clientX - r.left;
      mouse.y = e.clientY - r.top;
    });
    canvas.addEventListener('mouseleave', () => { mouse.x = mouse.y = -9999; });

    function accentRgb() {
      return root.getAttribute('data-theme') === 'light' ? '155,114,40' : '201,163,90';
    }

    let rafId: number;
    function drawFrame() {
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      const rgb = accentRgb();

      for (let i = 0; i < pts.length; i++) {
        const p = pts[i];

        // Gentle mouse repulsion
        const dx = p.x - mouse.x, dy = p.y - mouse.y;
        const d2 = dx*dx + dy*dy;
        if (d2 < 10000) {           // within 100px
          const d = Math.sqrt(d2);
          p.x += dx / d * 1.1;
          p.y += dy / d * 1.1;
        }

        // Draw lines to nearby neighbours
        for (let j = i + 1; j < pts.length; j++) {
          const q   = pts[j];
          const ldx = p.x - q.x, ldy = p.y - q.y;
          const ld2 = ldx*ldx + ldy*ldy;
          if (ld2 < 14400) {        // within 120px
            const alpha = (1 - ld2 / 14400) * 0.18;
            ctx.beginPath();
            ctx.strokeStyle = `rgba(${rgb},${alpha})`;
            ctx.lineWidth = 0.6;
            ctx.moveTo(p.x, p.y);
            ctx.lineTo(q.x, q.y);
            ctx.stroke();
          }
        }

        // Draw dot
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.fillStyle = `rgba(${rgb},0.42)`;
        ctx.fill();

        // Move + wrap
        p.x += p.vx;
        p.y += p.vy;
        if (p.x < 0) p.x = canvas.width;
        if (p.x > canvas.width)  p.x = 0;
        if (p.y < 0) p.y = canvas.height;
        if (p.y > canvas.height) p.y = 0;
      }
      rafId = requestAnimationFrame(drawFrame);
    }

    // Kill canvas animation when hero scrolls out of view (saves CPU)
    const heroObs = new IntersectionObserver(([e]) => {
      if (e.isIntersecting) {
        if (!rafId) rafId = requestAnimationFrame(drawFrame);
      } else {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }
    }, { threshold: 0.01 });
    heroObs.observe(hero);

    if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      rafId = requestAnimationFrame(drawFrame);
    }

    // ── Hero: SplitType + GSAP timeline ────────────────────────────
    const split = new SplitType('.hero-name', { types: 'chars' });

    const heroTl = gsap.timeline({ delay: 0.25 });
    heroTl
      .to('.hero-rule',     { opacity: 1, scaleX: 1, duration: 0.7, ease: 'expo.out', transformOrigin: 'left' })
      .to('.hero-label',    { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      .fromTo(split.chars,
        { opacity: 0, y: 55 },
        { opacity: 1, y: 0, stagger: 0.028, duration: 0.7, ease: 'expo.out' },
        '-=0.15')
      .to('.hero-role',     { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .to('.hero-tagline',  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.35')
      .to('.hero-facts',    { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.3')
      .to('.ctas',          { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.25');

    // Set initial y offsets for hero elements
    gsap.set(['.hero-label', '.hero-role', '.hero-tagline', '.hero-facts', '.ctas'],
      { y: 12 });
    gsap.set('.hero-name-wrap', { opacity: 1 }); // wrapper visible; chars start at y:55

    // ── ScrollTrigger: section headings ────────────────────────────
    gsap.utils.toArray<HTMLElement>('.eyebrow, .section-heading, .section-sub').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        opacity: 0, y: 22, duration: 0.7, ease: 'power2.out',
      });
    });

    // Tech grid: stagger in
    gsap.from('.tech-item', {
      scrollTrigger: { trigger: '#stack .tech-grid', start: 'top 82%', once: true },
      opacity: 0, y: 16,
      stagger: { amount: 0.55, from: 'start' },
      duration: 0.5, ease: 'power2.out',
    });

    // Group labels
    gsap.utils.toArray<HTMLElement>('.group-label').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
        opacity: 0, duration: 0.5, ease: 'power2.out',
      });
    });

    // Project items: slide from left, stagger by position
    gsap.utils.toArray<HTMLElement>('.project-item').forEach((item, i) => {
      gsap.from(item, {
        scrollTrigger: { trigger: item, start: 'top 88%', once: true },
        opacity: 0, x: -28, duration: 0.75, delay: (i % 2) * 0.08, ease: 'power3.out',
      });
    });

    // Case study rows
    gsap.utils.toArray<HTMLElement>('.study-item').forEach((item, i) => {
      gsap.from(item, {
        scrollTrigger: { trigger: item, start: 'top 88%', once: true },
        opacity: 0, y: 14, duration: 0.6, delay: i * 0.1, ease: 'power2.out',
      });
    });

    // Chat panel
    gsap.from('.chat-panel', {
      scrollTrigger: { trigger: '.chat-panel', start: 'top 82%', once: true },
      opacity: 0, y: 28, duration: 0.8, ease: 'power3.out',
    });

    // Footer
    gsap.from('.footer-inner > *', {
      scrollTrigger: { trigger: 'footer', start: 'top 92%', once: true },
      opacity: 0, y: 14, stagger: 0.1, duration: 0.6, ease: 'power2.out',
    });
  </script>

