  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPT — Lenis + GSAP + SplitType + Canvas
       Bundled by Vite — only runs in browser
  ═══════════════════════════════════════════════════════════════════ -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import SplitType from 'split-type';

    gsap.registerPlugin(ScrollTrigger);

    // ── Smooth inertia scroll ──────────────────────────────────────
    const lenis = new Lenis({ lerp: 0.09 });
    gsap.ticker.add((t) => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);
    // Connect Lenis scroll to ScrollTrigger updates
    lenis.on('scroll', ScrollTrigger.update);

    // ── Hero: scroll-scrubbed image sequence ───────────────────────
    // 120 pre-rendered frames in /public/seq — scroll position picks
    // the frame, so the camera flight is fully reversible.
    const FRAMES = 120;
    const canvas = document.getElementById('seq-canvas') as HTMLCanvasElement;
    const ctx    = canvas.getContext('2d')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    const seqImages: HTMLImageElement[] = [];
    const seqLoaded: boolean[] = [];
    let currentFrame = 0;

    function loadFrame(i: number) {
      const img = new Image();
      img.onload = () => {
        seqLoaded[i] = true;
        if (i === currentFrame) drawSeq(i);   // first paint as soon as frame 0 lands
      };
      img.src = `/seq/frame_${String(i).padStart(3, '0')}.jpg`;
      seqImages[i] = img;
    }
    // frame 0 first for instant paint, rest stream in behind it
    loadFrame(0);
    for (let i = 1; i < FRAMES; i++) loadFrame(i);

    // If the exact frame isn't decoded yet, draw the nearest one that is
    function nearestLoaded(i: number): number {
      if (seqLoaded[i]) return i;
      for (let d = 1; d < FRAMES; d++) {
        if (seqLoaded[i - d]) return i - d;
        if (seqLoaded[i + d]) return i + d;
      }
      return -1;
    }

    // Cover-crop draw so any viewport ratio (incl. portrait) stays framed
    function drawSeq(target: number) {
      const i = nearestLoaded(target);
      if (i < 0) return;
      currentFrame = target;
      const img = seqImages[i];
      const cw = canvas.width, ch = canvas.height;
      const scale = Math.max(cw / img.width, ch / img.height);
      const w = img.width * scale, h = img.height * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
    }

    function resizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width  = canvas.offsetWidth * dpr;
      canvas.height = canvas.offsetHeight * dpr;
      drawSeq(currentFrame);
    }
    window.addEventListener('resize', resizeCanvas);
    resizeCanvas();

    // Pin the hero for 3 viewport-heights and scrub frames + chapters.
    // Reduced motion: no pin, static intro over frame 0.
    if (!reduceMotion) {
      const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
      const seqTl = gsap.timeline({
        scrollTrigger: {
          trigger: '#hero',
          start: 'top top',
          end: '+=300%',
          pin: true,
          scrub: true,
          onUpdate: self => drawSeq(Math.round(self.progress * (FRAMES - 1))),
        },
      });

      // [chapter, fade-in at, fade-out at] as fractions of the pin
      const windows: [HTMLElement, number, number][] = [
        [chapters[0], 0.00, 0.12],
        [chapters[1], 0.16, 0.40],
        [chapters[2], 0.48, 0.70],
        [chapters[3], 0.78, 1.01],   // gold chapter holds to the end
      ];
      // autoAlpha = opacity + visibility, so hidden chapters can't catch clicks
      for (const [el, a, b] of windows) {
        if (a > 0) seqTl.fromTo(el, { autoAlpha: 0, y: 40 }, { autoAlpha: 1, y: 0, duration: 0.06 }, a);
        if (b <= 1) seqTl.to(el, { autoAlpha: 0, y: -40, duration: 0.06 }, b - 0.06);
      }
    }

    // ── Hero: SplitType + GSAP timeline ────────────────────────────
    const split = new SplitType('.hero-name', { types: 'chars' });

    const heroTl = gsap.timeline({ delay: 0.25 });
    heroTl
      .to('.hero-rule',     { opacity: 1, scaleX: 1, duration: 0.7, ease: 'expo.out', transformOrigin: 'left' })
      .to('.hero-label',    { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.3')
      .fromTo(split.chars,
        { opacity: 0, y: 55 },
        { opacity: 1, y: 0, stagger: 0.028, duration: 0.7, ease: 'expo.out' },
        '-=0.15')
      .to('.hero-role',     { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.4')
      .to('.hero-tagline',  { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.35')
      .to('.hero-facts',    { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.3')
      .to('.ctas',          { opacity: 1, y: 0, duration: 0.45, ease: 'power2.out' }, '-=0.25');

    // Set initial y offsets for hero elements
    gsap.set(['.hero-label', '.hero-role', '.hero-tagline', '.hero-facts', '.ctas'],
      { y: 12 });
    // wrapper AND h1 visible — the reveal is carried by the chars alone
    gsap.set(['.hero-name-wrap', '.hero-name'], { opacity: 1 });

    // ── ScrollTrigger: section headings ────────────────────────────
    gsap.utils.toArray<HTMLElement>('.eyebrow, .section-heading, .section-sub').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 88%', once: true },
        opacity: 0, y: 22, duration: 0.7, ease: 'power2.out',
      });
    });

    // Tech grid: stagger in
    gsap.from('.tech-item', {
      scrollTrigger: { trigger: '#stack .tech-grid', start: 'top 82%', once: true },
      opacity: 0, y: 16,
      stagger: { amount: 0.55, from: 'start' },
      duration: 0.5, ease: 'power2.out',
    });

    // Group labels
    gsap.utils.toArray<HTMLElement>('.group-label').forEach(el => {
      gsap.from(el, {
        scrollTrigger: { trigger: el, start: 'top 90%', once: true },
        opacity: 0, duration: 0.5, ease: 'power2.out',
      });
    });

    // Project items: slide from left, stagger by position
    gsap.utils.toArray<HTMLElement>('.project-item').forEach((item, i) => {
      gsap.from(item, {
        scrollTrigger: { trigger: item, start: 'top 88%', once: true },
        opacity: 0, x: -28, duration: 0.75, delay: (i % 2) * 0.08, ease: 'power3.out',
      });
    });

    // Case study rows
    gsap.utils.toArray<HTMLElement>('.study-item').forEach((item, i) => {
      gsap.from(item, {
        scrollTrigger: { trigger: item, start: 'top 88%', once: true },
        opacity: 0, y: 14, duration: 0.6, delay: i * 0.1, ease: 'power2.out',
      });
    });

    // Chat panel
    gsap.from('.chat-panel', {
      scrollTrigger: { trigger: '.chat-panel', start: 'top 82%', once: true },
      opacity: 0, y: 28, duration: 0.8, ease: 'power3.out',
    });

    // Footer
    gsap.from('.footer-inner > *', {
      scrollTrigger: { trigger: 'footer', start: 'top 92%', once: true },
      opacity: 0, y: 14, stagger: 0.1, duration: 0.6, ease: 'power2.out',
    });
  </script>

