---
/**
 * Dark version — default route (/).
 *
 * This page is a thin shell: it renders all 7 beats as real, semantic HTML
 * inside <main> so crawlers, ATS systems, and no-JS visitors get full content.
 * The designer's Three.js particle scene will attach to the canvas mount point
 * below and animate over this HTML — the HTML is the fallback, not a duplicate.
 *
 * Design tokens: near-black #060606, cream #ECE8DE, blue #3B6CF6 / amber #E8762B.
 * Fonts: Anton (display), Archivo 800/900 (labels), Inter (body).
 */
import Base from '../layouts/Base.astro';
import { TIMELINE, CONTACT } from '../lib/timeline.ts';
---

<Base version="dark">
  <!--
    SCENE MOUNT: dark
    The particle cloud canvas goes here — positioned fixed/absolute by the
    scene script so it sits behind this HTML without affecting document flow.
  -->
  <canvas id="scene" aria-hidden="true" style="display:none"></canvas>

  <style>
    /*
     * Dark version tokens — v3 (usta.agency) feel.
     * These are the design-canonical values; designers will extend them.
     */
    :root {
      --bg:       #060606;
      --surface:  #0c0c0d;
      --text:     #ece8de;
      --text-2:   #86857f;
      --accent:   #3b6cf6;
      --amber:    #e8762b;
      --border:   rgba(236,232,222,0.14);

      --font-display: 'Anton', 'Arial Narrow', sans-serif;
      --font-label:   'Archivo', sans-serif;
      --font-body:    'Inter', sans-serif;
      --font-mono:    'JetBrains Mono', ui-monospace, monospace;

      --px: clamp(1.5rem, 5.5vw, 5rem);
    }

    html[data-version="dark"] body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      line-height: 1.65;
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* ── No-JS / reduced-motion fallback: plain stacked sections ──── */
    main { padding: 0; }

    .beat {
      padding: clamp(3rem, 8vw, 6rem) var(--px);
      border-bottom: 1px solid var(--border);
    }

    .beat-eyebrow {
      font-family: var(--font-label);
      font-size: 0.72rem;
      font-weight: 700;
      letter-spacing: 0.35em;
      text-transform: uppercase;
      color: var(--amber);
      margin-bottom: 0.9rem;
    }

    .beat-title {
      font-family: var(--font-display);
      font-size: clamp(3rem, 10vw, 8rem);
      font-weight: 400;
      line-height: 0.9;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--text);
      margin-bottom: 1.2rem;
    }

    /* Hero title is larger */
    #beat-hero .beat-title {
      font-size: clamp(4rem, 14vw, 12rem);
    }

    .beat-body {
      font-size: clamp(0.95rem, 1.4vw, 1.15rem);
      line-height: 1.7;
      color: var(--text);
      max-width: 52ch;
    }

    .beat-body strong {
      color: var(--text);
      font-weight: 600;
    }

    /* Stack tags inline */
    .beat-tags {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.2rem;
      list-style: none;
    }

    .beat-tags li {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      color: var(--text-2);
      border: 1px solid var(--border);
      padding: 0.2rem 0.55rem;
    }

    /* Project and essay links */
    .beat-links {
      list-style: none;
      margin-top: 1.2rem;
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
    }

    .beat-links a {
      color: var(--accent);
      text-decoration: none;
      font-family: var(--font-mono);
      font-size: 0.82rem;
      letter-spacing: 0.06em;
      border-bottom: 1px solid transparent;
      transition: border-color 0.2s;
    }

    .beat-links a:hover {
      border-color: var(--accent);
    }

    /* Disabled bot input */
    .bot-input {
      display: flex;
      align-items: center;
      gap: 1rem;
      margin-top: 1.6rem;
      padding: 1rem 1.4rem;
      border: 1px solid var(--border);
      background: var(--surface);
      max-width: 36rem;
    }

    .bot-input input {
      flex: 1;
      background: transparent;
      border: none;
      outline: none;
      color: var(--text-2);
      font-family: var(--font-mono);
      font-size: 0.85rem;
      cursor: not-allowed;
    }

    .bot-input input::placeholder { color: var(--text-2); opacity: 0.6; }

    .bot-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      letter-spacing: 0.18em;
      text-transform: uppercase;
      color: var(--amber);
      white-space: nowrap;
    }

    /* Footer */
    footer {
      border-top: 1px solid var(--border);
      padding: 2.5rem var(--px);
      font-family: var(--font-mono);
      font-size: 0.65rem;
      color: var(--text-2);
      letter-spacing: 0.06em;
    }

    .footer-inner {
      display: flex;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 1rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .footer-links { display: flex; gap: 1.5rem; list-style: none; }
    .footer-links a { color: var(--text-2); text-decoration: none; }
    .footer-links a:hover { color: var(--text); }
  </style>

  <main id="main">

    <!-- 00 · Hero -->
    <section class="beat" id="beat-hero">
      <p class="beat-eyebrow">{TIMELINE[0].eyebrow}</p>
      <h1 class="beat-title">{TIMELINE[0].title}</h1>
      <p class="beat-body" set:html={TIMELINE[0].body}></p>
    </section>

    <!-- 01 · Neste -->
    <section class="beat" id="beat-neste">
      <p class="beat-eyebrow">{TIMELINE[1].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[1].title}</h2>
      <p class="beat-body" set:html={TIMELINE[1].body}></p>
      {TIMELINE[1].tags && (
        <ul class="beat-tags">
          {TIMELINE[1].tags.map(t => <li>{t}</li>)}
        </ul>
      )}
    </section>

    <!-- 02 · PostNord -->
    <section class="beat" id="beat-postnord">
      <p class="beat-eyebrow">{TIMELINE[2].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[2].title}</h2>
      <p class="beat-body" set:html={TIMELINE[2].body}></p>
      {TIMELINE[2].tags && (
        <ul class="beat-tags">
          {TIMELINE[2].tags.map(t => <li>{t}</li>)}
        </ul>
      )}
    </section>

    <!-- 03 · Basware -->
    <section class="beat" id="beat-basware">
      <p class="beat-eyebrow">{TIMELINE[3].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[3].title}</h2>
      <p class="beat-body" set:html={TIMELINE[3].body}></p>
      {TIMELINE[3].tags && (
        <ul class="beat-tags">
          {TIMELINE[3].tags.map(t => <li>{t}</li>)}
        </ul>
      )}
    </section>

    <!-- 04 · Projects -->
    <section class="beat" id="beat-projects">
      <p class="beat-eyebrow">{TIMELINE[4].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[4].title}</h2>
      <p class="beat-body" set:html={TIMELINE[4].body}></p>
      {TIMELINE[4].links && (
        <ul class="beat-links">
          {TIMELINE[4].links.map(l => (
            <li><a href={l.url} target="_blank" rel="noopener">{l.label}</a></li>
          ))}
        </ul>
      )}
    </section>

    <!-- 05 · Writes -->
    <section class="beat" id="beat-writes">
      <p class="beat-eyebrow">{TIMELINE[5].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[5].title}</h2>
      <p class="beat-body" set:html={TIMELINE[5].body}></p>
      {TIMELINE[5].links && (
        <ul class="beat-links">
          {TIMELINE[5].links.map(l => (
            <li><a href={l.url}>{l.label}</a></li>
          ))}
        </ul>
      )}
    </section>

    <!-- 06 · Bot (disabled shell — Phase 4) -->
    <section class="beat" id="beat-bot">
      <p class="beat-eyebrow">{TIMELINE[6].eyebrow}</p>
      <h2 class="beat-title">{TIMELINE[6].title}</h2>
      <p class="beat-body" set:html={TIMELINE[6].body}></p>
      <div class="bot-input">
        <input
          type="text"
          placeholder="Ask about my pipelines, my stack, my decisions…"
          disabled
          aria-label="Chat input — coming soon"
          aria-disabled="true"
        />
        <span class="bot-label">Soon</span>
      </div>
    </section>

  </main>

  <footer>
    <div class="footer-inner">
      <span>Tong Nie — Data Engineer & Builder</span>
      <ul class="footer-links">
        <li><a href={`mailto:${CONTACT.email}`}>Email</a></li>
        <li><a href={CONTACT.linkedin} target="_blank" rel="noopener">LinkedIn</a></li>
        <li><a href={CONTACT.github} target="_blank" rel="noopener">GitHub</a></li>
      </ul>
    </div>
  </footer>

</Base>
