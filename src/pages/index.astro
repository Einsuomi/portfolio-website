  <!-- ═══════════════════════════════════════════════════════════════
       SCRIPT — Lenis + GSAP + SplitType + frame canvas
  ═══════════════════════════════════════════════════════════════════ -->
  <script>
    import Lenis from 'lenis';
    import { gsap } from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import SplitType from 'split-type';

    gsap.registerPlugin(ScrollTrigger);

    const FRAMES = 120;
    const canvas = document.getElementById('seq') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const hudSeq = document.getElementById('hud-seq')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── frame loading: frame 0 first for instant paint, rest stream in
    const images: HTMLImageElement[] = [];
    const ready: boolean[] = [];
    let current = 0;

    function loadFrame(i: number) {
      const img = new Image();
      img.onload = () => { ready[i] = true; if (i === current) draw(i); };
      img.src = `/seq2/frame_${String(i).padStart(3, '0')}.jpg`;
      images[i] = img;
    }
    loadFrame(0);
    for (let i = 1; i < FRAMES; i++) loadFrame(i);

    // if the exact frame isn't decoded yet, draw the nearest one that is
    function nearest(i: number): number {
      if (ready[i]) return i;
      for (let d = 1; d < FRAMES; d++) {
        if (ready[i - d]) return i - d;
        if (ready[i + d]) return i + d;
      }
      return -1;
    }

    // cover-crop draw so any viewport ratio (incl. portrait) stays framed
    function draw(target: number) {
      const i = nearest(target);
      if (i < 0) return;
      current = target;
      const img = images[i];
      const cw = canvas.width, ch = canvas.height;
      const scale = Math.max(cw / img.width, ch / img.height);
      const w = img.width * scale, h = img.height * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
      hudSeq.textContent = `SEQ ${String(target).padStart(3, '0')} / ${FRAMES}`;
    }

    function resize() {
      // capped pixel ratio — retina sharpness without melting GPUs
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width  = canvas.offsetWidth * dpr;
      canvas.height = canvas.offsetHeight * dpr;
      draw(current);
    }
    window.addEventListener('resize', resize);
    resize();

    // ── smooth inertia scroll ───────────────────────────────────────
    const lenis = new Lenis({ lerp: 0.09 });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(t => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);

    // ── ONE pinned scrub for the whole film: 7 beats over 700% ──────
    const railEl = document.getElementById('rail')!;
    const railItems = Array.from(railEl.querySelectorAll('span'));

    if (!reduceMotion) {
      railEl.classList.add('on');
      const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#stage',
          start: 'top top',
          end: '+=760%',   // extra runway so the finale holds longer
          pin: true,
          scrub: true,
          onUpdate: self => {
            draw(Math.round(self.progress * (FRAMES - 1)));
            // highlight the rail item for the active chapter window
            const p = self.progress;
            const active =
              p < 0.095 ? 0 : p < 0.23 ? 1 : p < 0.365 ? 2 : p < 0.50 ? 3 :
              p < 0.655 ? 4 : p < 0.795 ? 5 : 6;
            railItems.forEach((el, i) => el.classList.toggle('active', i === active));
            railEl.classList.toggle('on', self.isActive);
          },
        },
      });

      // [chapter, fade-in at, fade-out at] as fractions of the pin;
      // TALK holds to the end — the film closes on the call-to-action
      const windows: [HTMLElement, number, number][] = [
        [chapters[0], 0.000, 0.075],
        [chapters[1], 0.115, 0.210],
        [chapters[2], 0.250, 0.345],
        [chapters[3], 0.385, 0.480],
        [chapters[4], 0.520, 0.640],
        [chapters[5], 0.675, 0.775],
        [chapters[6], 0.815, 1.010],   // the finale gets the longest hold
      ];
      // autoAlpha = opacity + visibility, so hidden chapters can't catch clicks
      for (const [el, a, b] of windows) {
        if (a > 0) tl.fromTo(el, { autoAlpha: 0, y: 50 }, { autoAlpha: 1, y: 0, duration: 0.045 }, a);
        if (b <= 1) tl.to(el, { autoAlpha: 0, y: -50, duration: 0.045 }, b - 0.045);
      }

      // HUD links + intro CTAs jump to a point inside the film
      const st = tl.scrollTrigger!;
      document.querySelectorAll<HTMLAnchorElement>('a[data-jump]').forEach(a => {
        a.addEventListener('click', e => {
          e.preventDefault();
          const p = Number(a.dataset.jump);
          lenis.scrollTo(st.start + (st.end - st.start) * p, { duration: 1.6 });
        });
      });

      // mouse parallax: scene drifts with the cursor, text drifts against it
      const xc = gsap.quickTo(canvas, 'x', { duration: 0.6, ease: 'power2.out' });
      const yc = gsap.quickTo(canvas, 'y', { duration: 0.6, ease: 'power2.out' });
      window.addEventListener('mousemove', e => {
        const nx = (e.clientX / innerWidth - 0.5), ny = (e.clientY / innerHeight - 0.5);
        xc(nx * 14); yc(ny * 10);
        gsap.to('.par', { x: nx * -10, y: ny * -7, duration: 0.6, ease: 'power2.out', overwrite: 'auto' });
      });
    }

    // ── intro entrance: name chars, then the manifesto line by line ──
    const split = new SplitType('.intro-name', { types: 'chars' });
    gsap.set(['.intro-name-wrap', '.intro-name'], { opacity: 1 });

    const heroTl = gsap.timeline({ delay: 0.25 });
    heroTl
      .to('.intro-kicker', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' })
      .fromTo(split.chars,
        { opacity: 0, y: 70 },
        { opacity: 1, y: 0, stagger: 0.03, duration: 0.7, ease: 'expo.out' },
        '-=0.2')
      .to('.manifesto', { opacity: 1, duration: 0.01 }, '-=0.3')
      .from('.manifesto span', { opacity: 0, y: 18, stagger: 0.22, duration: 0.6, ease: 'power2.out' }, '<')
      .to('.intro-ctas', { opacity: 1, y: 0, duration: 0.5, ease: 'power2.out' }, '-=0.2');
    gsap.set(['.intro-kicker', '.intro-ctas'], { y: 14 });

    // footer reveal — the only scrolled content after the film
    gsap.from('.footer-inner > *', {
      scrollTrigger: { trigger: 'footer', start: 'top 92%', once: true },
      opacity: 0, y: 14, stagger: 0.1, duration: 0.6, ease: 'power2.out',
    });
  </script>
