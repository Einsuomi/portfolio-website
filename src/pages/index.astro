---
/**
 * Home (/) — cinematic video hero.
 * Full-bleed background video (Pair B / graded by default) with the matching
 * still as poster + reduced-motion / autoplay-fail fallback. Warm off-white
 * type + a single gold accent sampled from the doorway glow, over a gradient
 * scrim that guarantees legibility on any frame. No top nav bar — just a
 * top-right menu icon placeholder (panel + animation come in a later change).
 */
import Base from '../layouts/Base.astro';
import '../styles/backbone.css';
import Experience from '../components/Experience.astro';
import Projects from '../components/Projects.astro';
import Writes from '../components/Writes.astro';
import Chatbot from '../components/Chatbot.astro';
import HeroBar from '../components/HeroBar.astro';
import ChatLauncher from '../components/ChatLauncher.astro';
import ChatPanel from '../components/ChatPanel.astro';
import Preloader from '../components/Preloader.astro';

// Single swap point: flip 'B' -> 'A' to A/B the two grades in the real layout.
// B = graded (moody, default), A = natural dusk.
const HERO_PAIR: 'A' | 'B' = 'B';
const PAIRS = {
  A: { video: '/hero/final_10s.mp4',    still: '/hero/7330final.png'    },
  // B uses the crossfade-looped graded clip (seam dissolved, breathing kept)
  // with a compressed still exported from the loop's first frame.
  B: { video: '/hero/graded_loop.mp4',  still: '/hero/graded-loop.jpg'  },
};
const { video, still } = PAIRS[HERO_PAIR];
---

<Base version="dark">
  <!-- Refresh intro: percentage curtain that lifts to reveal the hero. -->
  <Preloader />

  <main>
    <section class="hero">
      <!-- Background layer: poster (still) shows first and stays whenever the
           video doesn't play (reduced-motion, autoplay blocked, or no JS). -->
      <div class="hero__media" aria-hidden="true">
        <video
          poster={still}
          muted
          loop
          playsinline
          preload="none"
          disablepictureinpicture
        >
          <source src={video} type="video/mp4" />
        </video>
      </div>

      <!-- Scrim: bottom-anchored gradient keeps text ≥4.5:1 on any frame. -->
      <div class="hero__scrim" aria-hidden="true"></div>

      <!-- Top-right menu: the hamburger toggles a dropdown of every section.
           Opens on hover (desktop) or click/tap (everywhere); bars cross to an X. -->
      <nav class="nav" aria-label="Sections" data-open="false">
        <button
          class="menu"
          type="button"
          aria-label="Menu"
          aria-expanded="false"
          aria-controls="nav-menu"
        >
          <span></span><span></span>
        </button>
        <div class="nav__panel" id="nav-menu" role="menu" aria-hidden="true">
          <a class="nav__link" href="#experience" role="menuitem"><span class="nav__idx">01</span> Experience</a>
          <a class="nav__link" href="#projects"   role="menuitem"><span class="nav__idx">02</span> Projects</a>
          <a class="nav__link" href="#writes"     role="menuitem"><span class="nav__idx">03</span> Writes</a>
          <a class="nav__link" href="#chatbot"    role="menuitem"><span class="nav__idx">04</span> Ask</a>
        </div>
      </nav>

      <!-- Hero copy lives in real HTML so it's present without/before JS. -->
      <!-- Eyebrow is pinned top-left (its own element); the name + value block
           rides centered, lifted to sit around the top of the doorway. -->
      <p class="hero__eyebrow" data-anim>
        <span class="hero__rule" aria-hidden="true"></span>
        Building in public, Europe
      </p>
      <div class="hero__inner">
        <h1 class="hero__name" data-anim>Tong Nie</h1>
        <p class="hero__line" data-anim>
          By day, I orchestrate data.<br />
          By night, I ship ideas.<br />
          Same machine, different rules.
        </p>
      </div>
    </section>

    <!-- Boundary marquee: the seam between the video hero and the still body. -->
    <HeroBar />

    <!-- Body rides the same hero still as a continuous backdrop; sections stack
         and slide over the fixed scene. -->
    <div class="backbone">
      <Experience />
      <Projects />
      <Writes />
      <Chatbot />
    </div>
  </main>

  <!-- Persistent chatbot launcher + the floating chat panel it opens. -->
  <ChatLauncher />
  <ChatPanel />

  <style>
    /* ── Hero design tokens (scoped to this page) ───────────────── */
    .hero {
      --hero-ink:   var(--ink);  /* folded into the global ramp (same warm off-white) */
      --hero-gold:  var(--gold); /* folded into the global accent */
      --hero-scrim: #0c0a09; /* warm near-black, used only in the gradient */

      position: relative;
      width: 100%;
      min-height: 100svh;
      overflow: hidden;
      display: flex;
      align-items: center; /* name/value block rides the vertical middle, lifted up */
    }

    /* ── Background video / still ───────────────────────────────── */
    .hero__media { position: absolute; inset: 0; z-index: 0; }
    .hero__media video {
      width: 100%; height: 100%;
      object-fit: cover; object-position: center;
      display: block;
    }

    /* ── Legibility scrim ───────────────────────────────────────── */
    .hero__scrim {
      position: absolute; inset: 0; z-index: 1; pointer-events: none;
      /* Faint top wash + heavier bottom anchor where the copy sits. */
      background:
        linear-gradient(to top, rgba(12,10,9,0.78) 0%, rgba(12,10,9,0.35) 32%, rgba(12,10,9,0) 60%),
        linear-gradient(to bottom, rgba(12,10,9,0.28) 0%, rgba(12,10,9,0) 22%);
    }

    /* ── Top-right menu (toggle + dropdown, no top bar) ─────────── */
    .nav {
      position: fixed; z-index: 10;
      top: clamp(1.1rem, 2.5vw, 1.8rem);
      right: clamp(1.1rem, 4vw, 2.5rem);
    }
    .menu {
      position: relative; z-index: 1;
      margin-left: auto;
      width: 46px; height: 46px;
      display: flex; flex-direction: column; align-items: flex-end;
      justify-content: center; gap: 6px;
      background: none; border: none; cursor: pointer;
      padding: 8px;
    }
    .menu span {
      display: block; height: 2px; background: var(--hero-ink);
      transition: width 0.25s ease, background 0.25s ease,
                  transform 0.3s ease;
    }
    .menu span:nth-child(1) { width: 26px; }
    .menu span:nth-child(2) { width: 18px; }
    .menu:hover span,
    .menu:focus-visible span { background: var(--hero-gold); width: 26px; }
    /* Open: both bars go full-width gold and cross into an X. */
    .menu[aria-expanded='true'] span { background: var(--hero-gold); width: 26px; }
    .menu[aria-expanded='true'] span:nth-child(1) { transform: translateY(4px)  rotate(45deg); }
    .menu[aria-expanded='true'] span:nth-child(2) { transform: translateY(-4px) rotate(-45deg); }

    /* Borderless dropdown: no card, no frame — just the section names floating
       in a right-aligned column under the icon (legible via text-shadow). */
    .nav__panel {
      position: absolute; top: calc(100% + 14px); right: 0;
      display: flex; flex-direction: column; align-items: flex-end;
      gap: 0.1rem;
      /* Closed state — the JS toggles [data-open] on .nav to reveal it. */
      opacity: 0; transform: translateY(-6px); pointer-events: none;
      transition: opacity 0.22s ease,
                  transform 0.28s cubic-bezier(0.2, 0.7, 0.2, 1);
    }
    /* Invisible bridge across the gap so hover doesn't drop between the icon
       and the links (keeps the pointer "inside" .nav). */
    .nav__panel::before {
      content: ''; position: absolute; right: 0; top: -16px; width: 100%; height: 16px;
    }
    .nav[data-open='true'] .nav__panel {
      opacity: 1; transform: translateY(0); pointer-events: auto;
    }

    .nav__link {
      display: flex; align-items: baseline; justify-content: flex-end; gap: 0.55rem;
      padding: 0.28rem 0;
      font-family: var(--font-body); font-size: 1.05rem; font-weight: 500;
      color: var(--hero-ink); text-decoration: none;
      text-shadow: 0 1px 14px rgba(0, 0, 0, 0.7);
      transition: color 0.2s ease, transform 0.2s ease;
    }
    .nav__link:hover,
    .nav__link:focus-visible { color: var(--hero-gold); transform: translateX(-4px); }
    .nav__idx {
      font-family: var(--font-mono); font-size: 0.72rem;
      letter-spacing: 0.05em; color: var(--hero-gold); opacity: 0.85;
    }

    /* No-JS fallback only: with the toggle script absent, reveal the panel on
       hover/focus so the sections stay reachable. Gated to html:not(.js) so it
       never fights the JS click-to-close on desktop (where both would apply). */
    html:not(.js) .nav:hover .nav__panel,
    html:not(.js) .nav:focus-within .nav__panel {
      opacity: 1; transform: translateY(0) scale(1); pointer-events: auto;
    }

    /* ── Copy block ─────────────────────────────────────────────── */
    .hero__inner {
      position: relative; z-index: 2;
      padding: 0 clamp(1.5rem, 5.5vw, 5rem);
      max-width: 60rem;
      /* Nudge the block down + right a touch so the name sits lower in the left
         negative-space (clear of the eyebrow) rather than floating high. */
      transform: translate(2.5vw, -3vh);
    }

    /* Eyebrow pinned to the top-left (back where it reads as a standing label). */
    .hero__eyebrow {
      position: absolute; z-index: 2;
      top: clamp(4.5rem, 9vh, 7rem);
      left: clamp(1.5rem, 5.5vw, 5rem);
      display: flex; align-items: center; gap: 0.75rem;
      font-family: var(--font-mono);
      font-size: var(--t-label);
      font-weight: 500; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--hero-gold);
    }
    .hero__rule {
      display: block; width: clamp(28px, 6vw, 52px); height: 1px;
      background: var(--hero-gold); flex: none;
    }

    /* Bricolage wordmark — the identity voice. Weight floored at ~430 so the light
       display strokes stay legible over the moving footage (no faux italic; the
       family ships none). */
    .hero__name {
      font-family: var(--font-display); font-weight: 540;
      /* Sized to stay one line in the left region, clear of the central doorway.
         A touch larger than the --t-xl ramp to strengthen the focal point. */
      font-size: clamp(3.4rem, 2.2rem + 5.8vw, 6rem);
      line-height: var(--lh-tight); letter-spacing: 0.01em; text-transform: uppercase;
      white-space: nowrap;
      color: var(--hero-ink);
      text-shadow: 0 2px 40px rgba(0,0,0,0.35); /* extra safety over bright frames */
    }
    /* Mobile reflow: let TONG / NIE stack rather than push the page sideways. */
    @media (max-width: 30rem) {
      .hero__name { white-space: normal; }
    }

    .hero__line {
      font-family: var(--font-body);
      font-weight: 400;
      /* Bumped a step above --t-sm to match the larger wordmark. */
      font-size: clamp(1.45rem, 1.25rem + 1.15vw, 1.8rem);
      line-height: 1.3; max-width: 32ch;
      color: var(--hero-ink);
      margin-top: var(--space-sm);
    }

    /* ── Entrance animation ─────────────────────────────────────────
       Only hide elements up-front when JS is present AND motion is allowed,
       so reduced-motion and no-JS visitors always see the copy immediately. */
    @media (prefers-reduced-motion: no-preference) {
      html.js .hero [data-anim] { opacity: 0; transform: translateY(14px); }
    }
  </style>

  <script>
    import gsap from 'gsap';
    import SplitType from 'split-type';

    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    // Track refresh vs. in-site navigation: the cinematic entrance only plays on
    // a true page load. With View Transitions this module runs once but fires on
    // every astro:page-load, so the flag (held in the closure) tells them apart.
    let firstLoad = true;

    // Cinematic entrance: the name wipes in left→right while sliding from the
    // left (the big beat), the eyebrow slides in, and the tagline rises line by
    // line. Skipped under reduced-motion, where the CSS never hid the copy.
    function playHeroIntro() {
      // Split the tagline into lines so they can stagger up independently.
      const split = new SplitType('.hero__line', { types: 'lines' });
      const lines = split.lines && split.lines.length ? split.lines : ['.hero__line'];

      // Explicit start states (override the CSS hide) so .to() never lands on 0.
      gsap.set('.hero__eyebrow', { x: -32, opacity: 0, y: 0 });
      gsap.set('.hero__name', { opacity: 1, x: -60, y: 0, clipPath: 'inset(0 100% 0 0)' });
      gsap.set('.hero__line', { opacity: 1, y: 0 });
      gsap.set(lines, { yPercent: 90, opacity: 0 });

      const tl = gsap.timeline({ defaults: { ease: 'power3.out' } });
      tl.to('.hero__eyebrow', { x: 0, opacity: 1, duration: 0.6 })
        .to('.hero__name',
          { clipPath: 'inset(0 0% 0 0)', x: 0, duration: 1.0, ease: 'power4.out' }, '-=0.25')
        .to(lines, { yPercent: 0, opacity: 1, duration: 0.7, stagger: 0.12 }, '-=0.5');
    }

    // Reveal the hero copy instantly, with no entrance — used when arriving via
    // in-site navigation (no preloader curtain to hand off from).
    function revealHeroNow() {
      gsap.set('.hero__eyebrow, .hero__name, .hero__line', { clearProps: 'transform,opacity', opacity: 1 });
    }

    function onPageLoad() {
      // This listener persists across View Transitions, so it also fires on other
      // routes (e.g. project pages) where there is no hero — bail in that case.
      if (!document.querySelector('.hero__name')) return;

      // (Re)start the background video; a blocked autoplay just leaves the poster.
      // On phones we skip the video entirely — the graded poster (~147 KB) is the hero,
      // saving the ~5 MB clip on cellular. preload="none" means nothing loads until we
      // opt in here, so desktop bumps it back to "auto" before playing.
      const video = document.querySelector<HTMLVideoElement>('.hero__media video');
      const isPhone = window.matchMedia('(max-width: 768px)').matches;
      if (!reduce && !isPhone && video) {
        video.preload = 'auto';
        video.play().catch(() => { /* autoplay blocked → poster stays */ });
      }

      // Reduced motion never hid the copy — nothing to reveal.
      if (reduce) { firstLoad = false; return; }

      if (firstLoad) {
        // True refresh: overlap the entrance with the preloader curtain lift.
        let played = false;
        const go = () => { if (!played) { played = true; playHeroIntro(); } };
        window.addEventListener('preloader:done', go, { once: true });
        window.setTimeout(go, 3200); // fallback if the preloader never fires
      } else {
        // Back/forward in-site: no curtain, so just show the copy immediately.
        revealHeroNow();
      }
      firstLoad = false;
    }

    document.addEventListener('astro:page-load', onPageLoad);
  </script>

  <!-- Top-right menu: toggle the section dropdown + smooth-scroll its links. -->
  <script>
    type LenisLike = { scrollTo: (t: Element, o?: object) => void };

    function initNav() {
      const nav = document.querySelector<HTMLElement>('.nav');
      const btn = nav?.querySelector<HTMLButtonElement>('.menu');
      const panel = nav?.querySelector<HTMLElement>('.nav__panel');
      if (!nav || !btn || !panel) return;

      const open = () => {
        nav.dataset.open = 'true';
        btn.setAttribute('aria-expanded', 'true');
        panel.setAttribute('aria-hidden', 'false');
      };
      const close = () => {
        nav.dataset.open = 'false';
        btn.setAttribute('aria-expanded', 'false');
        panel.setAttribute('aria-hidden', 'true');
      };

      // Desktop pointers use hover (open on enter, close on leave); touch devices
      // (no hover) use a click/tap toggle. Splitting them avoids the case where a
      // click closes what hover just opened.
      if (window.matchMedia('(hover: hover) and (pointer: fine)').matches) {
        nav.addEventListener('pointerenter', open);
        nav.addEventListener('pointerleave', close);
      } else {
        btn.addEventListener('click', (e) => {
          e.stopPropagation();
          nav.dataset.open === 'true' ? close() : open();
        });
      }

      // Links: smooth-scroll to the section via Lenis (falls back to native).
      panel.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((a) => {
        a.addEventListener('click', (e) => {
          const target = document.querySelector(a.getAttribute('href') || '');
          if (target) {
            e.preventDefault();
            const lenis = (window as Window & { __lenis?: LenisLike | null }).__lenis;
            lenis ? lenis.scrollTo(target, { duration: 1.2 })
                  : target.scrollIntoView({ behavior: 'smooth' });
          }
          close();
        });
      });

      // Dismiss on outside click or Escape; clean the doc listeners on swap.
      const onDocClick = (e: MouseEvent) => { if (!nav.contains(e.target as Node)) close(); };
      const onKey = (e: KeyboardEvent) => { if (e.key === 'Escape') close(); };
      document.addEventListener('click', onDocClick);
      document.addEventListener('keydown', onKey);
      document.addEventListener('astro:before-swap', () => {
        document.removeEventListener('click', onDocClick);
        document.removeEventListener('keydown', onKey);
      }, { once: true });

      close();
    }

    document.addEventListener('astro:page-load', initNav);
  </script>

  <!-- Body scroll engine: Lenis smooth scroll + ScrollTrigger reveals. -->
  <script>
    import '../scripts/scroll.ts';
  </script>

  <!-- Pointer spotlight: one shared listener feeds the card glow CSS vars. -->
  <script>
    import '../scripts/pointer.ts';
  </script>
</Base>
