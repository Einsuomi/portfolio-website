---
/**
 * /v2 — second UI exploration: "mission control" direction.
 *
 * Same scroll-scrub mechanics as the homepage, different visual language:
 * data-hall corridor frames (public/seq2), Anton condensed display type,
 * HUD telemetry bar, cinematic letterbox, and a chapter progress rail.
 * Hero-only exploration — chapters link back to the homepage sections.
 * If this direction wins, it gets ported into index.astro.
 */
import '@fontsource/anton';

const FRAMES = 120;
---

<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>v2 exploration — Tong Nie</title>

  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg:     #07070a;
      --text:   #edeae2;
      --text-2: #b5b0a8;
      --text-3: #6e6a65;
      --accent: #c9a35a;
      --mono:   ui-monospace,'Cascadia Code','JetBrains Mono','Fira Code',monospace;
      --display:'Anton', 'Arial Narrow', sans-serif;
    }

    html { background: var(--bg); }
    body {
      background: var(--bg); color: var(--text);
      font-family: var(--mono);
      -webkit-font-smoothing: antialiased;
      overflow-x: hidden;
    }

    /* film grain */
    .grain {
      position: fixed; inset: -100%; z-index: 50; pointer-events: none;
      background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 240 240' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
      opacity: 0.05;
      animation: grain 8s steps(10) infinite;
    }
    @keyframes grain {
      0%,100% { transform: translate(0,0); }      20% { transform: translate(-3%,2%); }
      40%     { transform: translate(2%,-3%); }   60% { transform: translate(-2%,-2%); }
      80%     { transform: translate(3%,3%); }
    }

    /* ── HUD telemetry bar — replaces a conventional nav ───────────── */
    .hud-bar {
      position: fixed; top: 0; left: 0; right: 0; z-index: 40;
      display: flex; justify-content: space-between; align-items: center;
      padding: 1rem clamp(1.2rem, 4vw, 3rem);
      font-size: 0.66rem; font-weight: 700; letter-spacing: 0.22em;
      color: var(--text); text-transform: uppercase;
      background: linear-gradient(to bottom, rgba(7,7,10,0.85), transparent);
    }
    .hud-bar .dim { color: var(--text-3); font-weight: 400; }
    .hud-bar em { color: var(--accent); font-style: normal; }
    .hud-bar a { color: var(--text); text-decoration: none; }
    .hud-bar a:hover { color: var(--accent); }

    /* ── pinned stage ──────────────────────────────────────────────── */
    .stage { position: relative; height: 100svh; overflow: hidden; }
    .stage canvas { position: absolute; inset: 0; width: 100%; height: 100%; }

    /* cinematic letterbox bars */
    .bar { position: absolute; left: 0; right: 0; height: clamp(20px, 4vh, 44px); background: #000; z-index: 5; }
    .bar.top { top: 0; }
    .bar.bottom { bottom: 0; }

    /* ── chapters ──────────────────────────────────────────────────── */
    .chapter {
      position: absolute; inset: 0; z-index: 6;
      display: flex; flex-direction: column; justify-content: flex-end;
      padding: clamp(2.5rem, 7vw, 7rem);
      pointer-events: none;
      opacity: 0;
    }
    .chapter::before {
      content: '';
      position: absolute; inset: 0; z-index: -1;
      background: linear-gradient(to top,
        rgba(7,7,10,0.85) 0%, rgba(7,7,10,0.3) 40%, transparent 65%);
    }
    .chapter:not(.intro) { visibility: hidden; }

    .ch-num {
      position: absolute; top: clamp(4rem, 12vh, 7rem); left: clamp(2.5rem, 7vw, 7rem);
      font-family: var(--display);
      font-size: clamp(3rem, 9vw, 8rem); line-height: 1;
      color: transparent;
      -webkit-text-stroke: 1.5px rgba(237,234,226,0.55);   /* outlined index numeral */
    }
    .ch-kicker {
      font-size: 0.72rem; font-weight: 700; letter-spacing: 0.45em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.1rem;
    }
    .chapter h2, .chapter h1 {
      font-family: var(--display);
      font-weight: 400;
      font-size: clamp(4.5rem, 17vw, 16rem);
      line-height: 0.95;
      letter-spacing: 0.01em;
      text-transform: uppercase;
      color: var(--text);
    }
    .ch-copy {
      max-width: 38ch; margin-top: 1.3rem;
      font-size: clamp(0.85rem, 1.2vw, 1rem); line-height: 1.8;
      letter-spacing: 0.04em;
      color: var(--text);
    }
    .ch-view {
      display: inline-block; margin-top: 1.3rem;
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.3em;
      color: var(--accent); text-transform: uppercase;
      transition: transform 0.25s;
    }
    .ch-link { display: block; pointer-events: auto; text-decoration: none; color: inherit; cursor: pointer; }
    .ch-link:hover .ch-view { transform: translateX(8px); }
    .ch-link:hover h2 { text-shadow: 0 0 60px rgba(201,163,90,0.55); }

    .ch-list {
      position: absolute; bottom: clamp(3rem, 9vh, 7rem); right: clamp(2.5rem, 7vw, 7rem);
      list-style: none; text-align: right;
      font-size: 0.78rem; font-weight: 500; letter-spacing: 0.12em;
      color: #fff; line-height: 2.4;
      text-shadow: 0 1px 16px rgba(0,0,0,0.9);
    }
    .ch-list li::after { content: ' —'; color: var(--accent); }
    .chapter.right { align-items: flex-end; text-align: right; }
    .chapter.right .ch-num { left: auto; right: clamp(2.5rem, 7vw, 7rem); }
    .chapter.right .ch-list { right: auto; left: clamp(2.5rem, 7vw, 7rem); text-align: left; }
    .chapter.right .ch-list li::after { content: ''; }
    .chapter.right .ch-list li::before { content: '— '; color: var(--accent); }

    /* intro: name fills the frame, centered block */
    .chapter.intro { justify-content: center; opacity: 1; }
    .chapter.intro::before {
      background: linear-gradient(90deg, rgba(7,7,10,0.75) 0%, rgba(7,7,10,0.3) 50%, transparent 78%);
    }
    .intro-kicker {
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.5em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.5rem;
    }
    .intro-sub {
      display: flex; gap: 2.5rem; flex-wrap: wrap;
      margin-top: 1.8rem;
      font-size: 0.78rem; letter-spacing: 0.14em; line-height: 1.7;
      color: var(--text);
    }
    .intro-sub span::before { content: '— '; color: var(--accent); }
    .intro-ctas { display: flex; gap: 1rem; margin-top: 2.2rem; flex-wrap: wrap; }
    .chapter.intro .intro-ctas { pointer-events: auto; }
    .btn-a {
      padding: 0.85rem 1.6rem; background: var(--accent); color: #07070a;
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      transition: transform 0.15s, box-shadow 0.2s;
    }
    .btn-a:hover { transform: translateY(-1px); box-shadow: 0 8px 24px rgba(201,163,90,0.3); }
    .btn-b {
      padding: 0.85rem 1.6rem; border: 1px solid rgba(237,234,226,0.35); color: var(--text);
      font-size: 0.74rem; font-weight: 700; letter-spacing: 0.12em;
      text-transform: uppercase; text-decoration: none;
      transition: border-color 0.2s;
    }
    .btn-b:hover { border-color: var(--accent); }

    /* ── progress rail on the right edge ───────────────────────────── */
    .rail {
      position: fixed; right: clamp(0.9rem, 2vw, 1.6rem); top: 50%;
      transform: translateY(-50%); z-index: 40;
      display: flex; flex-direction: column; gap: 1.6rem;
      font-size: 0.6rem; font-weight: 700; letter-spacing: 0.2em;
      color: var(--text-3); text-transform: uppercase;
      opacity: 0; transition: opacity 0.4s;
    }
    .rail.on { opacity: 1; }
    .rail span { writing-mode: vertical-rl; transition: color 0.3s; }
    .rail span.active { color: var(--accent); }

    /* ── after the stage ───────────────────────────────────────────── */
    .after {
      min-height: 60vh; display: grid; place-items: center;
      padding: 4rem clamp(1.5rem, 6vw, 6rem); text-align: center;
    }
    .after p { max-width: 56ch; color: var(--text-2); line-height: 1.9; font-size: 0.85rem; letter-spacing: 0.04em; }
    .after a { color: var(--accent); }
    .after .k {
      font-size: 0.7rem; font-weight: 700; letter-spacing: 0.4em;
      color: var(--accent); text-transform: uppercase; margin-bottom: 1.2rem;
    }

    @media (max-width: 640px) {
      .ch-list { display: none; }
      .rail { display: none; }
      .intro-sub { gap: 0.5rem 1.5rem; }
    }

    @media (prefers-reduced-motion: reduce) {
      *, *::before, *::after {
        animation-duration: 0.01ms !important;
        animation-iteration-count: 1 !important;
        transition-duration: 0.01ms !important;
      }
      .chapter:not(.intro) { display: none !important; }
    }
  </style>
</head>

<body>
  <div class="grain"></div>

  <!-- HUD telemetry instead of a nav -->
  <div class="hud-bar">
    <span>Tong<em>.</em>Nie <span class="dim">/ data engineer</span></span>
    <span class="dim" id="hud-seq">SEQ 000 / {FRAMES}</span>
    <a href="/">← current home</a>
  </div>

  <!-- chapter progress rail -->
  <div class="rail" id="rail">
    <span data-i="0" class="active">00 Intro</span>
    <span data-i="1">01 Stack</span>
    <span data-i="2">02 Projects</span>
    <span data-i="3">03 Writing</span>
  </div>

  <main>
    <section class="stage" id="stage">
      <canvas id="seq"></canvas>
      <div class="bar top" aria-hidden="true"></div>
      <div class="bar bottom" aria-hidden="true"></div>

      <!-- 00 · intro -->
      <div class="chapter intro">
        <div class="par">
          <p class="intro-kicker">Data Engineer — Luxembourg / EU</p>
          <h1>Tong Nie</h1>
          <div class="intro-sub">
            <span>3 years in production pipelines</span>
            <span>Azure · Databricks · AWS</span>
            <span>Scroll to enter the hall</span>
          </div>
          <div class="intro-ctas">
            <a class="btn-a" href="/#chat">Ask me anything</a>
            <a class="btn-b" href="/cv">View CV</a>
          </div>
        </div>
      </div>

      <!-- 01 · stack -->
      <div class="chapter">
        <div class="ch-num">01</div>
        <ul class="ch-list">
          <li>Python · SQL · PySpark</li>
          <li>Azure · Databricks · AWS</li>
          <li>Delta Lake · dbt · Terraform</li>
        </ul>
        <a href="/#stack" class="ch-link par">
          <p class="ch-kicker">What I build with</p>
          <h2>Stack</h2>
          <p class="ch-copy">The daily toolkit — cloud, lakehouse, orchestration, BI.</p>
          <span class="ch-view">View stack →</span>
        </a>
      </div>

      <!-- 02 · projects -->
      <div class="chapter right">
        <div class="ch-num">02</div>
        <ul class="ch-list">
          <li>Fingrid Azure Pipeline</li>
          <li>AWS DLT Pipeline</li>
          <li>Power BI CI/CD</li>
          <li>Heureka Sales Analysis</li>
        </ul>
        <a href="/#work" class="ch-link par">
          <p class="ch-kicker">What I've built</p>
          <h2>Projects</h2>
          <p class="ch-copy">Production pipelines on Azure and AWS. Real clients, real data.</p>
          <span class="ch-view">View projects →</span>
        </a>
      </div>

      <!-- 03 · writing -->
      <div class="chapter">
        <div class="ch-num">03</div>
        <ul class="ch-list">
          <li>Deleting a Dependency</li>
          <li>Trust Boundary Before Defensive Coding</li>
        </ul>
        <a href="/#writing" class="ch-link par">
          <p class="ch-kicker">How I think</p>
          <h2>Writing</h2>
          <p class="ch-copy">Engineering decisions worth writing down.</p>
          <span class="ch-view">View writing →</span>
        </a>
      </div>
    </section>

    <section class="after">
      <div>
        <p class="k">End of sequence</p>
        <p>
          UI exploration v2 — "mission control". Condensed display type, HUD telemetry,
          letterbox, progress rail, data-hall frames. Compare with the
          <a href="/">current home page</a> and pick a direction.
        </p>
      </div>
    </section>
  </main>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import Lenis from 'lenis';

    gsap.registerPlugin(ScrollTrigger);

    const FRAMES = 120;
    const canvas = document.getElementById('seq') as HTMLCanvasElement;
    const ctx = canvas.getContext('2d')!;
    const hudSeq = document.getElementById('hud-seq')!;
    const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

    // ── frame loading: frame 0 first, rest stream in ───────────────
    const images: HTMLImageElement[] = [];
    const ready: boolean[] = [];
    let current = 0;

    function loadFrame(i: number) {
      const img = new Image();
      img.onload = () => { ready[i] = true; if (i === current) draw(i); };
      img.src = `/seq2/frame_${String(i).padStart(3, '0')}.jpg`;
      images[i] = img;
    }
    loadFrame(0);
    for (let i = 1; i < FRAMES; i++) loadFrame(i);

    function nearest(i: number): number {
      if (ready[i]) return i;
      for (let d = 1; d < FRAMES; d++) {
        if (ready[i - d]) return i - d;
        if (ready[i + d]) return i + d;
      }
      return -1;
    }

    function draw(target: number) {
      const i = nearest(target);
      if (i < 0) return;
      current = target;
      const img = images[i];
      const cw = canvas.width, ch = canvas.height;
      const scale = Math.max(cw / img.width, ch / img.height);
      const w = img.width * scale, h = img.height * scale;
      ctx.drawImage(img, (cw - w) / 2, (ch - h) / 2, w, h);
      hudSeq.textContent = `SEQ ${String(target).padStart(3, '0')} / ${FRAMES}`;
    }

    function resize() {
      const dpr = Math.min(window.devicePixelRatio || 1, 2);
      canvas.width  = canvas.offsetWidth * dpr;
      canvas.height = canvas.offsetHeight * dpr;
      draw(current);
    }
    window.addEventListener('resize', resize);
    resize();

    // ── smooth scroll ───────────────────────────────────────────────
    const lenis = new Lenis({ lerp: 0.09 });
    lenis.on('scroll', ScrollTrigger.update);
    gsap.ticker.add(t => lenis.raf(t * 1000));
    gsap.ticker.lagSmoothing(0);

    // ── pinned scrub: frames + chapters + rail ─────────────────────
    const railEl = document.getElementById('rail')!;
    const railItems = Array.from(railEl.querySelectorAll('span'));

    if (!reduceMotion) {
      railEl.classList.add('on');
      const chapters = gsap.utils.toArray<HTMLElement>('.chapter');
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: '#stage',
          start: 'top top',
          end: '+=350%',
          pin: true,
          scrub: true,
          onUpdate: self => {
            draw(Math.round(self.progress * (FRAMES - 1)));
            // highlight the rail item for the active chapter window
            const p = self.progress;
            const active = p < 0.14 ? 0 : p < 0.42 ? 1 : p < 0.72 ? 2 : 3;
            railItems.forEach((el, i) => el.classList.toggle('active', i === active));
            // rail fades with the stage
            railEl.classList.toggle('on', self.isActive);
          },
        },
      });

      const windows: [HTMLElement, number, number][] = [
        [chapters[0], 0.00, 0.12],
        [chapters[1], 0.17, 0.40],
        [chapters[2], 0.47, 0.70],
        [chapters[3], 0.78, 1.01],
      ];
      for (const [el, a, b] of windows) {
        if (a > 0) tl.fromTo(el, { autoAlpha: 0, y: 50 }, { autoAlpha: 1, y: 0, duration: 0.06 }, a);
        if (b <= 1) tl.to(el, { autoAlpha: 0, y: -50, duration: 0.06 }, b - 0.06);
      }

      // mouse parallax: scene drifts with the cursor, text drifts against it
      const xc = gsap.quickTo(canvas, 'x', { duration: 0.6, ease: 'power2.out' });
      const yc = gsap.quickTo(canvas, 'y', { duration: 0.6, ease: 'power2.out' });
      window.addEventListener('mousemove', e => {
        const nx = (e.clientX / innerWidth - 0.5), ny = (e.clientY / innerHeight - 0.5);
        xc(nx * 14); yc(ny * 10);
        gsap.to('.par', { x: nx * -10, y: ny * -7, duration: 0.6, ease: 'power2.out', overwrite: 'auto' });
      });
    }

    // intro load-in: kicker, name, facts, buttons stagger up
    gsap.from('.chapter.intro .par > *', {
      opacity: 0, y: 28, stagger: 0.09, duration: 0.8, ease: 'expo.out', delay: 0.2,
      clearProps: 'opacity',   // scrub owns the container, children end clean
    });
  </script>
</body>
</html>
