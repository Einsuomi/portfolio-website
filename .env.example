# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Chatbot provider — two connectors wired; switch with one variable.
#   CHAT_PROVIDER: "deepseek" (testing) or "anthropic" (production)
#   CHAT_MODEL:    optional override; else the provider's default
#                  (deepseek-v4-pro / claude-haiku-4-5)
CHAT_PROVIDER=deepseek
CHAT_MODEL=

# DeepSeek — testing backend (Anthropic-compatible endpoint)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic

# Anthropic — production chatbot backend
ANTHROPIC_API_KEY=

# Supabase — visitor analytics hot tier
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Vercel KV — chatbot rate limiting
VERCEL_KV_REST_API_URL=
VERCEL_KV_REST_API_TOKEN=

# Salt for hashing visitor IPs (any random string, keep it secret)
IP_HASH_SALT=
