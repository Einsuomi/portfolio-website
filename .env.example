# Copy this to .env.local and fill in your values.
# .env.local is gitignored — never commit real secrets.

# Anthropic — chatbot backend
ANTHROPIC_API_KEY=

# Supabase — visitor analytics hot tier
SUPABASE_URL=
SUPABASE_ANON_KEY=

# Vercel KV — chatbot rate limiting
VERCEL_KV_REST_API_URL=
VERCEL_KV_REST_API_TOKEN=

# Salt for hashing visitor IPs (any random string, keep it secret)
IP_HASH_SALT=
