{
  "ci": {
    "collect": {
      "numberOfRuns": 1,
      "settings": {
        "preset": "perf",
        "emulatedFormFactor": "mobile"
      }
    },
    "assert": {
      "assertions": {
        "largest-contentful-paint": ["error", { "maxNumericValue": 2500 }],
        "resource-summary:script:size": ["error", { "maxNumericValue": 307200 }]
      }
    }
  }
}
